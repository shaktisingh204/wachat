{
  "$comment": "Exhaustive RBAC truth-table for SabFlow document-scoped roles. 5 roles x 12 actions = 60 entries. Consumed by rbac-matrix.test.ts which calls canDo(role, action) from ../roles.ts. Update both files together when adding a new action or role.",
  "roles": ["OWNER", "EDITOR", "COMMENTER", "VIEWER", "NONE"],
  "actions": [
    "doc.read",
    "doc.write",
    "doc.delete",
    "doc.share",
    "doc.comment",
    "doc.export",
    "doc.fork",
    "owner.transfer",
    "share_link.create",
    "share_link.revoke",
    "invite.send",
    "credentials.read"
  ],
  "entries": [
    { "role": "OWNER", "action": "doc.read",          "expected": "allow" },
    { "role": "OWNER", "action": "doc.write",         "expected": "allow" },
    { "role": "OWNER", "action": "doc.delete",        "expected": "allow", "note": "Owner is the only doc-role that can destroy the resource." },
    { "role": "OWNER", "action": "doc.share",         "expected": "allow" },
    { "role": "OWNER", "action": "doc.comment",       "expected": "allow" },
    { "role": "OWNER", "action": "doc.export",        "expected": "allow" },
    { "role": "OWNER", "action": "doc.fork",          "expected": "allow" },
    { "role": "OWNER", "action": "owner.transfer",    "expected": "allow", "note": "Only the current owner may hand off ownership." },
    { "role": "OWNER", "action": "share_link.create", "expected": "allow" },
    { "role": "OWNER", "action": "share_link.revoke", "expected": "allow" },
    { "role": "OWNER", "action": "invite.send",       "expected": "allow" },
    { "role": "OWNER", "action": "credentials.read",  "expected": "allow", "note": "Secrets are readable only by the owner; editors must reference by handle." },

    { "role": "EDITOR", "action": "doc.read",          "expected": "allow" },
    { "role": "EDITOR", "action": "doc.write",         "expected": "allow" },
    { "role": "EDITOR", "action": "doc.delete",        "expected": "deny",  "note": "Destructive — owner-only." },
    { "role": "EDITOR", "action": "doc.share",         "expected": "allow" },
    { "role": "EDITOR", "action": "doc.comment",       "expected": "allow" },
    { "role": "EDITOR", "action": "doc.export",        "expected": "allow" },
    { "role": "EDITOR", "action": "doc.fork",          "expected": "allow" },
    { "role": "EDITOR", "action": "owner.transfer",    "expected": "deny",  "note": "Editors cannot reassign ownership." },
    { "role": "EDITOR", "action": "share_link.create", "expected": "allow" },
    { "role": "EDITOR", "action": "share_link.revoke", "expected": "deny",  "note": "Revoking a link is owner-only to prevent collaborator lock-out." },
    { "role": "EDITOR", "action": "invite.send",       "expected": "allow" },
    { "role": "EDITOR", "action": "credentials.read",  "expected": "deny",  "note": "Editors operate on credential handles, never raw secrets." },

    { "role": "COMMENTER", "action": "doc.read",          "expected": "allow" },
    { "role": "COMMENTER", "action": "doc.write",         "expected": "deny" },
    { "role": "COMMENTER", "action": "doc.delete",        "expected": "deny" },
    { "role": "COMMENTER", "action": "doc.share",         "expected": "deny",  "note": "Sharing requires write access." },
    { "role": "COMMENTER", "action": "doc.comment",       "expected": "allow" },
    { "role": "COMMENTER", "action": "doc.export",        "expected": "allow" },
    { "role": "COMMENTER", "action": "doc.fork",          "expected": "allow",  "note": "Fork creates a new doc the user fully owns; safe at commenter level." },
    { "role": "COMMENTER", "action": "owner.transfer",    "expected": "deny" },
    { "role": "COMMENTER", "action": "share_link.create", "expected": "deny" },
    { "role": "COMMENTER", "action": "share_link.revoke", "expected": "deny" },
    { "role": "COMMENTER", "action": "invite.send",       "expected": "deny" },
    { "role": "COMMENTER", "action": "credentials.read",  "expected": "deny" },

    { "role": "VIEWER", "action": "doc.read",          "expected": "allow" },
    { "role": "VIEWER", "action": "doc.write",         "expected": "deny" },
    { "role": "VIEWER", "action": "doc.delete",        "expected": "deny" },
    { "role": "VIEWER", "action": "doc.share",         "expected": "deny" },
    { "role": "VIEWER", "action": "doc.comment",       "expected": "deny",  "note": "Commenting requires the COMMENTER role." },
    { "role": "VIEWER", "action": "doc.export",        "expected": "allow" },
    { "role": "VIEWER", "action": "doc.fork",          "expected": "allow",  "note": "Viewers can branch a snapshot they can already read." },
    { "role": "VIEWER", "action": "owner.transfer",    "expected": "deny" },
    { "role": "VIEWER", "action": "share_link.create", "expected": "deny" },
    { "role": "VIEWER", "action": "share_link.revoke", "expected": "deny" },
    { "role": "VIEWER", "action": "invite.send",       "expected": "deny" },
    { "role": "VIEWER", "action": "credentials.read",  "expected": "deny" },

    { "role": "NONE", "action": "doc.read",          "expected": "deny", "note": "NONE represents users without any doc grant." },
    { "role": "NONE", "action": "doc.write",         "expected": "deny" },
    { "role": "NONE", "action": "doc.delete",        "expected": "deny" },
    { "role": "NONE", "action": "doc.share",         "expected": "deny" },
    { "role": "NONE", "action": "doc.comment",       "expected": "deny" },
    { "role": "NONE", "action": "doc.export",        "expected": "deny" },
    { "role": "NONE", "action": "doc.fork",          "expected": "deny" },
    { "role": "NONE", "action": "owner.transfer",    "expected": "deny" },
    { "role": "NONE", "action": "share_link.create", "expected": "deny" },
    { "role": "NONE", "action": "share_link.revoke", "expected": "deny" },
    { "role": "NONE", "action": "invite.send",       "expected": "deny" },
    { "role": "NONE", "action": "credentials.read",  "expected": "deny" }
  ]
}
