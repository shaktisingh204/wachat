{
  "id": "jotform",
  "name": "JotForm",
  "description": "JotForm API for managing forms, submissions, and webhooks.",
  "category": "Forms",
  "iconName": "LuClipboardList",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "query_token",
    "credentialType": "jotform",
    "queryParam": "apiKey"
  },
  "baseUrl": "https://api.jotform.com",
  "endpoints": [
    {
      "id": "list_forms",
      "label": "List forms",
      "method": "GET",
      "path": "/user/forms",
      "fields": [
        { "id": "offset", "label": "Offset", "type": "number", "in": "query" },
        { "id": "limit", "label": "Limit", "type": "number", "defaultValue": 20, "in": "query" },
        { "id": "filter", "label": "Filter (JSON)", "type": "json", "in": "query" },
        { "id": "orderby", "label": "Order by", "type": "text", "in": "query" }
      ]
    },
    {
      "id": "get_form",
      "label": "Get form",
      "method": "GET",
      "path": "/form/{formId}",
      "fields": [
        { "id": "formId", "label": "Form ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "list_submissions",
      "label": "List submissions",
      "method": "GET",
      "path": "/form/{formId}/submissions",
      "fields": [
        { "id": "formId", "label": "Form ID", "type": "text", "required": true, "in": "path" },
        { "id": "offset", "label": "Offset", "type": "number", "in": "query" },
        { "id": "limit", "label": "Limit", "type": "number", "defaultValue": 20, "in": "query" },
        { "id": "filter", "label": "Filter (JSON)", "type": "json", "in": "query" },
        { "id": "orderby", "label": "Order by", "type": "text", "in": "query" }
      ]
    },
    {
      "id": "get_submission",
      "label": "Get submission",
      "method": "GET",
      "path": "/submission/{submissionId}",
      "fields": [
        { "id": "submissionId", "label": "Submission ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "create_submission",
      "label": "Create submission",
      "method": "POST",
      "path": "/form/{formId}/submissions",
      "fields": [
        { "id": "formId", "label": "Form ID", "type": "text", "required": true, "in": "path" },
        { "id": "submission", "label": "Submission (JSON)", "type": "json", "required": true, "in": "body" }
      ]
    },
    {
      "id": "delete_submission",
      "label": "Delete submission",
      "method": "DELETE",
      "path": "/submission/{submissionId}",
      "fields": [
        { "id": "submissionId", "label": "Submission ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "list_webhooks",
      "label": "List webhooks",
      "method": "GET",
      "path": "/form/{formId}/webhooks",
      "fields": [
        { "id": "formId", "label": "Form ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "add_webhook",
      "label": "Add webhook",
      "method": "POST",
      "path": "/form/{formId}/webhooks",
      "fields": [
        { "id": "formId", "label": "Form ID", "type": "text", "required": true, "in": "path" },
        { "id": "webhookURL", "label": "Webhook URL", "type": "text", "required": true, "in": "body" }
      ]
    }
  ]
}
