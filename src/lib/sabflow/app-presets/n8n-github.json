      "method": "PUT",
      "path": "/repos/{owner}/{repository}/issues/{issueNumber}/lock",
      "fields": [
        {
          "id": "owner",
          "label": "Repository Owner",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "repository",
          "label": "Repository Name",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "issueNumber",
          "label": "Issue Number",
          "type": "number",
          "required": true,
          "description": "The issue number to lock",
          "defaultValue": 0,
          "in": "path"
        },
        {
          "id": "lockReason",
          "label": "Lock Reason",
          "type": "select",
          "description": "The reason for locking the issue",
          "defaultValue": "resolved",
          "options": [
            {
              "value": "off-topic",
              "label": "Off-Topic"
            },
            {
              "value": "too heated",
              "label": "Too Heated"
            },
            {
              "value": "resolved",
              "label": "Resolved"
            },
            {
              "value": "spam",
              "label": "Spam"
            }
          ]
        }
      ],
      "group": "Issue",
      "description": "Lock an issue"
    },
