      "description": "Create a new comment on an issue"
    },
    {
      "id": "issue_edit",
      "label": "Edit Issue",
      "method": "PATCH",
      "path": "/repos/{owner}/{repository}/issues/{issueNumber}",
      "fields": [
        {
          "id": "owner",
          "label": "Repository Owner",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "repository",
          "label": "Repository Name",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "issueNumber",
          "label": "Issue Number",
          "type": "number",
          "required": true,
          "description": "The number of the issue edit",
          "defaultValue": 0,
