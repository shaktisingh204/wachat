{
  "id": "n8n-github",
  "name": "GitHub",
  "description": "Consume GitHub API",
  "category": "dev",
  "iconName": "LuPackage",
  "version": 12,
  "lastVerified": "2026-06-12",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "provider": "github",
    "credentialType": "github",
    "fallback": {
      "type": "header",
      "credentialType": "http_header_auth"
    }
  },
  "baseUrl": "https://api.github.com",
  "endpoints": [
    {
      "id": "organization_get_repositories",
      "label": "Get Repositories Organization",
      "method": "GET",
      "path": "/orgs/{owner}/repos",
      "fields": [
        {
          "id": "owner",
          "label": "Repository Owner",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50
        }
      ],
      "group": "Organization",
      "description": "Returns all repositories of an organization"
    },
    {
      "id": "issue_create",
      "label": "Create Issue",
      "method": "POST",
      "path": "/repos/{owner}/{repository}/issues",
      "fields": [
        {
          "id": "owner",
          "label": "Repository Owner",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "repository",
          "label": "Repository Name",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "title",
          "label": "Title",
          "type": "text",
          "required": true,
          "description": "The title of the issue"
