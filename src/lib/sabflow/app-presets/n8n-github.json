        {
          "id": "body",
          "label": "Body",
          "type": "textarea",
          "description": "The body of the issue"
        },
        {
          "id": "labels",
          "label": "Labels",
          "type": "json",
          "description": "(JSON object; supported keys: label)"
        },
        {
          "id": "assignees",
          "label": "Assignees",
          "type": "json",
          "description": "(JSON object; supported keys: assignee)"
        }
      ],
      "group": "Issue",
      "description": "Create a new issue"
    },
