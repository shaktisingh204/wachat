    { "id": "insights", "label": "Insights", "method": "GET", "path": "/insights/{ip_address}", "fields": [{ "id": "ip_address", "type": "text", "required": true, "in": "path" }] },
    { "id": "me_country", "label": "Me — country", "method": "GET", "path": "/country/me", "fields": [] },
    { "id": "me_city", "label": "Me — city", "method": "GET", "path": "/city/me", "fields": [] }
