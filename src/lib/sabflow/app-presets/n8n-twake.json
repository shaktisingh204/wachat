{
  "id": "n8n-twake",
  "name": "Twake",
  "description": "Consume Twake API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://plugins.twake.app/plugins/n8n",
  "endpoints": [
    {
      "id": "message_send",
      "label": "Send Message",
      "method": "POST",
      "path": "/actions/message/save",
      "fields": [
        {
          "id": "channelId",
          "label": "Channel Name or ID",
          "type": "select",
          "description": "Channel's ID. Choose from the list, or specify an ID using an expression."
        },
        {
          "id": "content",
          "label": "Content",
          "type": "text",
          "required": true,
          "description": "Message content"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: senderIcon, senderName)"
        }
      ],
      "group": "Message",
      "description": "Send a message"
    }
  ]
}
