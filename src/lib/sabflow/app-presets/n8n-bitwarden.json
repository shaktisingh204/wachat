      "id": "collection_delete",
      "label": "Delete Collection",
      "method": "DELETE",
      "path": "/public/collections/{id}",
      "fields": [
        {
          "id": "collectionId",
          "label": "Collection ID",
          "type": "text",
          "required": true,
          "placeholder": "5e59c8c7-e05a-4d17-8e85-acc301343926",
          "description": "The identifier of the collection"
        }
      ],
      "group": "Collection",
      "description": "Delete a collection"
    },
    {
      "id": "collection_get",
      "label": "Get Collection",
      "method": "GET",
      "path": "/public/collections/{id}",
      "fields": [
        {
          "id": "collectionId",
          "label": "Collection ID",
          "type": "text",
          "required": true,
          "placeholder": "5e59c8c7-e05a-4d17-8e85-acc301343926",
          "description": "The identifier of the collection"
        }
      ],
      "group": "Collection",
      "description": "Get a collection"
    },
