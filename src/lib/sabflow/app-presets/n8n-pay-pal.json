{
  "id": "n8n-pay-pal",
  "name": "PayPal",
  "description": "Consume PayPal API",
  "category": "finance",
  "iconName": "LuPackage",
  "version": 12,
  "lastVerified": "2026-06-12",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "provider": "paypal",
    "credentialType": "paypal",
    "fallback": {
      "type": "header",
      "credentialType": "http_header_auth"
    }
  },
  "baseUrl": "https://api-m.sandbox.paypal.com",
  "endpoints": [
    {
      "id": "payout_create",
      "label": "Create Payout",
      "method": "POST",
      "path": "/payments/payouts",
      "fields": [
        {
          "id": "senderBatchId",
          "label": "Sender Batch ID",
          "type": "text",
          "required": true,
          "description": "A sender-specified ID number. Tracks the payout in an accounting system."
        },
        {
          "id": "jsonParameters",
          "label": "JSON Parameters",
          "type": "toggle",
          "defaultValue": false
        },
        {
          "id": "itemsUi",
          "label": "Items",
          "type": "json",
          "placeholder": "Add Item",
          "description": "(JSON object; supported keys: itemsValues, itemsValues.recipientType, itemsValues.receiverValue, itemsValues.currency, itemsValues.amount, itemsValues.note, itemsValues.senderItemId, itemsValues.recipientWallet)"
        },
        {
          "id": "itemsJson",
          "label": "Items",
          "type": "json",
          "description": "An array of individual payout items"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: emailSubject, emailMessage, note)"
        }
      ],
      "group": "Payout",
      "description": "Create a batch payout"
    },
    {
      "id": "payout_get",
      "label": "Get Payout",
      "method": "GET",
      "path": "/payments/payouts/{payoutBatchId}",
      "fields": [
        {
          "id": "payoutBatchId",
          "label": "Payout Batch ID",
          "type": "text",
          "required": true,
          "description": "The ID of the payout for which to show details",
          "in": "path"
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 100
        }
      ],
      "group": "Payout",
      "description": "Show batch payout details"
    },
    {
      "id": "payout_item_cancel",
      "label": "Cancel Payout Item",
      "method": "POST",
      "path": "/payments/payouts-item/{payoutItemId}/cancel",
      "fields": [
        {
          "id": "payoutItemId",
          "label": "Payout Item ID",
          "type": "text",
          "required": true,
          "description": "The ID of the payout item to cancel",
          "in": "path"
        }
      ],
      "group": "Payout Item",
      "description": "Cancels an unclaimed payout item"
    },
    {
      "id": "payout_item_get",
      "label": "Get Payout Item",
      "method": "GET",
      "path": "/payments/payouts-item/{payoutItemId}",
      "fields": [
        {
          "id": "payoutItemId",
          "label": "Payout Item ID",
          "type": "text",
          "required": true,
          "description": "The ID of the payout item for which to show details",
          "in": "path"
        }
      ],
      "group": "Payout Item",
      "description": "Show payout item details"
    }
  ]
}
