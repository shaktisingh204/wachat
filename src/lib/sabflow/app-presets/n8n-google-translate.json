{
  "id": "n8n-google-translate",
  "name": "Google Translate",
  "description": "Translate data using Google Translate",
  "category": "ai",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "provider": "google",
    "credentialType": "google_sheets",
    "fallback": {
      "type": "header",
      "credentialType": "http_header_auth"
    }
  },
  "baseUrl": "https://translation.googleapis.com",
  "endpoints": [
    {
      "id": "language_translate",
      "label": "Translate Language",
      "method": "POST",
      "path": "/language/translate/v2",
      "fields": [
        {
          "id": "text",
          "label": "Text",
          "type": "text",
          "required": true,
          "description": "The input text to translate"
        },
        {
          "id": "translateTo",
          "label": "Translate To",
          "type": "select",
          "required": true,
          "description": "The language to use for translation of the input text, set to one of the language codes listed in Language Support. Choose from the list, or specify an ID using an expression."
        }
      ],
      "group": "Language",
      "description": "Translate data"
    }
  ]
}
