{
  "id": "n8n-twilio",
  "name": "Twilio",
  "description": "Send SMS and WhatsApp messages or make phone calls",
  "category": "communication",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://api.twilio.com/2010-04-01",
  "endpoints": [
    {
      "id": "sms_send",
      "label": "Send SMS",
      "method": "POST",
      "path": "/Messages.json",
      "fields": [
        {
          "id": "from",
          "label": "From",
          "type": "text",
          "required": true,
          "placeholder": "+14155238886",
          "description": "The number from which to send the message"
        },
        {
          "id": "to",
          "label": "To",
          "type": "text",
          "required": true,
          "placeholder": "+14155238886",
          "description": "The number to which to send the message"
        },
        {
          "id": "toWhatsapp",
          "label": "To Whatsapp",
          "type": "toggle",
          "description": "Whether the message should be sent to WhatsApp",
          "defaultValue": false
        },
        {
          "id": "message",
          "label": "Message",
          "type": "text",
          "required": true,
          "description": "The message to send"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: statusCallback)"
        }
      ],
      "group": "SMS",
      "description": "Send SMS/MMS/WhatsApp message"
    },
    {
      "id": "call_make",
      "label": "Make Call",
      "method": "POST",
      "path": "/Calls.json",
      "fields": [
        {
          "id": "from",
          "label": "From",
          "type": "text",
          "required": true,
          "placeholder": "+14155238886",
          "description": "The number from which to send the message"
        },
        {
          "id": "to",
          "label": "To",
          "type": "text",
          "required": true,
          "placeholder": "+14155238886",
          "description": "The number to which to send the message"
        },
        {
          "id": "twiml",
          "label": "Use TwiML",
          "type": "toggle",
          "description": "Whether to use the Twilio Markup Language in the message",
          "defaultValue": false
        },
        {
          "id": "message",
          "label": "Message",
          "type": "text",
          "required": true
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: statusCallback)"
        }
      ],
      "group": "Call",
      "description": "Make a call"
    }
  ]
}
