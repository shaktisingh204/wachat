      "id": "contact_create",
      "label": "Create Contact",
      "method": "POST",
      "path": "/contact",
      "fields": [
        {
          "id": "subdomain",
          "label": "Subdomain",
          "type": "text",
          "required": true,
          "in": "path",
          "description": "Subdomain of your Agile CRM account (host token in the API base URL)"
        },
        {
          "id": "jsonParameters",
          "label": "JSON Parameters",
          "type": "toggle",
          "defaultValue": false
        },
        {
          "id": "additionalFieldsJson",
          "label": "Additional Fields",
          "type": "json",
          "description": "Object of values to set as described here"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: addressOptions, company, emailOptions, firstName, lastName, leadScore, starValue, phoneOptions, tags, title, websiteOptions, customProperties)"
        }
      ],
      "group": "Contact",
      "description": "[unverified path] Create a new contact"
    },
    {
