{
  "id": "n8n-google-books",
  "name": "Google Books",
  "description": "Read data from Google Books",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "provider": "google",
    "credentialType": "google_sheets",
    "fallback": {
      "type": "header",
      "credentialType": "http_header_auth"
    }
  },
  "baseUrl": "https://www.googleapis.com/books",
  "endpoints": [
    {
      "id": "bookshelf_get",
      "label": "Get Bookshelf",
      "method": "GET",
      "path": "/v1/users/{userId}/bookshelves/{shelfId}",
      "fields": [
        {
          "id": "myLibrary",
          "label": "My Library",
          "type": "toggle",
          "required": true,
          "defaultValue": false
        },
        {
          "id": "userId",
          "label": "User ID",
          "type": "text",
          "required": true,
          "description": "ID of user",
          "in": "path"
        },
        {
          "id": "shelfId",
          "label": "Bookshelf ID",
          "type": "text",
          "required": true,
          "description": "ID of the bookshelf",
          "in": "path"
        }
      ],
      "group": "Bookshelf",
      "description": "Retrieve a specific bookshelf resource for the specified user"
    },
    {
      "id": "bookshelf_get_all",
      "label": "Get Many Bookshelf",
      "method": "GET",
      "path": "/v1/users/{userId}/bookshelves",
      "fields": [
        {
          "id": "myLibrary",
          "label": "My Library",
          "type": "toggle",
          "required": true,
          "defaultValue": false
        },
        {
          "id": "userId",
          "label": "User ID",
          "type": "text",
          "required": true,
          "description": "ID of user",
          "in": "path"
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 40
        }
      ],
      "group": "Bookshelf",
      "description": "Get many public bookshelf resource for the specified user"
    },
    {
      "id": "bookshelf_volume_add",
      "label": "Add Bookshelf Volume",
      "method": "POST",
      "path": "/v1/mylibrary/bookshelves/{shelfId}/addVolume",
      "fields": [
        {
          "id": "shelfId",
          "label": "Bookshelf ID",
          "type": "text",
          "required": true,
          "description": "ID of the bookshelf",
          "in": "path"
        },
        {
          "id": "volumeId",
          "label": "Volume ID",
          "type": "text",
          "required": true,
          "description": "ID of the volume"
        }
      ],
      "group": "Bookshelf Volume",
      "description": "Add a volume to a bookshelf"
    },
    {
      "id": "bookshelf_volume_clear",
      "label": "Clear Bookshelf Volume",
      "method": "POST",
      "path": "/v1/mylibrary/bookshelves/{shelfId}/clearVolumes",
      "fields": [
        {
          "id": "shelfId",
          "label": "Bookshelf ID",
          "type": "text",
          "required": true,
          "description": "ID of the bookshelf",
          "in": "path"
        }
      ],
      "group": "Bookshelf Volume",
      "description": "Clears all volumes from a bookshelf"
    },
    {
      "id": "bookshelf_volume_get_all",
      "label": "Get Many Bookshelf Volume",
      "method": "GET",
      "path": "/v1/users/{userId}/bookshelves/{shelfId}/volumes",
      "fields": [
        {
          "id": "myLibrary",
          "label": "My Library",
          "type": "toggle",
          "required": true,
          "defaultValue": false
        },
        {
          "id": "userId",
          "label": "User ID",
          "type": "text",
          "required": true,
          "description": "ID of user",
          "in": "path"
        },
        {
          "id": "shelfId",
          "label": "Bookshelf ID",
          "type": "text",
          "required": true,
          "description": "ID of the bookshelf",
          "in": "path"
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 40
        }
      ],
      "group": "Bookshelf Volume",
      "description": "Get many volumes in a specific bookshelf for the specified user"
    },
    {
      "id": "bookshelf_volume_move",
      "label": "Move Bookshelf Volume",
      "method": "POST",
      "path": "/v1/mylibrary/bookshelves/{shelfId}/moveVolume",
      "fields": [
        {
          "id": "shelfId",
          "label": "Bookshelf ID",
          "type": "text",
          "required": true,
          "description": "ID of the bookshelf",
          "in": "path"
        },
        {
          "id": "volumeId",
          "label": "Volume ID",
          "type": "text",
          "required": true,
          "description": "ID of the volume"
        },
        {
          "id": "volumePosition",
          "label": "Volume Position",
          "type": "text",
          "required": true,
          "description": "Position on shelf to move the item (0 puts the item before the current first item, 1 puts it between the first and the second and so on)"
        }
      ],
      "group": "Bookshelf Volume",
      "description": "Moves a volume within a bookshelf"
    },
    {
      "id": "bookshelf_volume_remove",
      "label": "Remove Bookshelf Volume",
      "method": "POST",
      "path": "/v1/mylibrary/bookshelves/{shelfId}/removeVolume",
      "fields": [
        {
          "id": "shelfId",
          "label": "Bookshelf ID",
          "type": "text",
          "required": true,
          "description": "ID of the bookshelf",
          "in": "path"
        },
        {
          "id": "volumeId",
          "label": "Volume ID",
          "type": "text",
          "required": true,
          "description": "ID of the volume"
        }
      ],
      "group": "Bookshelf Volume",
      "description": "Removes a volume from a bookshelf"
    },
    {
      "id": "volume_get",
      "label": "Get Volume",
      "method": "GET",
      "path": "/v1/volumes/{volumeId}",
      "fields": [
        {
          "id": "volumeId",
          "label": "Volume ID",
          "type": "text",
          "required": true,
          "description": "ID of the volume",
          "in": "path"
        }
      ],
      "group": "Volume",
      "description": "Get a volume resource based on ID"
    },
    {
      "id": "volume_get_all",
      "label": "Get Many Volume",
      "method": "GET",
      "path": "/v1/volumes?q={searchQuery}",
      "fields": [
        {
          "id": "searchQuery",
          "label": "Search Query",
          "type": "text",
          "required": true,
          "description": "Full-text search query string",
          "in": "path"
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 40
        }
      ],
      "group": "Volume",
      "description": "Get many volumes filtered by query"
    }
  ]
}
