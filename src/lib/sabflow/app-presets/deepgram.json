{
  "id": "deepgram",
  "name": "Deepgram",
  "description": "Deepgram speech-to-text, TTS, and model management API.",
  "category": "AI",
  "iconName": "LuMic",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "header",
    "credentialType": "deepgram",
    "header": "Authorization",
    "scheme": "Token"
  },
  "baseUrl": "https://api.deepgram.com/v1",
  "endpoints": [
    {
      "id": "transcribe_from_url",
      "label": "Transcribe from URL",
      "method": "POST",
      "path": "/listen",
      "fields": [
        { "id": "url", "label": "Audio URL", "type": "text", "required": true, "in": "body" },
        { "id": "punctuate", "label": "Punctuate", "type": "toggle", "in": "query" },
        { "id": "model", "label": "Model", "type": "select", "in": "query", "defaultValue": "nova-2" },
        { "id": "detect_language", "label": "Detect language", "type": "toggle", "in": "query" },
        { "id": "diarize", "label": "Diarize", "type": "toggle", "in": "query" }
      ]
    },
    {
      "id": "tts",
      "label": "Text to speech",
      "method": "POST",
      "path": "/speak",
      "fields": [
        { "id": "model", "label": "Model", "type": "text", "in": "query" },
        { "id": "text", "label": "Text", "type": "textarea", "required": true, "in": "body" }
      ]
    },
    {
      "id": "list_projects",
      "label": "List projects",
      "method": "GET",
      "path": "/projects",
      "fields": []
    },
    {
      "id": "get_balance",
      "label": "Get project balance",
      "method": "GET",
      "path": "/projects/{project_id}/balances",
      "fields": [
        { "id": "project_id", "label": "Project ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "list_models",
      "label": "List models",
      "method": "GET",
      "path": "/models",
      "fields": []
    }
  ]
}
