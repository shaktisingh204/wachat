{
  "id": "airvisual",
  "name": "IQAir AirVisual",
  "description": "Real-time air quality data.",
  "category": "Weather",
  "iconName": "LuCloud",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": { "type": "query_token", "credentialType": "airvisual", "queryParam": "key" },
  "baseUrl": "https://api.airvisual.com/v2",
  "endpoints": [
    { "id": "nearest_city", "label": "Nearest city", "method": "GET", "path": "/nearest_city", "fields": [{ "id": "lat", "type": "number", "in": "query" }, { "id": "lon", "type": "number", "in": "query" }] },
    { "id": "city", "label": "City", "method": "GET", "path": "/city", "fields": [{ "id": "city", "type": "text", "required": true, "in": "query" }, { "id": "state", "type": "text", "required": true, "in": "query" }, { "id": "country", "type": "text", "required": true, "in": "query" }] },
    { "id": "countries", "label": "List countries", "method": "GET", "path": "/countries", "fields": [] },
    { "id": "states", "label": "List states", "method": "GET", "path": "/states", "fields": [{ "id": "country", "type": "text", "required": true, "in": "query" }] },
    { "id": "cities", "label": "List cities", "method": "GET", "path": "/cities", "fields": [{ "id": "state", "type": "text", "required": true, "in": "query" }, { "id": "country", "type": "text", "required": true, "in": "query" }] },
    { "id": "nearest_station", "label": "Nearest station", "method": "GET", "path": "/nearest_station", "fields": [{ "id": "lat", "type": "number", "in": "query" }, { "id": "lon", "type": "number", "in": "query" }] }
  ]
}
