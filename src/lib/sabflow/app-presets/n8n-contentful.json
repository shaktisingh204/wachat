{
  "id": "n8n-contentful",
  "name": "Contentful",
  "description": "Consume Contentful API",
  "category": "productivity",
  "iconName": "LuPackage",
  "version": 2,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://cdn.contentful.com",
  "endpoints": [
    {
      "id": "space_get",
      "label": "Get Space",
      "method": "GET",
      "path": "/spaces/{credentials__spaceId}",
      "fields": [
        {
          "id": "source",
          "label": "Source",
          "type": "select",
          "description": "Pick where your data comes from, delivery or preview API",
          "defaultValue": "deliveryApi",
          "options": [
            {
              "value": "deliveryApi",
              "label": "Delivery API"
            },
            {
              "value": "previewApi",
              "label": "Preview API"
            }
          ]
        }
      ],
      "group": "Space",
      "description": "[unverified path]"
    },
    {
      "id": "content_type_get",
      "label": "Get Content Type",
      "method": "GET",
      "path": "/spaces/{credentials__spaceId}/environments/{env}/content_types/{id}",
      "fields": [
        {
          "id": "source",
          "label": "Source",
          "type": "select",
          "description": "Pick where your data comes from, delivery or preview API",
          "defaultValue": "deliveryApi",
          "options": [
            {
              "value": "deliveryApi",
              "label": "Delivery API"
            },
            {
              "value": "previewApi",
              "label": "Preview API"
            }
          ]
        },
        {
          "id": "environmentId",
          "label": "Environment ID",
          "type": "text",
          "description": "The ID for the Contentful environment (e.g. master, staging, etc.). Depending on your plan, you might not have environments. In that case use \"master\".",
          "defaultValue": "master"
        },
        {
          "id": "contentTypeId",
          "label": "Content Type ID",
          "type": "text",
          "required": true
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: rawData)"
        }
      ],
      "group": "Content Type",
      "description": "[unverified path]"
    },
