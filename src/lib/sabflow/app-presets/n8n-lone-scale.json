{
  "id": "n8n-lone-scale",
  "name": "LoneScale",
  "description": "Create List, add / delete items",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://public-api.lonescale.com",
  "endpoints": [
    {
      "id": "list_create",
      "label": "Create List",
      "method": "POST",
      "path": "/lists",
      "fields": [
        {
          "id": "name",
          "label": "Name",
          "type": "text",
          "required": true,
          "placeholder": "list name",
          "description": "Name of your list"
        },
        {
          "id": "type",
          "label": "Type",
          "type": "select",
          "required": true,
          "description": "Type of your list",
          "defaultValue": "COMPANY",
          "options": [
            {
              "value": "COMPANY",
              "label": "Company"
            },
            {
              "value": "PEOPLE",
              "label": "Contact"
            }
          ]
        }
      ],
      "group": "List",
      "description": "Create a list"
    },
    {
      "id": "item_add",
      "label": "Create Item",
      "method": "POST",
      "path": "/lists/{listId}/item",
      "fields": [
        {
          "id": "type",
          "label": "Type",
          "type": "select",
          "required": true,
          "description": "Type of your list",
          "defaultValue": "PEOPLE",
          "options": [
            {
              "value": "COMPANY",
              "label": "Company"
            },
            {
              "value": "PEOPLE",
              "label": "Contact"
            }
          ]
        },
        {
          "id": "list",
          "label": "List Name or ID",
          "type": "select",
          "required": true,
          "description": "Choose from the list, or specify an ID using an expression"
        },
        {
          "id": "first_name",
          "label": "First Name",
          "type": "text",
          "required": true,
          "description": "Contact first name"
        },
        {
          "id": "last_name",
          "label": "Last Name",
          "type": "text",
          "required": true,
          "description": "Contact last name"
        },
        {
          "id": "company_name",
          "label": "Company Name",
          "type": "text",
          "description": "Contact company name"
        },
        {
          "id": "peopleAdditionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: full_name, email, company_name, current_position, domain, linkedin_url, location, contact_id)"
        },
        {
          "id": "companyAdditionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: linkedin_url, domain, location, contact_id)"
        }
      ],
      "group": "Item",
      "description": "Create an item"
    }
  ]
}
