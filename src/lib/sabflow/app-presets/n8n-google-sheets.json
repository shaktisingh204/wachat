{
  "id": "n8n-google-sheets",
  "name": "Google Sheets",
  "description": "Read, update and write data to Google Sheets",
  "category": "productivity",
  "iconName": "LuPackage",
  "version": 12,
  "lastVerified": "2026-06-12",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "provider": "google",
    "credentialType": "google_sheets",
    "fallback": {
      "type": "none"
    }
  },
  "baseUrl": "https://sheets.googleapis.com",
  "endpoints": [
    {
      "id": "sheet_append",
      "label": "Append Row Sheet Within Document",
      "method": "POST",
      "path": "/v4/spreadsheets/{documentId}/values/{sheetName}:append",
      "fields": [
        {
          "id": "documentId",
          "label": "Document",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "sheetName",
          "label": "Sheet",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "dataMode",
          "label": "Data Mode",
          "type": "select",
          "description": "Whether to insert the input data this node receives in the new row",
          "defaultValue": "defineBelow",
          "options": [
            {
              "value": "autoMapInputData",
              "label": "Auto-Map Input Data to Columns"
            },
            {
              "value": "defineBelow",
              "label": "Map Each Column Below"
            },
            {
              "value": "nothing",
              "label": "Nothing"
            }
          ]
        },
        {
          "id": "fieldsUi",
          "label": "Fields to Send",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: fieldValues, fieldValues.fieldId, fieldValues.fieldValue)"
        },
        {
          "id": "columns",
          "label": "Columns",
          "type": "json",
          "required": true,
          "description": "(JSON)"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: cellFormat, locationDefine, handlingExtraData, useAppend)"
        }
      ],
      "group": "Sheet Within Document",
      "description": "Create a new row in a sheet"
    },
    {
      "id": "sheet_clear",
      "label": "Clear Sheet Within Document",
      "method": "POST",
      "path": "/v4/spreadsheets/{documentId}/values/{range}:clear",
      "fields": [
        {
          "id": "documentId",
          "label": "Document",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "sheetName",
          "label": "Sheet",
          "type": "text",
          "required": true,
          "description": "(provide the ID)"
        },
        {
          "id": "clear",
          "label": "Clear",
          "type": "select",
          "description": "What to clear",
          "defaultValue": "wholeSheet",
          "options": [
            {
              "value": "wholeSheet",
              "label": "Whole Sheet"
            },
            {
              "value": "specificRows",
              "label": "Specific Rows"
            },
            {
              "value": "specificColumns",
              "label": "Specific Columns"
            },
            {
              "value": "specificRange",
              "label": "Specific Range"
            }
          ]
        },
        {
          "id": "keepFirstRow",
          "label": "Keep First Row",
          "type": "toggle",
          "defaultValue": false
        },
        {
          "id": "startIndex",
          "label": "Start Row Number",
          "type": "number",
          "description": "The row number to delete from, The first row is 1",
          "defaultValue": 1
        },
        {
          "id": "rowsToDelete",
          "label": "Number of Rows to Delete",
          "type": "number",
          "defaultValue": 1
        },
        {
          "id": "columnsToDelete",
          "label": "Number of Columns to Delete",
          "type": "number",
          "defaultValue": 1
        },
        {
          "id": "range",
          "label": "Range",
          "type": "text",
          "required": true,
          "description": "The table range to read from or to append data to. See the Google documentation for the details. If it contains multiple sheets it can also be added like this: \"MySheet!A:F\"",
          "defaultValue": "A:F",
          "in": "path"
        }
      ],
      "group": "Sheet Within Document",
      "description": "Delete all the contents or a part of a sheet"
    },
    {
      "id": "sheet_create",
      "label": "Create Sheet Within Document",
      "method": "POST",
      "path": "/v4/spreadsheets/{documentId}:batchUpdate",
      "fields": [
        {
          "id": "documentId",
          "label": "Document",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "title",
          "label": "Title",
          "type": "text",
          "required": true,
          "description": "The name of the sheet",
          "defaultValue": "n8n-sheet"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: hidden, rightToLeft, sheetId, index, tabColor)"
        }
      ],
      "group": "Sheet Within Document",
      "description": "Create a new sheet"
    },
    {
      "id": "sheet_remove",
      "label": "Delete Sheet Within Document",
      "method": "POST",
      "path": "/v4/spreadsheets/{documentId}:batchUpdate",
      "fields": [
        {
          "id": "documentId",
          "label": "Document",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "sheetName",
          "label": "Sheet",
          "type": "text",
          "required": true,
          "description": "(provide the ID)"
        }
      ],
      "group": "Sheet Within Document",
      "description": "Permanently delete a sheet"
    },
    {
      "id": "sheet_delete",
      "label": "Delete Rows or Columns Sheet Within Document",
      "method": "POST",
      "path": "/v4/spreadsheets/{documentId}:batchUpdate",
      "fields": [
        {
          "id": "documentId",
          "label": "Document",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "sheetName",
          "label": "Sheet",
          "type": "text",
          "required": true,
          "description": "(provide the ID)"
        },
        {
          "id": "toDelete",
          "label": "To Delete",
          "type": "select",
          "description": "What to delete",
          "defaultValue": "rows",
          "options": [
            {
              "value": "rows",
              "label": "Rows"
            },
            {
              "value": "columns",
              "label": "Columns"
            }
          ]
        },
        {
          "id": "startIndex",
          "label": "Start Row Number",
          "type": "number",
          "description": "The row number to delete from, The first row is 2",
          "defaultValue": 2
        },
        {
          "id": "numberToDelete",
          "label": "Number of Rows to Delete",
          "type": "number",
          "defaultValue": 1
        }
      ],
      "group": "Sheet Within Document",
      "description": "Delete columns or rows from a sheet"
    },
    {
      "id": "sheet_read",
      "label": "Get Row(s) Sheet Within Document",
      "method": "GET",
      "path": "/v4/spreadsheets/{documentId}/values/{sheetName}",
      "fields": [
        {
          "id": "documentId",
          "label": "Document",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "sheetName",
          "label": "Sheet",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "filtersUI",
          "label": "Filters",
          "type": "json",
          "placeholder": "Add Filter",
          "description": "(JSON object; supported keys: values, values.lookupColumn, values.lookupValue)"
        },
        {
          "id": "combineFilters",
          "label": "Combine Filters",
          "type": "select",
          "description": "How to combine the conditions defined in \"Filters\": AND requires all conditions to be true, OR requires at least one condition to be true",
          "defaultValue": "OR",
          "options": [
            {
              "value": "AND",
              "label": "AND"
            },
            {
              "value": "OR",
              "label": "OR"
            }
          ]
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: dataLocationOnSheet, outputFormatting, returnFirstMatch, returnAllMatches)"
        }
      ],
      "group": "Sheet Within Document",
      "description": "Retrieve one or more rows from a sheet"
    },
    {
      "id": "spreadsheet_create",
      "label": "Create Document",
      "method": "POST",
      "path": "/v4/spreadsheets",
      "fields": [
        {
          "id": "title",
          "label": "Title",
          "type": "text",
          "description": "The title of the spreadsheet"
        },
        {
          "id": "sheetsUi",
          "label": "Sheets",
          "type": "json",
          "placeholder": "Add Sheet",
          "description": "(JSON object; supported keys: sheetValues, sheetValues.title, sheetValues.hidden)"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: locale, autoRecalc)"
        }
      ],
      "group": "Document",
      "description": "Create a spreadsheet"
    }
  ]
}
