  "baseUrl": "https://{account}.documents.azure.com/dbs",
  "endpoints": [
    {
      "id": "container_create",
      "label": "Create Container",
      "method": "POST",
      "path": "/colls",
      "fields": [
        {
          "id": "account",
          "label": "Account",
          "type": "text",
          "required": true,
          "in": "path",
          "description": "Account of your Azure Cosmos DB account (host token in the API base URL)"
        }
      ],
      "group": "Container",
      "description": "Create a container"
    },
    {
      "id": "container_delete",
      "label": "Delete Container",
      "method": "DELETE",
      "path": "/colls/{{ {container} }}",
      "fields": [
        {
          "id": "account",
          "label": "Account",
          "type": "text",
          "required": true,
          "in": "path",
          "description": "Account of your Azure Cosmos DB account (host token in the API base URL)"
        }
      ],
      "group": "Container",
      "description": "[unverified path] Delete a container"
    },
    {
      "id": "container_get",
      "label": "Get Container",
      "method": "GET",
      "path": "/colls/{{ {container} }}",
      "fields": [
        {
          "id": "account",
          "label": "Account",
          "type": "text",
          "required": true,
          "in": "path",
          "description": "Account of your Azure Cosmos DB account (host token in the API base URL)"
