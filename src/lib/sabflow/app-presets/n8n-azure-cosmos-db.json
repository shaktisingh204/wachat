    {
      "id": "item_get",
      "label": "Get Item",
      "method": "GET",
      "path": "/colls/{{ {container}}}/docs/{{{item}}}",
      "fields": [
        {
          "id": "account",
          "label": "Account",
          "type": "text",
          "required": true,
          "in": "path",
          "description": "Account of your Azure Cosmos DB account (host token in the API base URL)"
        }
      ],
      "group": "Item",
      "description": "[unverified path] Retrieve an item"
    },
    {
      "id": "item_get_all",
