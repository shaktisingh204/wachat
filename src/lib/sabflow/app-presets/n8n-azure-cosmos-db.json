    },
    {
      "id": "item_query",
      "label": "Execute Query Item",
      "method": "POST",
      "path": "/colls/{{ {container} }}/docs",
      "fields": [
        {
          "id": "account",
          "label": "Account",
          "type": "text",
          "required": true,
          "in": "path",
          "description": "Account of your Azure Cosmos DB account (host token in the API base URL)"
        }
      ],
      "group": "Item",
      "description": "[unverified path] Query items"
    },
    {
      "id": "item_update",
      "label": "Update Item",
      "method": "PUT",
      "path": "/colls/{{ {container} }}/docs/{{ {item} }}",
      "fields": [
        {
          "id": "account",
          "label": "Account",
          "type": "text",
          "required": true,
          "in": "path",
