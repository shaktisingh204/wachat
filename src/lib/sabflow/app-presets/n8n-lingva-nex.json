{
  "id": "n8n-lingva-nex",
  "name": "LingvaNex",
  "description": "Consume LingvaNex API",
  "category": "ai",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://api-b2b.backenster.com/b1/api/v3",
  "endpoints": [
    {
      "id": "translate",
      "label": "Translate",
      "method": "POST",
      "path": "/translate",
      "fields": [
        {
          "id": "text",
          "label": "Text",
          "type": "text",
          "required": true,
          "description": "The input text to translate"
        },
        {
          "id": "translateTo",
          "label": "Translate To",
          "type": "select",
          "required": true,
          "description": "The language to use for translation of the input text, set to one of the language codes listed in Language Support. Choose from the list, or specify an ID using an expression."
        },
        {
          "id": "options",
          "label": "Additional Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: from, platform, translateMode)"
        }
      ],
      "description": "Translate data"
    }
  ]
}
