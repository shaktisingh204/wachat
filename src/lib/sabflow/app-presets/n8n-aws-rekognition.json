{
  "id": "n8n-aws-rekognition",
  "name": "AWS Rekognition",
  "description": "Sends data to AWS Rekognition",
  "category": "dev",
  "iconName": "LuPackage",
  "version": 2,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "aws_sigv4",
    "credentialType": "aws",
    "awsService": "rekognition"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "image_analyze",
      "label": "Analyze Image",
      "method": "POST",
      "path": "/image",
      "fields": [
        {
          "id": "type",
          "label": "Type",
          "type": "select",
          "defaultValue": "detectFaces",
          "options": [
            {
              "value": "detectFaces",
              "label": "Detect Faces"
            },
            {
              "value": "detectLabels",
              "label": "Detect Labels"
            },
            {
              "value": "detectModerationLabels",
              "label": "Detect Moderation Labels"
            },
            {
              "value": "detectText",
              "label": "Detect Text"
            },
            {
              "value": "recognizeCelebrity",
              "label": "Recognize Celebrity"
            }
          ]
        },
        {
          "id": "binaryData",
          "label": "Binary File",
          "type": "toggle",
          "required": true,
          "description": "Whether the image to analyze should be taken from binary field",
          "defaultValue": false
        },
        {
          "id": "binaryPropertyName",
          "label": "Input Binary Field",
          "type": "text",
          "required": true,
          "defaultValue": "data"
        },
        {
          "id": "bucket",
          "label": "Bucket",
          "type": "text",
          "required": true,
          "description": "Name of the S3 bucket"
        },
        {
          "id": "name",
          "label": "Name",
          "type": "text",
          "required": true,
          "description": "S3 object key name"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: regionsOfInterestUi, version, wordFilterUi, maxLabels, minConfidence, attributes)"
        }
      ],
      "group": "Image",
      "description": "[unverified path]"
    }
  ]
}
