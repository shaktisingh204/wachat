{
  "id": "n8n-aws-rekognition",
  "name": "AWS Rekognition",
  "description": "Sends data to AWS Rekognition",
  "category": "dev",
  "iconName": "LuPackage",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "draft",
  "auth": {
    "type": "none"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "image_analyze",
      "label": "Analyze Image",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "type",
          "label": "Type",
          "type": "select",
          "in": "query",
          "defaultValue": "detectFaces",
          "options": [
            {
              "value": "detectFaces",
              "label": "Detect Faces"
            },
            {
              "value": "detectLabels",
              "label": "Detect Labels"
            },
            {
              "value": "detectModerationLabels",
              "label": "Detect Moderation Labels"
            },
            {
              "value": "detectText",
              "label": "Detect Text"
            },
            {
              "value": "recognizeCelebrity",
              "label": "Recognize Celebrity"
            }
          ]
        },
        {
          "id": "binaryData",
          "label": "Binary File",
          "type": "toggle",
          "in": "query",
          "required": true,
          "description": "Whether the image to analyze should be taken from binary field",
          "defaultValue": false
        },
        {
          "id": "binaryPropertyName",
          "label": "Input Binary Field",
          "type": "text",
          "in": "query",
          "required": true,
          "defaultValue": "data"
        },
        {
          "id": "bucket",
          "label": "Bucket",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "Name of the S3 bucket"
        },
        {
          "id": "name",
          "label": "Name",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "S3 object key name"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "in": "query",
          "placeholder": "Add Field"
        }
      ]
    }
  ]
}
