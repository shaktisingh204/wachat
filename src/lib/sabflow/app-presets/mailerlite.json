{
  "id": "mailerlite",
  "name": "MailerLite",
  "description": "MailerLite email marketing API.",
  "category": "Email marketing",
  "iconName": "LuMail",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "bearer",
    "credentialType": "mailerlite"
  },
  "baseUrl": "https://connect.mailerlite.com/api",
  "endpoints": [
    {
      "id": "list_subscribers",
      "label": "List subscribers",
      "method": "GET",
      "path": "/subscribers",
      "fields": [
        { "id": "limit", "label": "Limit", "type": "number", "defaultValue": 25, "in": "query" },
        { "id": "page", "label": "Page", "type": "number", "defaultValue": 1, "in": "query" },
        { "id": "filter[status]", "label": "Status filter", "type": "text", "in": "query" }
      ]
    },
    {
      "id": "get_subscriber",
      "label": "Get subscriber",
      "method": "GET",
      "path": "/subscribers/{id}",
      "fields": [
        { "id": "id", "label": "Subscriber ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "upsert_subscriber",
      "label": "Upsert subscriber",
      "method": "POST",
      "path": "/subscribers",
      "fields": [
        { "id": "email", "label": "Email", "type": "text", "required": true, "in": "body" },
        { "id": "fields", "label": "Fields", "type": "json", "in": "body" },
        { "id": "groups", "label": "Groups", "type": "json", "in": "body" },
        { "id": "status", "label": "Status", "type": "text", "in": "body" },
        { "id": "subscribed_at", "label": "Subscribed at", "type": "text", "in": "body" }
      ]
    },
    {
      "id": "update_subscriber",
      "label": "Update subscriber",
      "method": "PUT",
      "path": "/subscribers/{id}",
      "fields": [
        { "id": "id", "label": "Subscriber ID", "type": "text", "required": true, "in": "path" },
        { "id": "email", "label": "Email", "type": "text", "in": "body" },
        { "id": "fields", "label": "Fields", "type": "json", "in": "body" },
        { "id": "groups", "label": "Groups", "type": "json", "in": "body" }
      ]
    },
    {
      "id": "delete_subscriber",
      "label": "Delete subscriber",
      "method": "DELETE",
      "path": "/subscribers/{id}",
      "fields": [
        { "id": "id", "label": "Subscriber ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "list_groups",
      "label": "List groups",
      "method": "GET",
      "path": "/groups",
      "fields": [
        { "id": "limit", "label": "Limit", "type": "number", "defaultValue": 25, "in": "query" },
        { "id": "page", "label": "Page", "type": "number", "defaultValue": 1, "in": "query" }
      ]
    },
    {
      "id": "assign_subscriber_to_group",
      "label": "Assign subscriber to group",
      "method": "POST",
      "path": "/subscribers/{subscriber_id}/groups/{group_id}",
      "fields": [
        { "id": "subscriber_id", "label": "Subscriber ID", "type": "text", "required": true, "in": "path" },
        { "id": "group_id", "label": "Group ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "list_campaigns",
      "label": "List campaigns",
      "method": "GET",
      "path": "/campaigns",
      "fields": [
        { "id": "limit", "label": "Limit", "type": "number", "defaultValue": 25, "in": "query" },
        { "id": "page", "label": "Page", "type": "number", "defaultValue": 1, "in": "query" },
        { "id": "filter[status]", "label": "Status filter", "type": "text", "in": "query" }
      ]
    },
    {
      "id": "create_campaign",
      "label": "Create campaign",
      "method": "POST",
      "path": "/campaigns",
      "fields": [
        { "id": "name", "label": "Name", "type": "text", "required": true, "in": "body" },
        { "id": "type", "label": "Type", "type": "text", "required": true, "in": "body" },
        { "id": "emails", "label": "Emails", "type": "json", "required": true, "in": "body" }
      ]
    },
    {
      "id": "list_fields",
      "label": "List fields",
      "method": "GET",
      "path": "/fields",
      "fields": [
        { "id": "limit", "label": "Limit", "type": "number", "defaultValue": 25, "in": "query" },
        { "id": "page", "label": "Page", "type": "number", "defaultValue": 1, "in": "query" }
      ]
    }
  ]
}
