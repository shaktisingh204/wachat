    { "id": "properties_list_for_sale", "label": "Properties list for sale", "method": "GET", "path": "/properties/list-for-sale", "fields": [{ "id": "rapidapi_host", "type": "text", "defaultValue": "realtor.p.rapidapi.com", "in": "header" }, { "id": "city", "type": "text", "required": true, "in": "query" }, { "id": "state_code", "type": "text", "required": true, "in": "query" }, { "id": "offset", "type": "number", "in": "query" }, { "id": "limit", "type": "number", "defaultValue": 25, "in": "query" }] },
