{
  "id": "n8n-aws-transcribe",
  "name": "AWS Transcribe",
  "description": "Sends data to AWS Transcribe",
  "category": "ai",
  "iconName": "LuPackage",
  "version": 3,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "transcription_job_create",
      "label": "Create Transcription Job",
      "method": "POST",
      "path": "/transcription-job",
      "fields": [
        {
          "id": "transcriptionJobName",
          "label": "Job Name",
          "type": "text",
          "description": "The name of the job"
        },
        {
          "id": "mediaFileUri",
          "label": "Media File URI",
          "type": "text",
          "description": "The S3 object location of the input media file"
        },
        {
          "id": "detectLanguage",
          "label": "Detect Language",
          "type": "toggle",
          "description": "Whether to set this field to true to enable automatic language identification",
          "defaultValue": false
        },
        {
          "id": "languageCode",
          "label": "Language",
          "type": "select",
          "description": "Language used in the input media file",
          "defaultValue": "en-US",
          "options": [
            {
              "value": "en-US",
              "label": "American English"
            },
            {
              "value": "en-GB",
              "label": "British English"
            },
            {
              "value": "de-DE",
              "label": "German"
            },
            {
              "value": "en-IN",
              "label": "Indian English"
            },
            {
              "value": "en-IE",
              "label": "Irish English"
            },
            {
              "value": "ru-RU",
              "label": "Russian"
            },
            {
              "value": "es-ES",
              "label": "Spanish"
            }
          ]
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: channelIdentification, maxAlternatives, maxSpeakerLabels, vocabularyName, vocabularyFilterName, vocabularyFilterMethod)"
        }
      ],
      "group": "Transcription Job",
      "description": "[unverified path] Create a transcription job"
    },
    {
      "id": "transcription_job_delete",
      "label": "Delete Transcription Job",
      "method": "DELETE",
      "path": "/transcription-job",
      "fields": [
        {
          "id": "transcriptionJobName",
          "label": "Job Name",
          "type": "text",
          "description": "The name of the job"
        }
      ],
      "group": "Transcription Job",
      "description": "[unverified path] Delete a transcription job"
    },
    {
      "id": "transcription_job_get",
      "label": "Get Transcription Job",
      "method": "GET",
      "path": "/transcription-job",
      "fields": [
        {
          "id": "transcriptionJobName",
          "label": "Job Name",
          "type": "text",
          "description": "The name of the job"
        },
        {
          "id": "returnTranscript",
          "label": "Return Transcript",
          "type": "toggle",
          "description": "By default, the response only contains metadata about the transcript. Enable this option to retrieve the transcript instead.",
          "defaultValue": true
        },
        {
          "id": "simple",
          "label": "Simplify",
          "type": "toggle",
          "description": "Whether to return a simplified version of the response instead of the raw data",
          "defaultValue": true
        }
      ],
      "group": "Transcription Job",
      "description": "[unverified path] Get a transcription job"
    },
    {
      "id": "transcription_job_get_all",
      "label": "Get Many Transcription Job",
      "method": "GET",
      "path": "/transcription-job",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 20
        },
        {
          "id": "filters",
          "label": "Filters",
          "type": "json",
          "placeholder": "Add Filter",
          "description": "(JSON object; supported keys: jobNameContains, status)"
        }
      ],
      "group": "Transcription Job",
      "description": "[unverified path] Get many transcription jobs"
    }
  ]
}
