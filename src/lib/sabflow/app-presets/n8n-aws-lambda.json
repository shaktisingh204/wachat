{
  "id": "n8n-aws-lambda",
  "name": "AWS Lambda",
  "description": "Invoke functions on AWS Lambda",
  "category": "dev",
  "iconName": "LuPackage",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "draft",
  "auth": {
    "type": "none"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "default_invoke",
      "label": "Invoke",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "function",
          "label": "Function Name or ID",
          "type": "select",
          "in": "query",
          "required": true,
          "description": "The function you want to invoke. Choose from the list, or specify an ID using an <a href=\"https://docs.n8n.io/code/expressions/\">expression</a>.",
          "options": []
        },
        {
          "id": "qualifier",
          "label": "Qualifier",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "Specify a version or alias to invoke a published version of the function",
          "defaultValue": "$LATEST"
        },
        {
          "id": "invocationType",
          "label": "Invocation Type",
          "type": "select",
          "in": "query",
          "description": "Specify if the workflow should wait for the function to return the results",
          "defaultValue": "RequestResponse",
          "options": [
            {
              "value": "RequestResponse",
              "label": "Wait for Results"
            },
            {
              "value": "Event",
              "label": "Continue Workflow"
            }
          ]
        },
        {
          "id": "payload",
          "label": "JSON Input",
          "type": "text",
          "in": "query",
          "description": "The JSON that you want to provide to your Lambda function as input"
        }
      ]
    }
  ]
}
