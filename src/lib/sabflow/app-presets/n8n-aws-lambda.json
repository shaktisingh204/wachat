{
  "id": "n8n-aws-lambda",
  "name": "AWS Lambda",
  "description": "Invoke functions on AWS Lambda",
  "category": "dev",
  "iconName": "LuPackage",
  "version": 10,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "bearer",
    "credentialType": "aws_lambda"
  },
  "baseUrl": "https://iam.amazonaws.com",
  "endpoints": [
    {
      "id": "invoke",
      "label": "Invoke",
      "method": "POST",
      "path": "/invoke",
      "fields": [
        {
          "id": "function",
          "label": "Function Name or ID",
          "type": "text",
          "required": true,
          "description": "The function you want to invoke. Choose from the list, or specify an ID using an expression."
        },
        {
          "id": "qualifier",
          "label": "Qualifier",
          "type": "text",
          "required": true,
          "description": "Specify a version or alias to invoke a published version of the function",
          "defaultValue": "$LATEST"
        },
        {
          "id": "invocationType",
          "label": "Invocation Type",
          "type": "select",
          "description": "Specify if the workflow should wait for the function to return the results",
          "defaultValue": "RequestResponse",
          "options": [
            {
              "value": "RequestResponse",
              "label": "Wait for Results"
            },
            {
              "value": "Event",
              "label": "Continue Workflow"
            }
          ]
        },
        {
          "id": "payload",
          "label": "JSON Input",
          "type": "text",
          "description": "The JSON that you want to provide to your Lambda function as input"
        }
      ],
      "description": "[unverified path] Invoke a function"
    }
  ]
}
