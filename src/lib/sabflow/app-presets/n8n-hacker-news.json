{
  "id": "n8n-hacker-news",
  "name": "Hacker News",
  "description": "Consume Hacker News API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 9,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "none"
  },
  "baseUrl": "http://hn.algolia.com/api/v1",
  "endpoints": [
    {
      "id": "all_get_all",
      "label": "Get Many All",
      "method": "GET",
      "path": "/search?",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 100
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: keyword, tags)"
        }
      ],
      "group": "All",
      "description": "Get many items"
    },
    {
      "id": "article_get",
      "label": "Get Article",
      "method": "GET",
      "path": "/items/{articleId}",
      "fields": [
        {
          "id": "articleId",
          "label": "Article ID",
          "type": "text",
          "required": true,
          "description": "The ID of the Hacker News article to be returned",
          "in": "path"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: includeComments)"
        }
      ],
      "group": "Article",
      "description": "Get a Hacker News article"
    },
    {
      "id": "user_get",
      "label": "Get User",
      "method": "GET",
      "path": "/users/{username}",
      "fields": [
        {
          "id": "username",
          "label": "Username",
          "type": "text",
          "required": true,
          "description": "The Hacker News user to be returned",
          "in": "path"
        }
      ],
      "group": "User",
      "description": "Get a Hacker News user"
    }
  ]
}
