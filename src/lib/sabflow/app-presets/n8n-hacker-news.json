{
  "id": "n8n-hacker-news",
  "name": "Hacker News",
  "description": "Consume Hacker News API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "draft",
  "auth": {
    "type": "none"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "all_get_all",
      "label": "Get Many All",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "in": "query",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "in": "query",
          "description": "Max number of results to return",
          "defaultValue": 100
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "in": "query",
          "placeholder": "Add Field"
        }
      ]
    },
    {
      "id": "article_get",
      "label": "Get Article",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "articleId",
          "label": "Article ID",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "The ID of the Hacker News article to be returned"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "in": "query",
          "placeholder": "Add Field"
        }
      ]
    },
    {
      "id": "user_get",
      "label": "Get User",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "username",
          "label": "Username",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "The Hacker News user to be returned"
        }
      ]
    }
  ]
}
