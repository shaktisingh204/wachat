{
  "id": "n8n-message-bird",
  "name": "MessageBird",
  "description": "Sends SMS via MessageBird",
  "category": "communication",
  "iconName": "LuPackage",
  "version": 12,
  "lastVerified": "2026-06-12",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://rest.messagebird.com",
  "endpoints": [
    {
      "id": "sms_send",
      "label": "Send SMS",
      "method": "POST",
      "path": "/messages",
      "fields": [
        {
          "id": "originator",
          "label": "From",
          "type": "text",
          "required": true,
          "placeholder": "14155238886",
          "description": "The number from which to send the message"
        },
        {
          "id": "recipients",
          "label": "To",
          "type": "text",
          "required": true,
          "placeholder": "14155238886/+14155238886",
          "description": "All recipients separated by commas"
        },
        {
          "id": "message",
          "label": "Message",
          "type": "text",
          "required": true,
          "description": "The message to be send"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Fields",
          "description": "(JSON object; supported keys: createdDatetime, datacoding, gateway, groupIds, mclass, reference, reportUrl, scheduledDatetime, type, typeDetails, validity)"
        }
      ],
      "group": "SMS",
      "description": "Send text messages (SMS)"
    },
    {
      "id": "balance_get",
      "label": "Get Balance",
      "method": "GET",
      "path": "/balance",
      "fields": [],
      "group": "Balance",
      "description": "Get the balance"
    }
  ]
}
