{
  "id": "practice-better",
  "name": "Practice Better",
  "description": "Health/wellness practice management.",
  "category": "Wellness",
  "iconName": "LuHeartPulse",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": { "type": "bearer", "credentialType": "practice_better" },
  "baseUrl": "https://api.practicebetter.io/v1",
  "endpoints": [
    { "id": "list_clients", "label": "List clients", "method": "GET", "path": "/clients", "fields": [] },
    { "id": "get_client", "label": "Get client", "method": "GET", "path": "/clients/{id}", "fields": [{ "id": "id", "type": "text", "required": true, "in": "path" }] },
    { "id": "create_client", "label": "Create client", "method": "POST", "path": "/clients", "fields": [{ "id": "first_name", "type": "text", "required": true, "in": "body" }, { "id": "last_name", "type": "text", "required": true, "in": "body" }, { "id": "email", "type": "text", "required": true, "in": "body" }] },
    { "id": "update_client", "label": "Update client", "method": "PATCH", "path": "/clients/{id}", "fields": [{ "id": "id", "type": "text", "required": true, "in": "path" }] },
    { "id": "list_sessions", "label": "List sessions", "method": "GET", "path": "/sessions", "fields": [{ "id": "from", "type": "text", "in": "query" }, { "id": "to", "type": "text", "in": "query" }] },
    { "id": "create_session", "label": "Create session", "method": "POST", "path": "/sessions", "fields": [{ "id": "client", "type": "text", "required": true, "in": "body" }, { "id": "practitioner", "type": "text", "required": true, "in": "body" }, { "id": "scheduled_at", "type": "text", "required": true, "in": "body" }, { "id": "duration_minutes", "type": "number", "required": true, "in": "body" }, { "id": "type", "type": "text", "required": true, "in": "body" }] },
    { "id": "list_invoices", "label": "List invoices", "method": "GET", "path": "/invoices", "fields": [{ "id": "client", "type": "text", "in": "query" }] },
    { "id": "list_forms", "label": "List forms", "method": "GET", "path": "/forms", "fields": [] },
    { "id": "list_protocols", "label": "List protocols", "method": "GET", "path": "/protocols", "fields": [] }
  ]
}
