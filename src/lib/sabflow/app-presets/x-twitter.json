{
  "id": "x-twitter",
  "name": "X (Twitter)",
  "description": "X / Twitter API v2 for tweets, likes, follows, search, and DMs.",
  "category": "Social",
  "iconName": "LuTwitter",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "oauth2",
    "provider": "twitter",
    "credentialType": "twitter",
    "fallback": {
      "type": "bearer",
      "credentialType": "x_twitter"
    }
  },
  "baseUrl": "https://api.twitter.com/2",
  "endpoints": [
    {
      "id": "me",
      "label": "Get me",
      "method": "GET",
      "path": "/users/me",
      "fields": [
        {
          "id": "user.fields",
          "label": "User fields",
          "type": "text",
          "in": "query"
        }
      ]
    },
    {
      "id": "post_tweet",
      "label": "Post tweet",
      "method": "POST",
      "path": "/tweets",
      "fields": [
        {
          "id": "text",
          "label": "Text",
          "type": "textarea",
          "required": true,
          "in": "body"
        },
        {
          "id": "reply",
          "label": "Reply",
          "type": "json",
          "in": "body"
        },
        {
          "id": "media",
          "label": "Media",
          "type": "json",
          "in": "body"
        },
        {
          "id": "poll",
          "label": "Poll",
          "type": "json",
          "in": "body"
        }
      ]
    },
    {
      "id": "delete_tweet",
      "label": "Delete tweet",
      "method": "DELETE",
      "path": "/tweets/{id}",
      "fields": [
        {
          "id": "id",
          "label": "Tweet ID",
          "type": "text",
          "required": true,
          "in": "path"
        }
      ]
    },
    {
      "id": "get_tweet",
      "label": "Get tweet",
      "method": "GET",
      "path": "/tweets/{id}",
      "fields": [
        {
          "id": "id",
          "label": "Tweet ID",
          "type": "text",
          "required": true,
          "in": "path"
        },
        {
          "id": "expansions",
          "label": "Expansions",
          "type": "text",
          "in": "query"
        },
        {
          "id": "tweet.fields",
          "label": "Tweet fields",
          "type": "text",
          "in": "query"
        }
      ]
    },
    {
      "id": "list_user_tweets",
      "label": "List user tweets",
      "method": "GET",
      "path": "/users/{id}/tweets",
      "fields": [
        {
          "id": "id",
          "label": "User ID",
          "type": "text",
          "required": true,
          "in": "path"
        },
        {
          "id": "max_results",
          "label": "Max results",
          "type": "number",
          "defaultValue": 10,
          "in": "query"
        },
        {
          "id": "pagination_token",
          "label": "Pagination token",
          "type": "text",
          "in": "query"
        }
      ]
    },
    {
      "id": "like_tweet",
      "label": "Like tweet",
      "method": "POST",
      "path": "/users/{id}/likes",
      "fields": [
        {
          "id": "id",
          "label": "User ID",
          "type": "text",
          "required": true,
          "in": "path"
        },
        {
          "id": "tweet_id",
          "label": "Tweet ID",
          "type": "text",
          "required": true,
          "in": "body"
        }
      ]
    },
    {
      "id": "unlike_tweet",
      "label": "Unlike tweet",
      "method": "DELETE",
      "path": "/users/{id}/likes/{tweet_id}",
      "fields": [
        {
          "id": "id",
          "label": "User ID",
          "type": "text",
          "required": true,
          "in": "path"
        },
        {
          "id": "tweet_id",
          "label": "Tweet ID",
          "type": "text",
          "required": true,
          "in": "path"
        }
      ]
    },
    {
      "id": "retweet",
      "label": "Retweet",
      "method": "POST",
      "path": "/users/{id}/retweets",
      "fields": [
        {
          "id": "id",
          "label": "User ID",
          "type": "text",
          "required": true,
          "in": "path"
        },
        {
          "id": "tweet_id",
          "label": "Tweet ID",
          "type": "text",
          "required": true,
          "in": "body"
        }
      ]
    },
    {
      "id": "un_retweet",
      "label": "Un-retweet",
      "method": "DELETE",
      "path": "/users/{id}/retweets/{source_tweet_id}",
      "fields": [
        {
          "id": "id",
          "label": "User ID",
          "type": "text",
          "required": true,
          "in": "path"
        },
        {
          "id": "source_tweet_id",
          "label": "Source tweet ID",
          "type": "text",
          "required": true,
          "in": "path"
        }
      ]
    },
    {
      "id": "follow_user",
      "label": "Follow user",
      "method": "POST",
      "path": "/users/{id}/following",
      "fields": [
        {
          "id": "id",
          "label": "User ID (source)",
          "type": "text",
          "required": true,
          "in": "path"
        },
        {
          "id": "target_user_id",
          "label": "Target user ID",
          "type": "text",
          "required": true,
          "in": "body"
        }
      ]
    },
    {
      "id": "unfollow_user",
      "label": "Unfollow user",
      "method": "DELETE",
      "path": "/users/{source_user_id}/following/{target_user_id}",
      "fields": [
        {
          "id": "source_user_id",
          "label": "Source user ID",
          "type": "text",
          "required": true,
          "in": "path"
        },
        {
          "id": "target_user_id",
          "label": "Target user ID",
          "type": "text",
          "required": true,
          "in": "path"
        }
      ]
    },
    {
      "id": "search_recent",
      "label": "Search recent tweets",
      "method": "GET",
      "path": "/tweets/search/recent",
      "fields": [
        {
          "id": "query",
          "label": "Query",
          "type": "text",
          "required": true,
          "in": "query"
        },
        {
          "id": "max_results",
          "label": "Max results",
          "type": "number",
          "defaultValue": 10,
          "in": "query"
        },
        {
          "id": "start_time",
          "label": "Start time (ISO8601)",
          "type": "text",
          "in": "query"
        },
        {
          "id": "end_time",
          "label": "End time (ISO8601)",
          "type": "text",
          "in": "query"
        }
      ]
    },
    {
      "id": "dm_create",
      "label": "Create DM",
      "method": "POST",
      "path": "/dm_conversations/with/{participant_id}/messages",
      "fields": [
        {
          "id": "participant_id",
          "label": "Participant ID",
          "type": "text",
          "required": true,
          "in": "path"
        },
        {
          "id": "text",
          "label": "Text",
          "type": "textarea",
          "required": true,
          "in": "body"
        },
        {
          "id": "media",
          "label": "Media",
          "type": "json",
          "in": "body"
        }
      ]
    }
  ]
}
