{
  "id": "n8n-ftp",
  "name": "FTP",
  "description": "Transfer files via FTP or SFTP",
  "category": "storage",
  "iconName": "LuPackage",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "default_delete",
      "label": "Delete",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "protocol",
          "label": "Protocol",
          "type": "select",
          "in": "query",
          "description": "File transfer protocol",
          "defaultValue": "ftp",
          "options": [
            {
              "value": "ftp",
              "label": "FTP"
            },
            {
              "value": "sftp",
              "label": "SFTP"
            }
          ]
        },
        {
          "id": "path",
          "label": "Path",
          "type": "text",
          "in": "query",
          "required": true,
          "placeholder": "e.g. /public/documents/file-to-delete.txt",
          "description": "The file path of the file to delete. Has to contain the full path."
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "in": "query",
          "placeholder": "Add option"
        }
      ]
    },
    {
      "id": "default_download",
      "label": "Download",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "protocol",
          "label": "Protocol",
          "type": "select",
          "in": "query",
