        { "id": "from_format", "label": "From format", "type": "text", "required": true, "in": "path" },
        { "id": "to_format", "label": "To format", "type": "text", "required": true, "in": "path" },
        { "id": "Parameters", "label": "Parameters", "type": "json", "required": true, "in": "body", "defaultValue": [{ "Name": "File", "FileValue": { "Url": "" } }] }
      ]
    },
    {
      "id": "get_user_info",
      "label": "Get user info",
      "method": "GET",
      "path": "/user",
      "fields": []
    }
  ]
