{
  "id": "n8n-egoi",
  "name": "E-goi",
  "description": "Consume E-goi API",
  "category": "marketing",
  "iconName": "LuPackage",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "contact_create",
      "label": "Create Contact",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "list",
          "label": "List Name or ID",
          "type": "select",
          "in": "query",
          "description": "ID of list to operate on. Choose from the list, or specify an ID using an <a href=\"https://docs.n8n.io/code/expressions/\">expression</a>."
        },
        {
          "id": "email",
          "label": "Email",
          "type": "text",
          "in": "query",
          "placeholder": "name@email.com",
          "description": "Email address for a subscriber"
        },
        {
          "id": "resolveData",
          "label": "Resolve Data",
          "type": "toggle",
          "in": "query",
          "description": "By default the response just includes the contact ID. If this option gets activated, it will resolve the data automatically.",
          "defaultValue": true
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "in": "query",
          "placeholder": "Add Field"
        }
      ]
    },
    {
      "id": "contact_get",
      "label": "Get Contact",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "list",
          "label": "List Name or ID",
          "type": "select",
          "in": "query",
          "description": "ID of list to operate on. Choose from the list, or specify an ID using an <a href=\"https://docs.n8n.io/code/expressions/\">expression</a>."
        },
        {
          "id": "by",
          "label": "By",
          "type": "select",
          "in": "query",
          "description": "Search by",
          "defaultValue": "id",
          "options": [
            {
              "value": "id",
              "label": "Contact ID"
            },
            {
              "value": "email",
              "label": "Email"
            }
          ]
        },
        {
          "id": "contactId",
          "label": "Contact ID",
          "type": "text",
          "in": "query",
          "description": "Contact ID of the subscriber"
        },
        {
          "id": "email",
          "label": "Email",
          "type": "text",
          "in": "query",
          "placeholder": "name@email.com",
          "description": "Email address for subscriber"
        },
        {
          "id": "simple",
          "label": "Simplify",
          "type": "toggle",
          "in": "query",
          "description": "Whether to return a simplified version of the response instead of the raw data",
          "defaultValue": true
        }
      ]
    },
    {
      "id": "contact_get_all",
      "label": "Get Many Contact",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "list",
          "label": "List Name or ID",
          "type": "select",
          "in": "query",
          "description": "ID of list to operate on. Choose from the list, or specify an ID using an <a href=\"https://docs.n8n.io/code/expressions/\">expression</a>."
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "in": "query",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "in": "query",
          "description": "Max number of results to return",
          "defaultValue": 100
        },
        {
          "id": "simple",
          "label": "Simplify",
          "type": "toggle",
          "in": "query",
          "description": "Whether to return a simplified version of the response instead of the raw data",
          "defaultValue": true
        }
      ]
    },
    {
      "id": "contact_update",
      "label": "Update Contact",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "list",
          "label": "List Name or ID",
          "type": "select",
          "in": "query",
          "description": "ID of list to operate on. Choose from the list, or specify an ID using an <a href=\"https://docs.n8n.io/code/expressions/\">expression</a>."
        },
        {
          "id": "contactId",
          "label": "Contact ID",
          "type": "text",
          "in": "query",
          "description": "Contact ID of the subscriber"
        },
        {
          "id": "resolveData",
          "label": "Resolve Data",
          "type": "toggle",
          "in": "query",
          "description": "By default the response just includes the contact ID. If this option gets activated, it will resolve the data automatically.",
          "defaultValue": true
        },
        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "in": "query",
          "placeholder": "Add Field"
        }
      ]
    }
  ]
}
