{
  "id": "lever",
  "name": "Lever",
  "description": "Lever ATS API.",
  "category": "HR",
  "iconName": "LuUsers",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": { "type": "basic", "credentialType": "lever" },
  "baseUrl": "https://api.lever.co/v1",
  "endpoints": [
    { "id": "list_opportunities", "label": "List opportunities", "method": "GET", "path": "/opportunities", "fields": [{ "id": "limit", "type": "number", "in": "query" }, { "id": "offset", "type": "text", "in": "query" }] },
    { "id": "get_opportunity", "label": "Get opportunity", "method": "GET", "path": "/opportunities/{id}", "fields": [{ "id": "id", "type": "text", "required": true, "in": "path" }] },
    { "id": "create_opportunity", "label": "Create opportunity", "method": "POST", "path": "/opportunities", "fields": [{ "id": "perform_as", "type": "text", "in": "query" }, { "id": "name", "type": "text", "required": true, "in": "body" }, { "id": "headline", "type": "text", "in": "body" }, { "id": "location", "type": "text", "in": "body" }, { "id": "emails", "type": "json", "in": "body" }, { "id": "phones", "type": "json", "in": "body" }, { "id": "sources", "type": "json", "in": "body" }, { "id": "stage", "type": "text", "in": "body" }] },
    { "id": "update_stage", "label": "Update stage", "method": "PUT", "path": "/opportunities/{id}/stage", "fields": [{ "id": "id", "type": "text", "required": true, "in": "path" }, { "id": "perform_as", "type": "text", "in": "query" }, { "id": "stage", "type": "text", "required": true, "in": "body" }] },
    { "id": "archive_opportunity", "label": "Archive opportunity", "method": "PUT", "path": "/opportunities/{id}/archived", "fields": [{ "id": "id", "type": "text", "required": true, "in": "path" }, { "id": "perform_as", "type": "text", "in": "query" }, { "id": "reason", "type": "text", "required": true, "in": "body" }] },
    { "id": "list_notes", "label": "List notes", "method": "GET", "path": "/opportunities/{id}/notes", "fields": [{ "id": "id", "type": "text", "required": true, "in": "path" }] },
    { "id": "create_note", "label": "Create note", "method": "POST", "path": "/opportunities/{id}/notes", "fields": [{ "id": "id", "type": "text", "required": true, "in": "path" }, { "id": "perform_as", "type": "text", "in": "query" }, { "id": "value", "type": "textarea", "required": true, "in": "body" }, { "id": "secret", "type": "toggle", "in": "body" }] },
    { "id": "list_postings", "label": "List postings", "method": "GET", "path": "/postings", "fields": [] },
    { "id": "list_users", "label": "List users", "method": "GET", "path": "/users", "fields": [] },
    { "id": "list_archive_reasons", "label": "List archive reasons", "method": "GET", "path": "/archive_reasons", "fields": [] }
  ]
}
