  "baseUrl": "https://api.ouraring.com/v2",
  "endpoints": [
    {
      "id": "profile_get",
      "label": "Get Profile",
      "method": "GET",
      "path": "/usercollection/personal_info",
      "fields": [],
      "group": "Profile",
      "description": "Get the user's personal information"
    },
    {
      "id": "summary_get_activity",
      "label": "Get Activity Summary Summary",
      "method": "GET",
      "path": "/usercollection/daily_activity",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 5
        },
        {
          "id": "filters",
          "label": "Filters",
          "type": "json",
          "placeholder": "Add Filter",
          "description": "(JSON object; supported keys: end, start)"
        }
      ],
      "group": "Summary",
      "description": "Get the user's activity summary"
    },
    {
