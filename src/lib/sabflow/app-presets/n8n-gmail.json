    {
      "id": "draft_create",
      "label": "Create Draft",
      "method": "POST",
      "path": "/gmail/v1/users/me/drafts",
      "fields": [
        {
          "id": "subject",
          "label": "Subject",
          "type": "text",
          "required": true,
          "placeholder": "Hello World!"
        },
        {
          "id": "emailType",
          "label": "Email Type",
          "type": "select",
          "required": true,
          "defaultValue": "text",
          "options": [
            {
              "value": "html",
              "label": "HTML"
            },
            {
              "value": "text",
              "label": "Text"
            }
          ]
        },
        {
          "id": "message",
          "label": "Message",
          "type": "text",
          "required": true
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: attachmentsUi, bccList, ccList, fromAlias, replyTo, threadId, sendTo)"
        }
      ],
      "group": "Draft",
      "description": "Create a draft"
    },
    {
      "id": "draft_delete",
