{
  "id": "recurly",
  "name": "Recurly",
  "description": "Recurly subscription billing: accounts, subscriptions, invoices, transactions, plans, and coupons.",
  "category": "Billing",
  "iconName": "LuCreditCard",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "basic",
    "credentialType": "recurly"
  },
  "baseUrl": "https://v3.recurly.com",
  "endpoints": [
    {
      "id": "list_accounts",
      "label": "List Accounts",
      "method": "GET",
      "path": "/accounts",
      "fields": [
        { "id": "Accept", "label": "Accept Header", "type": "text", "defaultValue": "application/vnd.recurly.v2021-02-25", "in": "header" },
        { "id": "limit", "label": "Limit", "type": "number", "in": "query" }
      ]
    },
    {
      "id": "get_account",
      "label": "Get Account",
      "method": "GET",
      "path": "/accounts/{account_id}",
      "fields": [
        { "id": "Accept", "label": "Accept Header", "type": "text", "defaultValue": "application/vnd.recurly.v2021-02-25", "in": "header" },
        { "id": "account_id", "label": "Account ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "create_account",
      "label": "Create Account",
      "method": "POST",
      "path": "/accounts",
      "fields": [
        { "id": "Accept", "label": "Accept Header", "type": "text", "defaultValue": "application/vnd.recurly.v2021-02-25", "in": "header" },
        { "id": "code", "label": "Code", "type": "text", "required": true, "in": "body" },
        { "id": "email", "label": "Email", "type": "text", "in": "body" },
        { "id": "first_name", "label": "First Name", "type": "text", "in": "body" },
        { "id": "last_name", "label": "Last Name", "type": "text", "in": "body" },
        { "id": "billing_info", "label": "Billing Info", "type": "json", "in": "body" }
      ]
    },
    {
      "id": "list_subscriptions",
      "label": "List Subscriptions",
      "method": "GET",
      "path": "/subscriptions",
      "fields": [
        { "id": "Accept", "label": "Accept Header", "type": "text", "defaultValue": "application/vnd.recurly.v2021-02-25", "in": "header" },
        { "id": "limit", "label": "Limit", "type": "number", "in": "query" },
        { "id": "state", "label": "State", "type": "text", "in": "query" }
      ]
    },
    {
      "id": "create_subscription",
      "label": "Create Subscription",
      "method": "POST",
      "path": "/subscriptions",
      "fields": [
        { "id": "Accept", "label": "Accept Header", "type": "text", "defaultValue": "application/vnd.recurly.v2021-02-25", "in": "header" },
        { "id": "plan_code", "label": "Plan Code", "type": "text", "required": true, "in": "body" },
        { "id": "account", "label": "Account", "type": "json", "required": true, "in": "body" },
        { "id": "currency", "label": "Currency", "type": "text", "required": true, "in": "body" }
      ]
    },
    {
      "id": "cancel_subscription",
      "label": "Cancel Subscription",
      "method": "PUT",
      "path": "/subscriptions/{subscription_uuid}/cancel",
      "fields": [
        { "id": "Accept", "label": "Accept Header", "type": "text", "defaultValue": "application/vnd.recurly.v2021-02-25", "in": "header" },
        { "id": "subscription_uuid", "label": "Subscription UUID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "pause_subscription",
      "label": "Pause Subscription",
      "method": "PUT",
      "path": "/subscriptions/{subscription_uuid}/pause",
      "fields": [
        { "id": "Accept", "label": "Accept Header", "type": "text", "defaultValue": "application/vnd.recurly.v2021-02-25", "in": "header" },
        { "id": "subscription_uuid", "label": "Subscription UUID", "type": "text", "required": true, "in": "path" },
        { "id": "remaining_pause_cycles", "label": "Remaining Pause Cycles", "type": "number", "required": true, "in": "body" }
      ]
    },
    {
      "id": "list_invoices",
      "label": "List Invoices",
      "method": "GET",
      "path": "/invoices",
      "fields": [
        { "id": "Accept", "label": "Accept Header", "type": "text", "defaultValue": "application/vnd.recurly.v2021-02-25", "in": "header" },
        { "id": "limit", "label": "Limit", "type": "number", "in": "query" },
        { "id": "state", "label": "State", "type": "text", "in": "query" }
      ]
    },
    {
      "id": "list_transactions",
      "label": "List Transactions",
      "method": "GET",
      "path": "/transactions",
      "fields": [
        { "id": "Accept", "label": "Accept Header", "type": "text", "defaultValue": "application/vnd.recurly.v2021-02-25", "in": "header" },
        { "id": "limit", "label": "Limit", "type": "number", "in": "query" }
      ]
    },
    {
      "id": "list_plans",
      "label": "List Plans",
      "method": "GET",
      "path": "/plans",
      "fields": [
        { "id": "Accept", "label": "Accept Header", "type": "text", "defaultValue": "application/vnd.recurly.v2021-02-25", "in": "header" },
        { "id": "limit", "label": "Limit", "type": "number", "in": "query" }
      ]
    },
    {
      "id": "list_coupons",
      "label": "List Coupons",
      "method": "GET",
      "path": "/coupons",
      "fields": [
        { "id": "Accept", "label": "Accept Header", "type": "text", "defaultValue": "application/vnd.recurly.v2021-02-25", "in": "header" },
        { "id": "limit", "label": "Limit", "type": "number", "in": "query" }
      ]
    }
  ]
}
