{
  "id": "n8n-api-template-io",
  "name": "APITemplate.io",
  "description": "Consume the APITemplate.io API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://api.apitemplate.io/v1",
  "endpoints": [
    {
      "id": "image_create",
      "label": "Create Image",
      "method": "POST",
      "path": "/create",
      "fields": [
        {
          "id": "imageTemplateId",
          "label": "Template Name or ID",
          "type": "select",
          "required": true,
          "description": "ID of the image template to use. Choose from the list, or specify an ID using an expression."
        },
        {
          "id": "jsonParameters",
          "label": "JSON Parameters",
          "type": "toggle",
          "defaultValue": false
        },
        {
          "id": "download",
          "label": "Download",
          "type": "toggle",
          "description": "Name of the binary property to which to write the data of the read file",
          "defaultValue": false
        },
        {
          "id": "binaryProperty",
          "label": "Put Output File in Field",
          "type": "text",
          "required": true,
          "defaultValue": "data"
        },
        {
          "id": "overridesJson",
          "label": "Overrides (JSON)",
          "type": "json",
          "placeholder": "[ {\"name\": \"text_1\", \"text\": \"hello world\", \"textBackgroundColor\": \"rgba(246, 243, 243, 0)\" } ]"
        },
        {
          "id": "overridesUi",
          "label": "Overrides",
          "type": "json",
          "placeholder": "Add Override",
          "description": "(JSON object; supported keys: overrideValues, overrideValues.propertiesUi)"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: fileName)"
        }
      ],
      "group": "Image",
      "description": "Create an image"
    },
    {
      "id": "pdf_create",
      "label": "Create PDF",
      "method": "POST",
      "path": "/create",
      "fields": [
        {
          "id": "pdfTemplateId",
          "label": "Template Name or ID",
          "type": "select",
          "required": true,
          "description": "ID of the PDF template to use. Choose from the list, or specify an ID using an expression."
        },
        {
          "id": "jsonParameters",
          "label": "JSON Parameters",
          "type": "toggle",
          "defaultValue": false
        },
        {
          "id": "download",
          "label": "Download",
          "type": "toggle",
          "description": "Name of the binary property to which to write the data of the read file",
          "defaultValue": false
        },
        {
          "id": "binaryProperty",
          "label": "Put Output File in Field",
          "type": "text",
          "required": true,
          "defaultValue": "data"
        },
        {
          "id": "propertiesJson",
          "label": "Properties (JSON)",
          "type": "json",
          "placeholder": "{ \"name\": \"text_1\" }"
        },
        {
          "id": "propertiesUi",
          "label": "Properties",
          "type": "json",
          "placeholder": "Add Property",
          "description": "(JSON object; supported keys: propertyValues, propertyValues.key, propertyValues.value)"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: fileName)"
        }
      ],
      "group": "PDF",
      "description": "Create a pdf"
    },
    {
      "id": "account_get",
      "label": "Get Account",
      "method": "GET",
      "path": "/account-information",
      "fields": [],
      "group": "Account",
      "description": "Get an account"
    }
  ]
}
