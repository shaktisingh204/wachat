{
  "id": "n8n-google-drive",
  "name": "Google Drive",
  "description": "Access data on Google Drive",
  "category": "storage",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "provider": "google",
    "credentialType": "google_sheets",
    "fallback": {
      "type": "none"
    }
  },
  "baseUrl": "https://www.googleapis.com/drive/v3",
  "endpoints": [
    {
      "id": "drive_create",
      "label": "Create Shared Drive",
      "method": "POST",
      "path": "/drive/v3/drives",
      "fields": [],
      "group": "Shared Drive",
      "description": "Create a shared drive"
    },
    {
      "id": "drive_delete_drive",
      "label": "Delete Shared Drive",
      "method": "DELETE",
      "path": "/drive/v3/drives/{driveId}",
      "fields": [],
      "group": "Shared Drive",
      "description": "Permanently delete a shared drive"
    },
    {
      "id": "drive_get",
      "label": "Get Shared Drive",
      "method": "GET",
      "path": "/drive/v3/drives/{driveId}",
      "fields": [],
      "group": "Shared Drive",
      "description": "Get a shared drive"
    },
    {
      "id": "drive_list",
      "label": "Get Many Shared Drive",
      "method": "GET",
      "path": "/drives",
      "fields": [],
