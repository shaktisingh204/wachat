{
  "id": "n8n-one-simple-api",
  "name": "One Simple API",
  "description": "A toolbox of no-code utilities",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 10,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://onesimpleapi.com/api",
  "endpoints": [
    {
      "id": "website_pdf",
      "label": "Generate PDF Website",
      "method": "POST",
      "path": "/pdf",
      "fields": [
        {
          "id": "link",
          "label": "Webpage URL",
          "type": "text",
          "required": true,
          "description": "Link to webpage to convert"
        },
        {
          "id": "download",
          "label": "Download PDF?",
          "type": "toggle",
          "required": true,
          "description": "Whether to download the PDF or return a link to it",
          "defaultValue": false
        },
        {
          "id": "output",
          "label": "Put Output In Field",
          "type": "text",
          "required": true,
          "description": "The name of the output field to put the binary file data in",
          "defaultValue": "data"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: page, force)"
        }
      ],
      "group": "Website",
      "description": "Generate a PDF from a webpage"
    },
    {
      "id": "website_seo",
      "label": "Get SEO Data Website",
      "method": "POST",
      "path": "/page_info",
      "fields": [
        {
          "id": "link",
          "label": "Webpage URL",
          "type": "text",
          "required": true,
          "description": "Webpage to get SEO information for"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: headers)"
        }
      ],
      "group": "Website",
      "description": "Get SEO information from website"
    },
    {
      "id": "website_screenshot",
      "label": "Take Screenshot Website",
      "method": "POST",
      "path": "/screenshot",
      "fields": [
        {
          "id": "link",
          "label": "Webpage URL",
          "type": "text",
          "required": true,
          "description": "Link to webpage to convert"
        },
        {
          "id": "download",
          "label": "Download Screenshot?",
          "type": "toggle",
          "required": true,
          "description": "Whether to download the screenshot or return a link to it",
          "defaultValue": false
        },
        {
          "id": "output",
          "label": "Put Output In Field",
          "type": "text",
          "required": true,
          "description": "The name of the output field to put the binary file data in",
          "defaultValue": "data"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: screen, force, fullpage)"
        }
      ],
      "group": "Website",
      "description": "Create a screenshot from a webpage"
    },
    {
      "id": "social_profile_instagram_profile",
      "label": "Instagram Social Profile",
      "method": "POST",
      "path": "/instagram_profile",
      "fields": [
        {
          "id": "profileName",
          "label": "Profile Name",
          "type": "text",
          "required": true,
          "description": "Profile name to get details of"
        }
      ],
      "group": "Social Profile",
      "description": "Get details about an Instagram profile"
    },
    {
      "id": "social_profile_spotify_artist_profile",
      "label": "Spotify Social Profile",
      "method": "POST",
      "path": "/spotify_profile",
      "fields": [
        {
          "id": "artistName",
          "label": "Artist Name",
          "type": "text",
          "required": true,
          "description": "Artist name to get details for"
        }
      ],
      "group": "Social Profile",
      "description": "Get details about a Spotify Artist"
    },
    {
      "id": "information_exchange_rate",
      "label": "Exchange Rate Information",
      "method": "POST",
      "path": "/exchange_rate",
      "fields": [
        {
          "id": "value",
          "label": "Value",
          "type": "text",
          "required": true,
          "description": "Value to convert"
        },
        {
          "id": "fromCurrency",
          "label": "From Currency",
          "type": "text",
          "required": true,
          "placeholder": "USD"
        },
        {
          "id": "toCurrency",
          "label": "To Currency",
          "type": "text",
          "required": true,
          "placeholder": "EUR"
        }
      ],
      "group": "Information",
      "description": "Convert a value between currencies"
    },
    {
      "id": "information_image_metadata",
      "label": "Image Metadata Information",
      "method": "POST",
      "path": "/image_info",
      "fields": [
        {
          "id": "link",
          "label": "Link To Image",
          "type": "text",
          "required": true,
          "description": "Image to get metadata from"
        }
      ],
      "group": "Information",
      "description": "Retrieve image metadata from a URL"
    },
    {
      "id": "utility_expand_url",
      "label": "Expand URL Utility",
      "method": "POST",
      "path": "/unshorten",
      "fields": [
        {
          "id": "link",
          "label": "URL",
          "type": "text",
          "required": true,
          "description": "URL to unshorten"
        }
      ],
      "group": "Utility",
      "description": "Expand a shortened URL"
    },
    {
      "id": "utility_qr_code",
      "label": "Generate QR Code Utility",
      "method": "POST",
      "path": "/qr_code",
      "fields": [
        {
          "id": "message",
          "label": "QR Content",
          "type": "text",
          "required": true,
          "description": "The text that should be turned into a QR code - like a website URL"
        },
        {
          "id": "download",
          "label": "Download Image?",
          "type": "toggle",
          "required": true,
          "description": "Whether to download the QR code or return a link to it",
          "defaultValue": false
        },
        {
          "id": "output",
          "label": "Put Output In Field",
          "type": "text",
          "required": true,
          "description": "The name of the output field to put the binary file data in",
          "defaultValue": "data"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: size, format)"
        }
      ],
      "group": "Utility",
      "description": "Generate a QR Code"
    },
    {
      "id": "utility_validate_email",
      "label": "Validate Email Utility",
      "method": "POST",
      "path": "/email",
      "fields": [
        {
          "id": "emailAddress",
          "label": "Email Address",
          "type": "text",
          "required": true
        }
      ],
      "group": "Utility",
      "description": "Validate an email address"
    }
  ]
}
