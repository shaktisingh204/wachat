          "placeholder": "Add Address",
          "description": "(JSON object; supported keys: addressesValues, addressesValues.countryCode, addressesValues.line1, addressesValues.line2, addressesValues.locality, addressesValues.postalCode, addressesValues.region, addressesValues.zipCode, addressesValues.zipFour)"
