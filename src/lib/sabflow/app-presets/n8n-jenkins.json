      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "instanceNotice",
          "label": "Instance operation can shutdown Jenkins instance and make it unresponsive. Some commands may not be available depending on instance implementation.",
          "type": "text",
          "in": "query"
        }
      ]
    },
    {
      "id": "build_get_all",
      "label": "Get Many Build",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "job",
          "label": "Job Name or ID",
          "type": "select",
          "in": "query",
          "required": true,
          "description": "Name of the job. Choose from the list, or specify an ID using an <a href=\"https://docs.n8n.io/code/expressions/\">expression</a>."
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "in": "query",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "in": "query",
          "description": "Max number of results to return",
          "defaultValue": 50
