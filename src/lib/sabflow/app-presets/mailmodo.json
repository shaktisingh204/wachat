{
  "id": "mailmodo",
  "name": "Mailmodo",
  "description": "Mailmodo interactive email marketing API.",
  "category": "Email marketing",
  "iconName": "LuMail",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "header",
    "header": "mmApiKey",
    "credentialType": "mailmodo"
  },
  "baseUrl": "https://api.mailmodo.com/api/v1",
  "endpoints": [
    {
      "id": "send_campaign",
      "label": "Send campaign",
      "method": "POST",
      "path": "/sendCampaign",
      "fields": [
        { "id": "campaignId", "label": "Campaign ID", "type": "text", "required": true, "in": "body" },
        { "id": "email", "label": "Email", "type": "text", "required": true, "in": "body" },
        { "id": "data", "label": "Data", "type": "json", "in": "body" },
        { "id": "addToList", "label": "Add to list", "type": "text", "in": "body" }
      ]
    },
    {
      "id": "add_to_list",
      "label": "Add to list",
      "method": "POST",
      "path": "/addToList/{listName}",
      "fields": [
        { "id": "listName", "label": "List name", "type": "text", "required": true, "in": "path" },
        { "id": "values", "label": "Values", "type": "json", "required": true, "in": "body" }
      ]
    },
    {
      "id": "remove_from_list",
      "label": "Remove from list",
      "method": "POST",
      "path": "/removeFromList/{listName}",
      "fields": [
        { "id": "listName", "label": "List name", "type": "text", "required": true, "in": "path" },
        { "id": "values", "label": "Values", "type": "json", "required": true, "in": "body" }
      ]
    },
    {
      "id": "list_contacts",
      "label": "List contacts",
      "method": "GET",
      "path": "/contacts",
      "fields": [
        { "id": "limit", "label": "Limit", "type": "number", "defaultValue": 25, "in": "query" },
        { "id": "offset", "label": "Offset", "type": "number", "in": "query" }
      ]
    },
    {
      "id": "create_contact",
      "label": "Create contact",
      "method": "POST",
      "path": "/contact",
      "fields": [
        { "id": "email", "label": "Email", "type": "text", "required": true, "in": "body" },
        { "id": "data", "label": "Data", "type": "json", "in": "body" }
      ]
    },
    {
      "id": "get_user_details",
      "label": "Get user details",
      "method": "GET",
      "path": "/contact/{email}",
      "fields": [
        { "id": "email", "label": "Email", "type": "text", "required": true, "in": "path" }
      ]
    }
  ]
}
