    {
      "id": "client_create",
      "label": "Create Client",
      "method": "POST",
      "path": "/client",
      "fields": [
        {
          "id": "clientName",
          "label": "Name",
          "type": "text",
          "required": true,
          "description": "Enter client name"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: inactive, notes, is_vip, website)"
        }
      ],
      "group": "Client",
      "description": "Create a client"
    },
    {
      "id": "client_delete",
      "label": "Delete Client",
      "method": "DELETE",
      "path": "/client/{clientId}",
      "fields": [
        {
          "id": "clientId",
          "label": "Client ID",
          "type": "text",
          "required": true,
          "in": "path"
        }
      ],
      "group": "Client",
      "description": "Delete a client"
    },
    {
      "id": "client_get",
      "label": "Get Client",
      "method": "GET",
      "path": "/client/{clientId}",
      "fields": [
        {
          "id": "clientId",
          "label": "Client ID",
          "type": "text",
          "required": true,
          "in": "path"
