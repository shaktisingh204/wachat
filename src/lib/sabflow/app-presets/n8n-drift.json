{
  "id": "n8n-drift",
  "name": "Drift",
  "description": "Consume Drift API",
  "category": "support",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://driftapi.com",
  "endpoints": [
    {
      "id": "contact_create",
      "label": "Create Contact",
      "method": "POST",
      "path": "/contacts",
      "fields": [
        {
          "id": "email",
          "label": "Email",
          "type": "text",
          "required": true,
          "placeholder": "name@email.com",
          "description": "The email of the contact"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: name, phone)"
        }
      ],
      "group": "Contact",
      "description": "Create a contact"
    },
    {
      "id": "contact_get_custom_attributes",
      "label": "Custom Attributes Contact",
      "method": "GET",
      "path": "/contacts/attributes",
      "fields": [],
      "group": "Contact",
      "description": "Get custom attributes"
    },
    {
      "id": "contact_delete",
      "label": "Delete Contact",
      "method": "DELETE",
      "path": "/contacts/{contactId}",
      "fields": [
        {
          "id": "contactId",
          "label": "Contact ID",
          "type": "text",
          "required": true,
          "description": "Unique identifier for the contact",
          "in": "path"
        }
      ],
      "group": "Contact",
      "description": "Delete a contact"
    },
    {
      "id": "contact_get",
      "label": "Get Contact",
      "method": "GET",
      "path": "/contacts/{contactId}",
      "fields": [
        {
          "id": "contactId",
          "label": "Contact ID",
          "type": "text",
          "required": true,
          "description": "Unique identifier for the contact",
          "in": "path"
        }
      ],
      "group": "Contact",
      "description": "Get a contact"
    },
    {
      "id": "contact_update",
      "label": "Update Contact",
      "method": "PATCH",
      "path": "/contacts/{contactId}",
      "fields": [
        {
          "id": "contactId",
          "label": "Contact ID",
          "type": "text",
          "required": true,
          "description": "Unique identifier for the contact",
          "in": "path"
        },
        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: email, name, phone)"
        }
      ],
      "group": "Contact",
      "description": "Update a contact"
    }
  ]
}
