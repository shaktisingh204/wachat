{
  "id": "loom",
  "name": "Loom",
  "description": "Loom video recording API.",
  "category": "Video",
  "iconName": "LuVideo",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "bearer",
    "credentialType": "loom",
    "header": "Authorization",
    "scheme": "Bearer"
  },
  "baseUrl": "https://api.loom.com/v1",
  "endpoints": [
    {
      "id": "create_video_link",
      "label": "Create video link",
      "method": "POST",
      "path": "/videos",
      "fields": [
        { "id": "title", "label": "Title", "type": "text", "required": true, "in": "body" },
        { "id": "source_url", "label": "Source URL", "type": "text", "required": true, "in": "body" }
      ]
    },
    {
      "id": "list_videos",
      "label": "List videos",
      "method": "GET",
      "path": "/videos",
      "fields": [
        { "id": "page", "label": "Page", "type": "number", "defaultValue": 1, "in": "query" },
        { "id": "per_page", "label": "Per page", "type": "number", "defaultValue": 25, "in": "query" }
      ]
    },
    {
      "id": "get_video",
      "label": "Get video",
      "method": "GET",
      "path": "/videos/{id}",
      "fields": [
        { "id": "id", "label": "Video ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "delete_video",
      "label": "Delete video",
      "method": "DELETE",
      "path": "/videos/{id}",
      "fields": [
        { "id": "id", "label": "Video ID", "type": "text", "required": true, "in": "path" }
      ]
    }
  ]
}
