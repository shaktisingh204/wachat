{
  "id": "n8n-g-suite-admin",
  "name": "Google Workspace Admin",
  "description": "Consume Google Workspace Admin API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 12,
  "lastVerified": "2026-06-12",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "credentialType": "oauth2"
  },
  "baseUrl": "https://www.googleapis.com/admin",
  "endpoints": [
    {
      "id": "device_get",
      "label": "Get ChromeOS Device",
      "method": "GET",
      "path": "/directory/v1/customer/my_customer/devices/chromeos/{deviceId}?projection={output}",
      "fields": [
        {
          "id": "deviceId",
          "label": "Device",
          "type": "text",
          "required": true,
          "description": "Select the device you want to retrieve (provide the ID)",
          "in": "path"
        },
        {
          "id": "projection",
          "label": "Output",
          "type": "select",
          "required": true,
          "description": "What subset of fields to fetch for this device",
          "defaultValue": "basic",
          "options": [
            {
              "value": "basic",
              "label": "Basic"
            },
            {
              "value": "full",
              "label": "Full"
            }
          ]
        }
      ],
      "group": "ChromeOS Device",
      "description": "Get a ChromeOS device"
    },
    {
      "id": "device_get_all",
      "label": "Get Many ChromeOS Device",
      "method": "GET",
      "path": "/directory/v1/customer/my_customer/devices/chromeos",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 100
        },
        {
          "id": "projection",
          "label": "Output",
          "type": "select",
          "required": true,
          "description": "What subset of fields to fetch for this device",
          "defaultValue": "basic",
          "options": [
            {
              "value": "basic",
              "label": "Basic"
            },
            {
              "value": "full",
              "label": "Full"
            }
          ]
        },
        {
          "id": "includeChildOrgunits",
          "label": "Include Children",
          "type": "toggle",
          "description": "Whether to include devices from organizational units below your specified organizational unit",
          "defaultValue": false
        },
        {
          "id": "filter",
          "label": "Filter",
          "type": "json",
          "placeholder": "Add Filter",
          "description": "(JSON object; supported keys: orgUnitPath, query)"
        },
        {
          "id": "sort",
          "label": "Sort",
          "type": "json",
          "placeholder": "Add Sort Rule",
          "description": "Define sorting rules for the results (JSON object; supported keys: sortRules, sortRules.orderBy, sortRules.sortBy)"
        }
      ],
      "group": "ChromeOS Device",
      "description": "Get many ChromeOS devices"
    },
    {
      "id": "device_update",
      "label": "Update ChromeOS Device",
      "method": "PUT",
      "path": "/directory/v1/customer/my_customer/devices/chromeos/{deviceId}",
      "fields": [
        {
          "id": "deviceId",
          "label": "Device",
          "type": "text",
          "required": true,
          "description": "Select the device you want to retrieve (provide the ID)",
          "in": "path"
        },
        {
          "id": "updateOptions",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add Option",
          "description": "(JSON object; supported keys: orgUnitPath, annotatedUser, annotatedLocation, annotatedAssetId, notes)"
        }
      ],
      "group": "ChromeOS Device",
      "description": "Update a ChromeOS device"
    },
    {
      "id": "device_change_status",
      "label": "Change Status ChromeOS Device",
      "method": "POST",
      "path": "/directory/v1/customer/my_customer/devices/chromeos/{deviceId}/action",
      "fields": [
        {
          "id": "deviceId",
          "label": "Device",
          "type": "text",
          "required": true,
          "description": "Select the device you want to retrieve (provide the ID)",
          "in": "path"
        },
        {
          "id": "action",
          "label": "Status",
          "type": "select",
          "required": true,
          "description": "Set the status of a device",
          "defaultValue": "reenable",
          "options": [
            {
              "value": "reenable",
              "label": "Enabled"
            },
            {
              "value": "disable",
              "label": "Disabled"
            }
          ]
        }
      ],
      "group": "ChromeOS Device",
      "description": "Change the status of a ChromeOS device"
    },
    {
      "id": "group_create",
      "label": "Create Group",
      "method": "POST",
      "path": "/directory/v1/groups",
      "fields": [
        {
          "id": "name",
          "label": "Group Name",
          "type": "text",
          "placeholder": "e.g. Sales",
          "description": "The group's display name"
        },
        {
          "id": "email",
          "label": "Group Email",
          "type": "text",
          "required": true,
          "placeholder": "e.g. sales@example.com",
          "description": "The group's email address. If your account has multiple domains, select the appropriate domain for the email address. The email must be unique"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: description)"
        }
      ],
      "group": "Group",
      "description": "Create a group"
    },
    {
      "id": "group_delete",
      "label": "Delete Group",
      "method": "DELETE",
      "path": "/directory/v1/groups/{groupId}",
      "fields": [
        {
          "id": "groupId",
          "label": "Group",
          "type": "text",
          "required": true,
          "description": "Select the group to perform the operation on (provide the ID)",
          "in": "path"
        }
      ],
      "group": "Group",
      "description": "Delete a group"
    },
    {
      "id": "group_get",
      "label": "Get Group",
      "method": "GET",
      "path": "/directory/v1/groups/{groupId}",
      "fields": [
        {
          "id": "groupId",
          "label": "Group",
          "type": "text",
          "required": true,
          "description": "Select the group to perform the operation on (provide the ID)",
          "in": "path"
        }
      ],
      "group": "Group",
      "description": "Get a group"
    },
    {
      "id": "group_get_all",
      "label": "Get Many Group",
      "method": "GET",
      "path": "/directory/v1/groups",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
