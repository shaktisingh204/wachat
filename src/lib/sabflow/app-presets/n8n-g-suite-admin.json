          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 100
        },
        {
          "id": "filter",
          "label": "Filter",
          "type": "json",
          "placeholder": "Add Filter",
          "description": "(JSON object; supported keys: customer, domain, query, userId)"
        },
        {
          "id": "sort",
          "label": "Sort",
          "type": "json",
          "placeholder": "Add Sort Rule",
          "description": "(JSON object; supported keys: sortRules, sortRules.orderBy, sortRules.sortOrder)"
