{
  "id": "ashby",
  "name": "Ashby",
  "description": "Ashby ATS API.",
  "category": "HR",
  "iconName": "LuUsers",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": { "type": "basic", "credentialType": "ashby" },
  "baseUrl": "https://api.ashbyhq.com",
  "endpoints": [
    { "id": "list_candidates", "label": "List candidates", "method": "POST", "path": "/candidate.list", "fields": [{ "id": "syncToken", "type": "text", "in": "body" }, { "id": "cursor", "type": "text", "in": "body" }] },
    { "id": "info_candidate", "label": "Info candidate", "method": "POST", "path": "/candidate.info", "fields": [{ "id": "candidateId", "type": "text", "required": true, "in": "body" }] },
    { "id": "create_candidate", "label": "Create candidate", "method": "POST", "path": "/candidate.create", "fields": [{ "id": "name", "type": "text", "required": true, "in": "body" }, { "id": "email", "type": "text", "in": "body" }, { "id": "phoneNumber", "type": "text", "in": "body" }, { "id": "position", "type": "text", "in": "body" }, { "id": "source", "type": "text", "in": "body" }] },
    { "id": "update_candidate", "label": "Update candidate", "method": "POST", "path": "/candidate.update", "fields": [{ "id": "candidateId", "type": "text", "required": true, "in": "body" }] },
    { "id": "add_candidate_tag", "label": "Add candidate tag", "method": "POST", "path": "/candidate.addTag", "fields": [{ "id": "candidateId", "type": "text", "required": true, "in": "body" }, { "id": "tagId", "type": "text", "required": true, "in": "body" }] },
    { "id": "list_jobs", "label": "List jobs", "method": "POST", "path": "/job.list", "fields": [{ "id": "status", "type": "text", "in": "body" }] },
    { "id": "list_applications", "label": "List applications", "method": "POST", "path": "/application.list", "fields": [] },
    { "id": "change_stage", "label": "Change stage", "method": "POST", "path": "/application.changeStage", "fields": [{ "id": "applicationId", "type": "text", "required": true, "in": "body" }, { "id": "interviewStageId", "type": "text", "required": true, "in": "body" }] },
    { "id": "list_users", "label": "List users", "method": "POST", "path": "/user.list", "fields": [] },
    { "id": "create_note", "label": "Create note", "method": "POST", "path": "/candidate.createNote", "fields": [{ "id": "candidateId", "type": "text", "required": true, "in": "body" }, { "id": "note", "type": "textarea", "required": true, "in": "body" }, { "id": "sendNotifications", "type": "toggle", "in": "body" }] }
  ]
}
