  "baseUrl": "https://people.googleapis.com/v1",
  "endpoints": [
    {
      "id": "contact_create",
      "label": "Create Contact",
      "method": "POST",
      "path": "/people:createContact",
      "fields": [
        {
          "id": "familyName",
          "label": "Family Name",
          "type": "text"
        },
        {
          "id": "givenName",
          "label": "Given Name",
          "type": "text"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: addressesUi, birthday, companyUi, customFieldsUi, emailsUi, eventsUi, fileAs, group, honorificPrefix, honorificSuffix, middleName, biographies, phoneUi, relationsUi)"
        }
      ],
      "group": "Contact",
      "description": "Create a contact"
    },
    {
      "id": "contact_delete",
      "label": "Delete Contact",
      "method": "DELETE",
      "path": "/people/{contactId}:deleteContact",
