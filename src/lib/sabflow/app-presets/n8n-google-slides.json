{
  "id": "n8n-google-slides",
  "name": "Google Slides",
  "description": "Consume the Google Slides API",
  "category": "productivity",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "provider": "google",
    "credentialType": "google_sheets",
    "fallback": {
      "type": "header",
      "credentialType": "http_header_auth"
    }
  },
  "baseUrl": "https://slides.googleapis.com/v1",
  "endpoints": [
    {
      "id": "presentation_create",
      "label": "Create Presentation",
      "method": "POST",
      "path": "/presentations",
      "fields": [
        {
          "id": "title",
          "label": "Title",
          "type": "text",
          "required": true,
          "description": "Title of the presentation to create"
        }
      ],
      "group": "Presentation",
      "description": "Create a presentation"
    },
    {
      "id": "presentation_get",
      "label": "Get Presentation",
      "method": "GET",
      "path": "/presentations/{presentationId}",
      "fields": [
        {
          "id": "presentationId",
          "label": "Presentation ID",
          "type": "text",
          "required": true,
          "placeholder": "1wZtNFZ8MO-WKrxhYrOLMvyiqSgFwdSz5vn8_l_7eNqw",
          "description": "ID of the presentation to retrieve. Found in the presentation URL: https://docs.google.com/presentation/d/PRESENTATION_ID/edit",
          "in": "path"
        }
      ],
      "group": "Presentation",
      "description": "Get a presentation"
    },
    {
      "id": "presentation_get_slides",
      "label": "Get Slides Presentation",
      "method": "GET",
      "path": "/presentations/{presentationId}",
      "fields": [
        {
          "id": "presentationId",
          "label": "Presentation ID",
          "type": "text",
          "required": true,
          "placeholder": "1wZtNFZ8MO-WKrxhYrOLMvyiqSgFwdSz5vn8_l_7eNqw",
          "description": "ID of the presentation to retrieve. Found in the presentation URL: https://docs.google.com/presentation/d/PRESENTATION_ID/edit",
          "in": "path"
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 100
        }
      ],
      "group": "Presentation",
      "description": "Get presentation slides"
    },
    {
      "id": "presentation_replace_text",
      "label": "Replace Text Presentation",
      "method": "POST",
      "path": "/presentations/{presentationId}:batchUpdate",
      "fields": [
        {
          "id": "presentationId",
          "label": "Presentation ID",
          "type": "text",
          "required": true,
          "placeholder": "1wZtNFZ8MO-WKrxhYrOLMvyiqSgFwdSz5vn8_l_7eNqw",
          "description": "ID of the presentation to retrieve. Found in the presentation URL: https://docs.google.com/presentation/d/PRESENTATION_ID/edit",
          "in": "path"
        },
        {
          "id": "textUi",
          "label": "Texts To Replace",
          "type": "json",
          "placeholder": "Add Text",
          "description": "(JSON object; supported keys: textValues, textValues.matchCase, textValues.pageObjectIds, textValues.text, textValues.replaceText)"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: revisionId)"
        }
      ],
      "group": "Presentation",
      "description": "Replace text in a presentation"
    },
    {
      "id": "page_get",
      "label": "Get Page",
      "method": "GET",
      "path": "/presentations/{presentationId}/pages/{pageObjectId}",
      "fields": [
        {
          "id": "presentationId",
          "label": "Presentation ID",
          "type": "text",
          "required": true,
          "placeholder": "1wZtNFZ8MO-WKrxhYrOLMvyiqSgFwdSz5vn8_l_7eNqw",
          "description": "ID of the presentation to retrieve. Found in the presentation URL: https://docs.google.com/presentation/d/PRESENTATION_ID/edit",
          "in": "path"
        },
        {
          "id": "pageObjectId",
          "label": "Page Object ID",
          "type": "text",
          "required": true,
          "description": "ID of the page object to retrieve",
          "in": "path"
        }
      ],
      "group": "Page",
      "description": "Get a page"
    },
    {
      "id": "page_get_thumbnail",
      "label": "Get Thumbnail Page",
      "method": "GET",
      "path": "/presentations/{presentationId}/pages/{pageObjectId}/thumbnail",
      "fields": [
        {
          "id": "presentationId",
          "label": "Presentation ID",
          "type": "text",
          "required": true,
          "placeholder": "1wZtNFZ8MO-WKrxhYrOLMvyiqSgFwdSz5vn8_l_7eNqw",
          "description": "ID of the presentation to retrieve. Found in the presentation URL: https://docs.google.com/presentation/d/PRESENTATION_ID/edit",
          "in": "path"
        },
        {
          "id": "pageObjectId",
          "label": "Page Object ID",
          "type": "text",
          "required": true,
          "description": "ID of the page object to retrieve",
          "in": "path"
        },
        {
          "id": "download",
          "label": "Download",
          "type": "toggle",
          "description": "Name of the binary property to which to write the data of the read page",
          "defaultValue": false
        },
        {
          "id": "binaryProperty",
          "label": "Put Output File in Field",
          "type": "text",
          "required": true,
          "defaultValue": "data"
        }
      ],
      "group": "Page",
      "description": "Get a thumbnail"
    }
  ]
}
