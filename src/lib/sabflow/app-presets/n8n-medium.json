{
  "id": "n8n-medium",
  "name": "Medium",
  "description": "Consume Medium API",
  "category": "communication",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://api.medium.com/v1",
  "endpoints": [
    {
      "id": "post_create",
      "label": "Create Post",
      "method": "POST",
      "path": "/publications/{publicationId}/posts",
      "fields": [
        {
          "id": "publication",
          "label": "Publication",
          "type": "toggle",
          "description": "Whether you are posting for a publication",
          "defaultValue": false
        },
        {
          "id": "publicationId",
          "label": "Publication Name or ID",
          "type": "select",
          "description": "Publication IDs. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        },
        {
          "id": "title",
          "label": "Title",
          "type": "text",
          "required": true,
          "placeholder": "My Open Source Contribution",
          "description": "Title of the post. Max Length : 100 characters."
        },
        {
          "id": "contentFormat",
          "label": "Content Format",
          "type": "select",
          "required": true,
          "description": "The format of the content to be posted",
          "options": [
            {
              "value": "html",
              "label": "HTML"
            },
            {
              "value": "markdown",
              "label": "Markdown"
            }
          ]
        },
        {
          "id": "content",
          "label": "Content",
          "type": "text",
          "required": true,
          "placeholder": "My open source contribution",
          "description": "The body of the post, in a valid semantic HTML fragment, or Markdown"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: canonicalUrl, license, notifyFollowers, publishStatus, tags)"
        }
      ],
      "group": "Post",
      "description": "Create a post"
    },
    {
      "id": "publication_get_all",
      "label": "Get Many Publication",
      "method": "GET",
      "path": "/me",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 100
        }
      ],
      "group": "Publication",
      "description": "Get many publications"
    }
  ]
}
