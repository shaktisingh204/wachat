          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50
        }
      ],
      "group": "Service",
      "description": "Get many services"
    },
    {
      "id": "state_upsert",
      "label": "Create or Update State",
      "method": "POST",
      "path": "/states/{entityId}",
      "fields": [
        {
          "id": "entityId",
          "label": "Entity Name or ID",
          "type": "select",
          "required": true,
          "description": "The entity ID for which a state will be created. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        },
        {
          "id": "state",
          "label": "State",
          "type": "text",
          "required": true
        },
        {
          "id": "stateAttributes",
          "label": "State Attributes",
          "type": "json",
          "placeholder": "Add Attribute",
          "description": "(JSON object; supported keys: attributes, attributes.name, attributes.value)"
        }
      ],
      "group": "State",
      "description": "Create a new record, or update the current one if it already exists (upsert)"
    },
    {
      "id": "state_get",
      "label": "Get State",
      "method": "GET",
      "path": "/states/{entityId}",
      "fields": [
        {
          "id": "entityId",
          "label": "Entity Name or ID",
          "type": "select",
          "required": true,
          "description": "Choose from the list, or specify an ID using an expression",
          "in": "path"
        }
      ],
      "group": "State",
      "description": "Get a state for a specific entity"
    },
    {
      "id": "state_get_all",
      "label": "Get Many State",
      "method": "GET",
      "path": "/states",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50
        }
      ],
      "group": "State",
      "description": "Get many states"
    },
    {
      "id": "template_create",
      "label": "Create Template",
      "method": "POST",
      "path": "/template",
      "fields": [
        {
          "id": "template",
          "label": "Template",
          "type": "text",
          "required": true,
          "description": "Render a Home Assistant template. See template docs for more information.."
        }
      ],
      "group": "Template",
      "description": "Create a template"
    }
  ]
}
