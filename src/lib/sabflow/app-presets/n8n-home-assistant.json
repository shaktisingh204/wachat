      "label": "Call Service",
      "method": "POST",
      "path": "/services/{domain}/{service}",
      "fields": [
        {
          "id": "domain",
          "label": "Domain Name or ID",
          "type": "select",
          "required": true,
          "description": "Choose from the list, or specify an ID using an expression",
          "in": "path"
        },
        {
          "id": "service",
          "label": "Service Name or ID",
          "type": "select",
          "required": true,
          "description": "Choose from the list, or specify an ID using an expression",
          "in": "path"
        },
        {
          "id": "serviceAttributes",
          "label": "Service Attributes",
          "type": "json",
          "placeholder": "Add Attribute",
          "description": "(JSON object; supported keys: attributes, attributes.name, attributes.value)"
        }
