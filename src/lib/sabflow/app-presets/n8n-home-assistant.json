{
  "id": "n8n-home-assistant",
  "name": "Home Assistant",
  "description": "Consume Home Assistant API",
  "category": "dev",
  "iconName": "LuPackage",
  "version": 2,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "bearer",
    "credentialType": "home_assistant",
    "baseUrlFromCredential": "baseUrl"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "camera_proxy_get_screenshot",
      "label": "Get Screenshot Camera Proxy",
      "method": "GET",
      "path": "/camera_proxy/{cameraEntityId}",
      "fields": [
        {
          "id": "cameraEntityId",
          "label": "Camera Entity Name or ID",
          "type": "select",
          "required": true,
          "description": "Choose from the list, or specify an ID using an expression",
          "in": "path"
        },
        {
          "id": "binaryPropertyName",
          "label": "Put Output File in Field",
          "type": "text",
          "required": true,
          "defaultValue": "data"
        }
      ],
      "group": "Camera Proxy",
      "description": "Get the camera screenshot"
    },
    {
      "id": "config_get",
      "label": "Get Config",
      "method": "GET",
      "path": "/config",
      "fields": [],
      "group": "Config",
      "description": "Get the configuration"
    },
    {
      "id": "config_check",
      "label": "Check Configuration Config",
      "method": "POST",
      "path": "/config/core/check_config",
      "fields": [],
      "group": "Config",
      "description": "Check the configuration"
    },
    {
      "id": "event_create",
      "label": "Create Event",
      "method": "POST",
      "path": "/events/{eventType}",
      "fields": [
        {
          "id": "eventType",
          "label": "Event Type",
          "type": "text",
          "required": true,
          "description": "The Entity ID for which an event will be created",
          "in": "path"
        },
        {
          "id": "eventAttributes",
          "label": "Event Attributes",
          "type": "json",
          "placeholder": "Add Attribute",
          "description": "(JSON object; supported keys: attributes, attributes.name, attributes.value)"
        }
      ],
      "group": "Event",
      "description": "Create an event"
    },
    {
      "id": "event_get_all",
      "label": "Get Many Event",
      "method": "GET",
      "path": "/events",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50
        }
      ],
      "group": "Event",
      "description": "Get many events"
    },
    {
      "id": "history_get_all",
      "label": "Get Many History",
      "method": "GET",
      "path": "/history/period",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: endTime, entityIds, minimalResponse, significantChangesOnly, startTime)"
        }
      ],
      "group": "History",
      "description": "Get many state changes"
    },
    {
      "id": "log_get_erro_logs",
      "label": "Get Error Logs Log",
      "method": "GET",
      "path": "/error_log",
      "fields": [],
      "group": "Log",
      "description": "Get a log for a specific entity"
    },
    {
      "id": "log_get_logbook_entries",
      "label": "Get Logbook Entries Log",
      "method": "GET",
      "path": "/logbook",
      "fields": [
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: endTime, entityId, startTime)"
        }
      ],
      "group": "Log",
      "description": "Get all logs"
    },
    {
