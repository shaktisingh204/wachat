{
  "id": "fillout",
  "name": "Fillout",
  "description": "Fillout API for managing forms, submissions, and webhooks.",
  "category": "Forms",
  "iconName": "LuClipboardList",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "bearer",
    "credentialType": "fillout"
  },
  "baseUrl": "https://api.fillout.com/v1/api",
  "endpoints": [
    {
      "id": "list_forms",
      "label": "List forms",
      "method": "GET",
      "path": "/forms",
      "fields": [
        { "id": "limit", "label": "Limit", "type": "number", "defaultValue": 50, "in": "query" },
        { "id": "offset", "label": "Offset", "type": "number", "in": "query" }
      ]
    },
    {
      "id": "get_form",
      "label": "Get form",
      "method": "GET",
      "path": "/forms/{formId}",
      "fields": [
        { "id": "formId", "label": "Form ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "list_submissions",
      "label": "List submissions",
      "method": "GET",
      "path": "/forms/{formId}/submissions",
      "fields": [
        { "id": "formId", "label": "Form ID", "type": "text", "required": true, "in": "path" },
        { "id": "limit", "label": "Limit", "type": "number", "defaultValue": 50, "in": "query" },
        { "id": "offset", "label": "Offset", "type": "number", "in": "query" },
        { "id": "afterDate", "label": "After date (ISO)", "type": "text", "in": "query" },
        { "id": "beforeDate", "label": "Before date (ISO)", "type": "text", "in": "query" }
      ]
    },
    {
      "id": "get_submission",
      "label": "Get submission",
      "method": "GET",
      "path": "/forms/{formId}/submissions/{submissionId}",
      "fields": [
        { "id": "formId", "label": "Form ID", "type": "text", "required": true, "in": "path" },
        { "id": "submissionId", "label": "Submission ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "create_webhook",
      "label": "Create webhook",
      "method": "POST",
      "path": "/webhook/create",
      "fields": [
        { "id": "formId", "label": "Form ID", "type": "text", "required": true, "in": "body" },
        { "id": "url", "label": "Webhook URL", "type": "text", "required": true, "in": "body" }
      ]
    },
    {
      "id": "delete_webhook",
      "label": "Delete webhook",
      "method": "DELETE",
      "path": "/webhook/delete",
      "fields": [
        { "id": "webhookId", "label": "Webhook ID", "type": "text", "required": true, "in": "body" }
      ]
    }
  ]
}
