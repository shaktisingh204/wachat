{
  "id": "bunny-cdn",
  "name": "Bunny CDN Storage",
  "description": "Bunny.net edge storage API. Purge endpoints live on the separate management API (https://api.bunny.net) and are not included here.",
  "category": "CDN",
  "iconName": "LuCloud",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "header",
    "credentialType": "bunny_cdn",
    "header": "AccessKey"
  },
  "baseUrl": "https://storage.bunnycdn.com",
  "endpoints": [
    {
      "id": "list_storage_zones",
      "label": "List storage zones",
      "method": "GET",
      "path": "/",
      "fields": []
    },
    {
      "id": "list_files",
      "label": "List files",
      "method": "GET",
      "path": "/{storage_zone_name}/{path}/",
      "fields": [
        { "id": "storage_zone_name", "label": "Storage zone name", "type": "text", "required": true, "in": "path" },
        { "id": "path", "label": "Path", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "download_file",
      "label": "Download file",
      "method": "GET",
      "path": "/{storage_zone_name}/{path}/{filename}",
      "fields": [
        { "id": "storage_zone_name", "label": "Storage zone name", "type": "text", "required": true, "in": "path" },
        { "id": "path", "label": "Path", "type": "text", "required": true, "in": "path" },
        { "id": "filename", "label": "Filename", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "upload_file",
      "label": "Upload file",
      "method": "PUT",
      "path": "/{storage_zone_name}/{path}/{filename}",
      "fields": [
        { "id": "storage_zone_name", "label": "Storage zone name", "type": "text", "required": true, "in": "path" },
        { "id": "path", "label": "Path", "type": "text", "required": true, "in": "path" },
        { "id": "filename", "label": "Filename", "type": "text", "required": true, "in": "path" },
        { "id": "body", "label": "Raw body", "type": "textarea", "required": true, "in": "body" }
      ]
    },
    {
      "id": "delete_file",
      "label": "Delete file",
      "method": "DELETE",
      "path": "/{storage_zone_name}/{path}/{filename}",
      "fields": [
        { "id": "storage_zone_name", "label": "Storage zone name", "type": "text", "required": true, "in": "path" },
        { "id": "path", "label": "Path", "type": "text", "required": true, "in": "path" },
        { "id": "filename", "label": "Filename", "type": "text", "required": true, "in": "path" }
      ]
    }
  ]
}
