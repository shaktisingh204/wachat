{
  "id": "n8n-mindee",
  "name": "Mindee",
  "description": "Consume Mindee API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 10,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://api.mindee.net/products",
  "endpoints": [
    {
      "id": "invoice_predict",
      "label": "Predict Invoice",
      "method": "POST",
      "path": "/invoices/v1/predict",
      "fields": [
        {
          "id": "apiVersion",
          "label": "API Version",
          "type": "select",
          "description": "Which Mindee API Version to use",
          "defaultValue": 1,
          "options": [
            {
              "value": "1",
              "label": "1"
            },
            {
              "value": "3",
              "label": "3"
            },
            {
              "value": "4",
              "label": "4"
            }
          ]
        },
        {
          "id": "binaryPropertyName",
          "label": "Input Binary Field",
          "type": "text",
          "required": true,
          "defaultValue": "data"
        },
        {
          "id": "rawData",
          "label": "RAW Data",
          "type": "toggle",
          "description": "Whether to return the data exactly in the way it got received from the API",
          "defaultValue": false
        }
      ],
      "group": "Invoice"
    },
    {
      "id": "receipt_predict",
      "label": "Predict Receipt",
      "method": "POST",
      "path": "/expense_receipts/v2/predict",
      "fields": [
        {
          "id": "apiVersion",
          "label": "API Version",
          "type": "select",
          "description": "Which Mindee API Version to use",
          "defaultValue": 1,
          "options": [
            {
              "value": "1",
              "label": "1"
            },
            {
              "value": "3",
              "label": "3"
            },
            {
              "value": "4",
              "label": "4"
            }
          ]
        },
        {
          "id": "binaryPropertyName",
          "label": "Input Binary Field",
          "type": "text",
          "required": true,
          "defaultValue": "data"
        },
        {
          "id": "rawData",
          "label": "RAW Data",
          "type": "toggle",
          "description": "Whether to return the data exactly in the way it got received from the API",
          "defaultValue": false
        }
      ],
      "group": "Receipt"
    }
  ]
}
