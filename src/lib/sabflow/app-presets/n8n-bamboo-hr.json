          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: address, dateOfBirth, department, division, employeeNumber, exempt, gender, hireDate, location, maritalStatus, mobilePhone, paidPer, payRate, payType, preferredName, ssn, workEmail, workPhone)"
        }
