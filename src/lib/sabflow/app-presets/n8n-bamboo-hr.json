            {
              "value": "daily",
              "label": "Daily"
            },
            {
              "value": "exceptionHourly",
              "label": "Exception Hourly"
            },
            {
              "value": "hourly",
              "label": "Hourly"
            },
            {
              "value": "monthly",
              "label": "Monthly"
            },
            {
              "value": "pieceRate",
              "label": "Piece Rate"
            },
            {
              "value": "proRata",
              "label": "Pro Rata"
            },
            {
              "value": "salary",
              "label": "Salary"
            },
            {
              "value": "weekly",
              "label": "Weekly"
            }
          ]
        },
        {
          "id": "preferredName",
          "label": "Preferred Name",
          "type": "text",
          "required": true
        },
        {
          "id": "ssn",
          "label": "Social Security Number",
          "type": "text",
          "required": true,
          "placeholder": "123-45-6789",
          "description": "A standard United States Social Security number, with dashes"
