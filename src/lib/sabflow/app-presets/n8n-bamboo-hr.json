        {
          "id": "synced",
          "label": "Synced with Trax Payroll",
          "type": "toggle",
          "required": true,
          "description": "Whether the employee to create was added to a pay schedule synced with Trax Payroll",
          "defaultValue": false
        },
        {
          "id": "firstName",
          "label": "First Name",
          "type": "text",
          "required": true
        },
        {
          "id": "lastName",
          "label": "Last Name",
          "type": "text",
          "required": true
        },
        {
          "id": "address",
          "label": "Address",
          "type": "json",
          "required": true,
          "placeholder": "Address",
          "description": "(JSON object; supported keys: value, value.address1, value.address2, value.city, value.state, value.country)"
        },
        {
          "id": "dateOfBirth",
          "label": "Date of Birth",
          "type": "text",
          "required": true,
          "placeholder": "2024-01-01T00:00:00Z",
          "description": "(ISO 8601 date-time)"
        },
        {
          "id": "department",
          "label": "Department Name or ID",
          "type": "select",
          "required": true,
          "description": "Choose from the list, or specify an ID using an expression"
        },
        {
          "id": "division",
          "label": "Division Name or ID",
          "type": "select",
          "required": true,
          "description": "Choose from the list, or specify an ID using an expression"
