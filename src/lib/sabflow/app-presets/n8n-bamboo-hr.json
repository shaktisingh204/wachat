        {
          "id": "paidPer",
          "label": "Pay Per",
          "type": "select",
          "required": true,
          "options": [
            {
              "value": "hour",
              "label": "Hour"
            },
            {
              "value": "day",
              "label": "Day"
            },
            {
              "value": "week",
              "label": "Week"
            },
            {
              "value": "month",
              "label": "Month"
            },
            {
              "value": "quater",
              "label": "Quater"
            },
            {
              "value": "year",
              "label": "Year"
