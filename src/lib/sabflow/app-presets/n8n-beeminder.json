{
  "id": "n8n-beeminder",
  "name": "Beeminder",
  "description": "Consume Beeminder API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 12,
  "lastVerified": "2026-06-12",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://www.beeminder.com/api/v1",
  "endpoints": [
    {
      "id": "charge_create",
      "label": "Create Charge",
      "method": "POST",
      "path": "/charges.json",
      "fields": [
        {
          "id": "amount",
          "label": "Amount",
          "type": "number",
          "required": true,
          "description": "Charge amount in USD",
          "defaultValue": 0
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: note, dryrun)"
        }
      ],
      "group": "Charge",
      "description": "Create a charge"
    },
    {
      "id": "datapoint_create",
      "label": "Create Datapoint",
      "method": "POST",
      "path": "/users/me/goals/{goalName}/datapoints.json",
      "fields": [
        {
          "id": "goalName",
          "label": "Goal Name or ID",
          "type": "select",
          "required": true,
          "description": "The name of the goal. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        },
        {
          "id": "value",
          "label": "Value",
          "type": "number",
          "required": true,
          "description": "Datapoint value to send",
          "defaultValue": 1
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: comment, timestamp, requestid)"
        }
      ],
      "group": "Datapoint",
      "description": "Create datapoint for goal"
    },
    {
      "id": "datapoint_create_all",
      "label": "Create All Datapoint",
      "method": "POST",
      "path": "/users/me/goals/{goalName}/datapoints/create_all.json",
      "fields": [
        {
          "id": "goalName",
          "label": "Goal Name or ID",
          "type": "select",
          "required": true,
          "description": "The name of the goal. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        },
        {
          "id": "datapoints",
          "label": "Datapoints",
          "type": "json",
          "required": true,
          "placeholder": "[{\"value\": 1, \"comment\": \"First datapoint\"}, {\"value\": 2, \"comment\": \"Second datapoint\"}]",
          "description": "Array of datapoint objects to create. Each object should contain value and optionally timestamp, comment, etc.",
          "defaultValue": "[]"
        }
      ],
      "group": "Datapoint",
      "description": "Create multiple datapoints at once"
    },
    {
      "id": "datapoint_delete",
      "label": "Delete Datapoint",
      "method": "DELETE",
      "path": "/users/me/goals/{goalName}/datapoints/{datapointId}.json",
      "fields": [
        {
          "id": "goalName",
          "label": "Goal Name or ID",
          "type": "select",
          "required": true,
          "description": "The name of the goal. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        },
        {
          "id": "datapointId",
          "label": "Datapoint ID",
          "type": "text",
          "required": true,
          "in": "path"
        }
      ],
      "group": "Datapoint",
      "description": "Delete a datapoint"
    },
    {
      "id": "datapoint_get",
      "label": "Get Datapoint",
      "method": "GET",
      "path": "/users/me/goals/{goalName}/datapoints/{datapointId}.json",
      "fields": [
        {
          "id": "goalName",
          "label": "Goal Name or ID",
          "type": "select",
          "required": true,
          "description": "The name of the goal. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        },
        {
          "id": "datapointId",
          "label": "Datapoint ID",
          "type": "text",
          "required": true,
          "in": "path"
        }
      ],
      "group": "Datapoint",
      "description": "Get a single datapoint"
    },
    {
      "id": "datapoint_get_all",
      "label": "Get Many Datapoint",
      "method": "GET",
      "path": "/users/me/goals/{goalName}/datapoints.json",
      "fields": [
        {
          "id": "goalName",
          "label": "Goal Name or ID",
          "type": "select",
          "required": true,
          "description": "The name of the goal. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 30
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add field",
          "description": "(JSON object; supported keys: sort, page, per)"
        }
      ],
      "group": "Datapoint",
      "description": "Get many datapoints for a goal"
    },
    {
      "id": "datapoint_update",
      "label": "Update Datapoint",
      "method": "PUT",
      "path": "/users/me/goals/{goalName}/datapoints/{datapointId}.json",
      "fields": [
        {
          "id": "goalName",
          "label": "Goal Name or ID",
          "type": "select",
          "required": true,
          "description": "The name of the goal. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        },
        {
          "id": "datapointId",
          "label": "Datapoint ID",
          "type": "text",
          "required": true,
          "in": "path"
        },
        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: value, comment, timestamp)"
        }
      ],
      "group": "Datapoint",
      "description": "Update a datapoint"
    },
    {
      "id": "goal_create",
      "label": "Create Goal",
      "method": "POST",
      "path": "/users/me/goals.json",
      "fields": [
        {
          "id": "slug",
          "label": "Goal Slug",
          "type": "text",
          "required": true,
          "description": "Unique identifier for the goal"
        },
        {
          "id": "title",
          "label": "Goal Title",
          "type": "text",
          "required": true,
          "description": "Human-readable title for the goal"
        },
        {
          "id": "goal_type",
          "label": "Goal Type",
          "type": "select",
          "required": true,
          "description": "Type of goal. More info here..",
          "defaultValue": "hustler",
          "options": [
            {
              "value": "hustler",
              "label": "Hustler"
            },
            {
              "value": "biker",
              "label": "Biker"
            },
            {
              "value": "fatloser",
              "label": "Fatloser"
            },
            {
              "value": "gainer",
              "label": "Gainer"
            },
            {
              "value": "inboxer",
              "label": "Inboxer"
            },
            {
              "value": "drinker",
              "label": "Drinker"
            },
            {
              "value": "custom",
              "label": "Custom"
            }
          ]
        },
        {
          "id": "gunits",
          "label": "Goal Units",
          "type": "text",
          "required": true,
          "description": "Units for the goal (e.g., \"hours\", \"pages\", \"pounds\")"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: goaldate, goalval, rate, initval, secret, datapublic, datasource, dryrun, tags)"
        }
      ],
      "group": "Goal",
      "description": "Create a new goal"
    },
    {
      "id": "goal_get",
      "label": "Get Goal",
      "method": "GET",
      "path": "/users/me/goals/{goalName}.json",
      "fields": [
        {
          "id": "goalName",
          "label": "Goal Name or ID",
          "type": "select",
          "required": true,
          "description": "The name of the goal. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: datapoints, emaciated)"
        }
      ],
      "group": "Goal",
      "description": "Get a specific goal"
    },
    {
      "id": "goal_get_all",
      "label": "Get Many Goal",
      "method": "GET",
      "path": "/users/me/goals.json",
      "fields": [
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: emaciated)"
        }
      ],
      "group": "Goal",
      "description": "Get many goals"
    },
    {
      "id": "goal_get_archived",
      "label": "Get Archived Goal",
      "method": "GET",
      "path": "/users/me/goals/archived.json",
      "fields": [
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: emaciated)"
        }
      ],
      "group": "Goal",
      "description": "Get archived goals"
    },
    {
      "id": "goal_update",
      "label": "Update Goal",
      "method": "PUT",
      "path": "/users/me/goals/{goalName}.json",
      "fields": [
        {
          "id": "goalName",
          "label": "Goal Name or ID",
          "type": "select",
          "required": true,
          "description": "The name of the goal. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        },
        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: title, yaxis, tmin, tmax, secret, datapublic, roadall, datasource, tags)"
        }
      ],
      "group": "Goal",
      "description": "Update a goal"
    },
    {
      "id": "goal_refresh",
      "label": "Refresh Goal",
      "method": "GET",
      "path": "/users/me/goals/{goalName}/refresh_graph.json",
      "fields": [
        {
          "id": "goalName",
          "label": "Goal Name or ID",
          "type": "select",
          "required": true,
          "description": "The name of the goal. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        }
      ],
      "group": "Goal",
      "description": "Refresh goal data"
    },
    {
      "id": "goal_short_circuit",
      "label": "Short Circuit Goal",
      "method": "POST",
      "path": "/users/me/goals/{goalName}/shortcircuit.json",
      "fields": [
        {
          "id": "goalName",
          "label": "Goal Name or ID",
          "type": "select",
          "required": true,
          "description": "The name of the goal. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        }
      ],
      "group": "Goal",
      "description": "Short circuit pledge"
    },
    {
      "id": "goal_step_down",
      "label": "Step Down Goal",
      "method": "POST",
      "path": "/users/me/goals/{goalName}/stepdown.json",
      "fields": [
        {
          "id": "goalName",
          "label": "Goal Name or ID",
          "type": "select",
          "required": true,
          "description": "The name of the goal. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        }
      ],
      "group": "Goal",
      "description": "Step down pledge"
    },
    {
      "id": "goal_cancel_step_down",
      "label": "Cancel Step Down Goal",
      "method": "POST",
      "path": "/users/me/goals/{goalName}/cancel_stepdown.json",
      "fields": [
        {
          "id": "goalName",
          "label": "Goal Name or ID",
          "type": "select",
          "required": true,
          "description": "The name of the goal. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        }
      ],
      "group": "Goal",
      "description": "Cancel step down"
    },
    {
      "id": "goal_uncle",
      "label": "Uncle Goal",
      "method": "POST",
      "path": "/users/me/goals/{goalName}/uncleme.json",
      "fields": [
        {
          "id": "goalName",
          "label": "Goal Name or ID",
          "type": "select",
          "required": true,
          "description": "The name of the goal to derail. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        }
      ],
      "group": "Goal",
      "description": "Derail a goal and charge the pledge amount"
    },
    {
      "id": "user_get",
      "label": "Get User",
      "method": "GET",
      "path": "/users/me.json",
      "fields": [
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: associations, diff_since, skinny, emaciated, datapoints_count)"
        }
      ],
      "group": "User",
      "description": "Get user information"
    }
  ]
}
