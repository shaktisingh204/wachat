        {
          "id": "authentication",
          "label": "Authentication",
          "type": "select",
          "in": "query",
          "defaultValue": "apiToken",
          "options": [
            {
              "value": "apiToken",
              "label": "API Token"
            },
            {
              "value": "oAuth2",
              "label": "OAuth2"
            }
          ]
        },
        {
          "id": "amount",
          "label": "Amount",
          "type": "number",
          "in": "query",
          "required": true,
          "description": "Charge amount in USD",
          "defaultValue": 0
