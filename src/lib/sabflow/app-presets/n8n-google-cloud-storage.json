      "id": "bucket_create",
      "label": "Create Bucket",
      "method": "POST",
      "path": "/b/",
      "fields": [
        {
          "id": "projectId",
          "label": "Project ID",
          "type": "text",
          "required": true,
          "placeholder": "Project ID"
        },
        {
          "id": "bucketName",
          "label": "Bucket Name",
          "type": "text",
          "required": true,
          "placeholder": "Bucket Name"
        },
        {
          "id": "projection",
          "label": "Projection",
          "type": "select",
          "defaultValue": "noAcl",
          "options": [
            {
              "value": "full",
              "label": "All Properties"
            },
            {
              "value": "noAcl",
              "label": "No ACL"
            }
          ]
        },
        {
          "id": "createAcl",
          "label": "Predefined Access Control",
          "type": "json",
          "placeholder": "Add Access Control Parameters",
          "description": "(JSON object; supported keys: predefinedAcl, predefinedDefaultObjectAcl)"
        },
        {
          "id": "createBody",
          "label": "Additional Parameters",
          "type": "json",
          "placeholder": "Add Metadata Parameter",
