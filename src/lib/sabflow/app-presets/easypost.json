{
  "id": "easypost",
  "name": "EasyPost",
  "description": "EasyPost shipping API.",
  "category": "Shipping",
  "iconName": "LuTruck",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": { "type": "basic", "credentialType": "easypost" },
  "baseUrl": "https://api.easypost.com/v2",
  "endpoints": [
    { "id": "create_shipment", "label": "Create shipment", "method": "POST", "path": "/shipments", "fields": [{ "id": "shipment", "type": "json", "required": true, "in": "body", "defaultValue": { "to_address": {}, "from_address": {}, "parcel": {} } }] },
    { "id": "get_shipment", "label": "Get shipment", "method": "GET", "path": "/shipments/{id}", "fields": [{ "id": "id", "type": "text", "required": true, "in": "path" }] },
    { "id": "list_shipments", "label": "List shipments", "method": "GET", "path": "/shipments", "fields": [] },
    { "id": "buy_label", "label": "Buy label", "method": "POST", "path": "/shipments/{id}/buy", "fields": [{ "id": "id", "type": "text", "required": true, "in": "path" }, { "id": "rate", "type": "json", "required": true, "in": "body", "defaultValue": { "id": "" } }] },
    { "id": "refund_shipment", "label": "Refund shipment", "method": "POST", "path": "/shipments/{id}/refund", "fields": [{ "id": "id", "type": "text", "required": true, "in": "path" }] },
    { "id": "track_shipment", "label": "Track shipment", "method": "GET", "path": "/trackers/{id}", "fields": [{ "id": "id", "type": "text", "required": true, "in": "path" }] },
    { "id": "create_tracker", "label": "Create tracker", "method": "POST", "path": "/trackers", "fields": [{ "id": "tracker", "type": "json", "required": true, "in": "body", "defaultValue": { "tracking_code": "", "carrier": "" } }] },
    { "id": "create_address", "label": "Create address", "method": "POST", "path": "/addresses", "fields": [{ "id": "address", "type": "json", "required": true, "in": "body", "defaultValue": { "street1": "", "city": "", "state": "", "zip": "", "country": "US" } }] },
    { "id": "verify_address", "label": "Verify address", "method": "POST", "path": "/addresses", "fields": [{ "id": "address", "type": "json", "required": true, "in": "body" }, { "id": "verify", "type": "json", "required": true, "in": "body", "defaultValue": ["delivery"] }] },
    { "id": "list_carriers", "label": "List carrier accounts", "method": "GET", "path": "/carrier_accounts", "fields": [] }
  ]
}
