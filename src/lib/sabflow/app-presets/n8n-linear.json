{
  "id": "n8n-linear",
  "name": "Linear",
  "description": "Consume Linear API",
  "category": "dev",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "provider": "linear",
    "credentialType": "linear",
    "fallback": {
      "type": "header",
      "credentialType": "http_header_auth"
    }
  },
  "baseUrl": "https://api.linear.app/graphql",
  "endpoints": [
    {
      "id": "comment_add_comment",
      "label": "Add Comment Comment",
      "method": "POST",
      "path": "/comment",
      "fields": [
        {
          "id": "issueId",
          "label": "Issue ID",
          "type": "text",
          "required": true
        },
        {
          "id": "comment",
          "label": "Comment",
          "type": "text",
          "required": true
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: parentId)"
        }
      ],
      "group": "Comment",
      "description": "[unverified path] Add a comment to an issue"
    },
    {
      "id": "issue_add_link",
      "label": "Add Link Issue",
      "method": "POST",
      "path": "/issue",
      "fields": [
        {
          "id": "issueId",
          "label": "Issue ID",
          "type": "text",
          "required": true
        },
        {
          "id": "link",
          "label": "Link",
          "type": "text",
          "required": true
        }
      ],
      "group": "Issue",
      "description": "[unverified path] Add a link to an issue"
    },
    {
      "id": "issue_create",
      "label": "Create Issue",
      "method": "POST",
      "path": "/issue",
      "fields": [
        {
          "id": "teamId",
          "label": "Team Name or ID",
          "type": "select",
          "required": true,
          "description": "Choose from the list, or specify an ID using an expression"
        },
        {
          "id": "title",
          "label": "Title",
          "type": "text",
          "required": true
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: assigneeId, description, priorityId, stateId)"
        }
      ],
      "group": "Issue",
      "description": "[unverified path] Create an issue"
    },
    {
      "id": "issue_delete",
      "label": "Delete Issue",
      "method": "DELETE",
      "path": "/issue",
      "fields": [
        {
          "id": "issueId",
          "label": "Issue ID",
          "type": "text",
          "required": true
        }
      ],
      "group": "Issue",
      "description": "[unverified path] Delete an issue"
    },
    {
      "id": "issue_get",
      "label": "Get Issue",
      "method": "GET",
      "path": "/issue",
      "fields": [
        {
          "id": "issueId",
          "label": "Issue ID",
          "type": "text",
          "required": true
        }
      ],
      "group": "Issue",
      "description": "[unverified path] Get an issue"
    },
    {
      "id": "issue_get_all",
      "label": "Get Many Issue",
      "method": "GET",
      "path": "/issue",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50
        }
      ],
      "group": "Issue",
      "description": "[unverified path] Get many issues"
    },
    {
      "id": "issue_update",
      "label": "Update Issue",
      "method": "PATCH",
      "path": "/issue",
      "fields": [
        {
          "id": "issueId",
          "label": "Issue ID",
          "type": "text",
          "required": true
        },
        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: assigneeId, description, priorityId, stateId, teamId, title)"
        }
      ],
      "group": "Issue",
      "description": "[unverified path] Update an issue"
    }
  ]
}
