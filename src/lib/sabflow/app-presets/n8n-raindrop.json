      "description": "Get many collections"
    },
    {
      "id": "collection_update",
      "label": "Update Collection",
      "method": "PUT",
      "path": "/collection/{collectionId}",
      "fields": [
        {
          "id": "collectionId",
          "label": "Collection ID",
          "type": "text",
          "required": true,
          "description": "The ID of the collection to update",
          "in": "path"
        },
        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: cover, public, parentId, sort, title, view)"
        }
      ],
      "group": "Collection",
      "description": "Update a collection"
    },
    {
