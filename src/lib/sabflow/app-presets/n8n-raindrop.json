{
  "id": "n8n-raindrop",
  "name": "Raindrop",
  "description": "Consume the Raindrop API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 12,
  "lastVerified": "2026-06-12",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "credentialType": "oauth2"
  },
  "baseUrl": "https://api.raindrop.io/rest/v1",
  "endpoints": [
    {
      "id": "bookmark_create",
      "label": "Create Bookmark",
      "method": "POST",
      "path": "/raindrop",
      "fields": [
        {
          "id": "collectionId",
          "label": "Collection Name or ID",
          "type": "select",
          "description": "Choose from the list, or specify an ID using an expression"
        },
        {
          "id": "link",
          "label": "Link",
          "type": "text",
          "required": true,
          "description": "Link of the bookmark to be created"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: important, order, pleaseParse, tags, title)"
        }
      ],
      "group": "Bookmark",
      "description": "Create a bookmark"
    },
    {
      "id": "bookmark_delete",
      "label": "Delete Bookmark",
      "method": "DELETE",
      "path": "/raindrop/{bookmarkId}",
      "fields": [
        {
          "id": "bookmarkId",
          "label": "Bookmark ID",
          "type": "text",
          "required": true,
          "description": "The ID of the bookmark to delete",
          "in": "path"
        }
      ],
      "group": "Bookmark",
      "description": "Delete a bookmark"
    },
    {
      "id": "bookmark_get",
      "label": "Get Bookmark",
      "method": "GET",
      "path": "/raindrop/{bookmarkId}",
      "fields": [
        {
          "id": "bookmarkId",
          "label": "Bookmark ID",
          "type": "text",
          "required": true,
          "description": "The ID of the bookmark to retrieve",
          "in": "path"
        }
      ],
      "group": "Bookmark",
      "description": "Get a bookmark"
    },
    {
      "id": "bookmark_get_all",
      "label": "Get Many Bookmark",
      "method": "GET",
      "path": "/raindrops/{collectionId}",
      "fields": [
        {
          "id": "collectionId",
          "label": "Collection Name or ID",
          "type": "select",
          "required": true,
          "description": "The ID of the collection from which to retrieve all bookmarks. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 5
        }
      ],
      "group": "Bookmark",
      "description": "Get many bookmarks"
    },
    {
      "id": "bookmark_update",
      "label": "Update Bookmark",
      "method": "PUT",
      "path": "/raindrop/{bookmarkId}",
      "fields": [
        {
          "id": "bookmarkId",
          "label": "Bookmark ID",
          "type": "text",
          "required": true,
          "description": "The ID of the bookmark to update",
          "in": "path"
        },
        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: collectionId, important, order, pleaseParse, tags, title)"
        }
      ],
      "group": "Bookmark",
      "description": "Update a bookmark"
    },
    {
      "id": "collection_create",
