      "fields": [
        {
          "id": "taskId",
          "label": "Task ID",
          "type": "text",
          "required": true
        },
        {
          "id": "project",
          "label": "Project Name or ID",
          "type": "text",
          "required": true,
          "description": "The destination project. Choose from the list, or specify an ID. (provide the ID)"
        },
        {
          "id": "section",
          "label": "Section Name or ID",
          "type": "select",
          "description": "Section to which you want move the task. Choose from the list, or specify an ID using an expression."
        },
        {
          "id": "options",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: section, parent)"
        }
      ],
      "group": "Task",
      "description": "[unverified path] Move a task"
    },
    {
      "id": "task_quick_add",
      "label": "Quick Add Task",
      "method": "POST",
      "path": "/task",
      "fields": [
        {
          "id": "text",
          "label": "Text",
          "type": "textarea",
          "required": true,
          "description": "Natural language text for quick adding task (e.g., \"Buy milk @Grocery #shopping tomorrow\"). It can include a due date in free form text, a project name starting with the \"#\" character (without spaces), a label starting with the \"@\" character, an assignee starting with the \"+\" character, a priority (e.g., p1), a deadline between \"{}\" (e.g. {in 3 days}), or a description starting from \"//\" until the end of the text."
        },
        {
          "id": "options",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: note, reminder, auto_reminder)"
        }
      ],
      "group": "Task",
      "description": "[unverified path] Quick add a task using natural language"
    },
    {
