      "id": "reminder_create",
      "label": "Create Reminder",
      "method": "POST",
      "path": "/tasks",
      "fields": [
        {
          "id": "itemId",
          "label": "Task ID",
          "type": "text",
          "required": true,
          "description": "The ID of the task to attach reminder to"
        },
        {
          "id": "dueDateType",
          "label": "Due Date Type",
          "type": "select",
          "required": true,
          "description": "How to specify when the reminder should trigger",
          "defaultValue": "natural_language",
          "options": [
            {
              "value": "natural_language",
              "label": "Natural Language"
            },
            {
              "value": "full_day",
              "label": "Full-Day Date"
            },
            {
              "value": "floating_time",
              "label": "Floating Date with Time"
            },
            {
              "value": "fixed_timezone",
              "label": "Fixed Timezone Date with Time"
            }
          ]
        },
        {
          "id": "natural_language_representation",
          "label": "Natural Language Representation",
          "type": "text",
          "required": true,
          "placeholder": "e.g., \"tomorrow 2pm\", \"monday 10:45am\"",
          "description": "Human-readable date and time"
        },
        {
          "id": "date",
          "label": "Date",
          "type": "text",
          "required": true,
          "placeholder": "YYYY-MM-DD",
          "description": "Full-day date in YYYY-MM-DD format"
        },
        {
          "id": "datetime",
          "label": "Date Time",
          "type": "text",
          "required": true,
          "placeholder": "2024-01-01T00:00:00Z",
          "description": "Floating date and time (no timezone) (ISO 8601 date-time)"
        },
        {
          "id": "timezone",
          "label": "Timezone",
          "type": "text",
          "required": true,
          "placeholder": "e.g., \"America/New_York\"",
          "description": "Timezone for the fixed timezone date"
        },
