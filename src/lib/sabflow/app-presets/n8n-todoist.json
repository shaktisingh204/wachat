{
  "id": "n8n-todoist",
  "name": "Todoist",
  "description": "Consume Todoist API",
  "category": "productivity",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "bearer",
    "credentialType": "todoist"
  },
  "baseUrl": "https://api.todoist.com/rest/v2",
  "endpoints": [
    {
      "id": "task_close",
      "label": "Close Task",
      "method": "POST",
      "path": "/tasks/{id}/close",
      "fields": [
        {
          "id": "taskId",
          "label": "Task ID",
          "type": "text",
          "required": true
        }
      ],
      "group": "Task",
      "description": "Close a task"
    },
    {
      "id": "task_create",
      "label": "Create Task",
      "method": "POST",
      "path": "/tasks",
      "fields": [
        {
          "id": "project",
          "label": "Project Name or ID",
          "type": "text",
          "required": true,
          "description": "The destination project. Choose from the list, or specify an ID. (provide the ID)"
        },
        {
          "id": "labels",
          "label": "Label Names",
          "type": "select",
          "description": "Optional labels that will be assigned to a created task. Choose from the list, or specify IDs using an expression. (multiple values: comma-separated)"
        },
        {
          "id": "content",
          "label": "Content",
          "type": "textarea",
          "required": true,
          "description": "Task content"
        },
        {
          "id": "options",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: description, dueDateTime, dueLang, dueString, parentId, priority, section, order, dueDate, assigneeId, duration, durationUnit, deadlineDate)"
        }
      ],
      "group": "Task",
      "description": "Create a new task"
    },
    {
      "id": "task_delete",
      "label": "Delete Task",
      "method": "DELETE",
      "path": "/tasks/{id}",
      "fields": [
        {
          "id": "taskId",
          "label": "Task ID",
          "type": "text",
          "required": true
        }
      ],
      "group": "Task",
      "description": "Delete a task"
    },
    {
      "id": "task_get",
