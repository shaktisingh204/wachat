      "id": "task_get_all",
      "label": "Get Many Task",
      "method": "GET",
      "path": "/task",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50
        },
        {
          "id": "filters",
          "label": "Filters",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: filter, ids, labelId, lang, parentId, projectId, sectionId)"
        }
      ],
