      "path": "/contacts/{contactId}/tasks/",
      "fields": [
        {
          "id": "contactId",
          "label": "Contact Email or ID",
          "type": "select",
          "required": true,
          "description": "Contact the task belongs to. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
