{
  "id": "n8n-high-level",
  "name": "HighLevel",
  "description": "Consume HighLevel API v2",
  "category": "crm",
  "iconName": "LuPackage",
  "version": 12,
  "lastVerified": "2026-06-12",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "credentialType": "high_level"
  },
  "baseUrl": "https://services.leadconnectorhq.com",
  "endpoints": [
    {
      "id": "contact_create",
      "label": "Create or Update Contact",
      "method": "POST",
      "path": "/contacts/upsert/",
      "fields": [
        {
          "id": "email",
          "label": "Email",
          "type": "text",
          "placeholder": "name@email.com",
          "description": "Email or Phone are required to create contact",
          "in": "body"
        },
        {
          "id": "phone",
          "label": "Phone",
          "type": "text",
          "placeholder": "+491234567890",
          "description": "Phone or Email are required to create contact. Phone number has to start with a valid country code leading with + sign.",
          "in": "body"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: address1, city, customFields, dnd, firstName, lastName, name, postalCode, source, state, notes, tags, timezone, website)"
        }
      ],
      "group": "Contact",
      "description": "Create or update a contact"
    },
    {
      "id": "contact_delete",
      "label": "Delete Contact",
      "method": "DELETE",
      "path": "/contacts/{contactId}/",
      "fields": [
        {
          "id": "contactId",
          "label": "Contact ID",
          "type": "text",
          "required": true,
          "in": "path"
        }
      ],
      "group": "Contact",
      "description": "Delete a contact"
    },
    {
      "id": "contact_get",
      "label": "Get Contact",
      "method": "GET",
      "path": "/contacts/{contactId}/",
      "fields": [
        {
          "id": "contactId",
          "label": "Contact ID",
          "type": "text",
          "required": true,
          "in": "path"
        }
      ],
      "group": "Contact",
      "description": "Get a contact"
    },
    {
      "id": "contact_get_all",
      "label": "Get Many Contact",
      "method": "GET",
      "path": "/contacts/",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50,
          "in": "query"
        },
        {
          "id": "filters",
          "label": "Filters",
          "type": "json",
          "placeholder": "Add Filter",
          "description": "(JSON object; supported keys: query)"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: order, sortBy)"
        }
      ],
      "group": "Contact",
      "description": "Get many contacts"
    },
    {
      "id": "contact_update",
      "label": "Update Contact",
      "method": "PUT",
      "path": "/contacts/{contactId}/",
      "fields": [
        {
          "id": "contactId",
          "label": "Contact ID",
          "type": "text",
          "required": true,
          "in": "path"
        },
        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: address1, city, customFields, dnd, email, firstName, lastName, name, phone, postalCode, state, tags, timezone, website)"
        }
      ],
      "group": "Contact",
      "description": "Update a contact"
    },
    {
      "id": "opportunity_create",
      "label": "Create Opportunity",
      "method": "POST",
      "path": "/opportunities/",
      "fields": [
        {
          "id": "pipelineId",
          "label": "Pipeline Name or ID",
          "type": "select",
          "description": "Choose from the list, or specify an ID using an expression",
          "in": "body"
        },
        {
          "id": "contactId",
          "label": "Contact Email or ID",
          "type": "select",
          "required": true,
          "description": "Choose from the list, or specify an ID using an expression",
          "in": "body"
        },
        {
          "id": "name",
          "label": "Name",
          "type": "text",
          "required": true,
          "in": "body"
        },
        {
          "id": "status",
          "label": "Status",
          "type": "select",
          "required": true,
          "defaultValue": "open",
          "options": [
            {
              "value": "open",
              "label": "Open"
            },
            {
              "value": "won",
              "label": "Won"
            },
            {
              "value": "lost",
              "label": "Lost"
            },
            {
              "value": "abandoned",
              "label": "Abandoned"
            }
          ],
          "in": "body"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: assignedTo, companyName, monetaryValue, tags, stageId)"
        }
      ],
      "group": "Opportunity",
      "description": "Create an opportunity"
    },
    {
      "id": "opportunity_delete",
      "label": "Delete Opportunity",
      "method": "DELETE",
      "path": "/opportunities/{opportunityId}",
      "fields": [
        {
          "id": "opportunityId",
          "label": "Opportunity ID",
          "type": "text",
          "required": true,
          "in": "path"
        }
      ],
      "group": "Opportunity",
      "description": "Delete an opportunity"
    },
    {
      "id": "opportunity_get",
      "label": "Get Opportunity",
      "method": "GET",
      "path": "/opportunities/{opportunityId}",
      "fields": [
        {
          "id": "opportunityId",
          "label": "Opportunity ID",
          "type": "text",
          "required": true,
          "in": "path"
        }
      ],
      "group": "Opportunity",
      "description": "Get an opportunity"
    },
    {
      "id": "opportunity_get_all",
      "label": "Get Many Opportunity",
      "method": "GET",
      "path": "/opportunities/search",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 20,
          "in": "query"
        },
        {
          "id": "filters",
          "label": "Filters",
          "type": "json",
          "placeholder": "Add Filter",
          "description": "(JSON object; supported keys: assignedTo, campaignId, endDate, pipelineId, stageId, startDate, status, query)"
        }
      ],
      "group": "Opportunity",
      "description": "Get many opportunities"
    },
    {
      "id": "opportunity_update",
      "label": "Update Opportunity",
      "method": "PUT",
      "path": "/opportunities/{opportunityId}",
      "fields": [
        {
          "id": "opportunityId",
          "label": "Opportunity ID",
          "type": "text",
          "required": true,
          "in": "path"
        },
        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: assignedTo, monetaryValue, name, pipelineId, stageId, status)"
        }
      ],
      "group": "Opportunity",
      "description": "Update an opportunity"
    },
    {
