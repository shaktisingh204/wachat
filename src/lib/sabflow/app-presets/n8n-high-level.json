      "label": "Create Task",
      "method": "POST",
      "path": "/contacts/{contactId}/tasks/",
      "fields": [
        {
          "id": "contactId",
          "label": "Contact Email or ID",
          "type": "select",
          "required": true,
          "description": "Contact the task belongs to. Choose from the list, or specify an ID using an expression.",
          "in": "path"
        },
        {
          "id": "title",
          "label": "Title",
          "type": "text",
          "required": true,
          "in": "body"
        },
        {
          "id": "dueDate",
          "label": "Due Date",
          "type": "text",
          "required": true,
          "placeholder": "2024-01-01T00:00:00Z",
          "description": "(ISO 8601 date-time)",
          "in": "body"
        },
        {
          "id": "completed",
          "label": "Completed",
          "type": "toggle",
          "required": true,
          "defaultValue": false,
          "in": "body"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: assignedTo, body)"
        }
      ],
      "group": "Task",
      "description": "Create a task"
