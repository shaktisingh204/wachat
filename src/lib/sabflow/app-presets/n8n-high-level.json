    {
      "id": "calendar_book_appointment",
      "label": "Book Appointment Calendar",
      "method": "POST",
      "path": "/calendars/events/appointments",
      "fields": [
        {
          "id": "calendarId",
          "label": "Calendar ID",
          "type": "text",
          "required": true,
          "in": "body"
        },
        {
          "id": "locationId",
          "label": "Location ID",
          "type": "text",
          "required": true,
          "in": "body"
        },
        {
          "id": "contactId",
          "label": "Contact ID",
          "type": "text",
          "required": true,
          "in": "body"
        },
        {
          "id": "startTime",
          "label": "Start Time",
          "type": "text",
          "required": true,
          "description": "Example: 2021-06-23T03:30:00+05:30",
          "in": "body"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: endTime, title, appointmentStatus, assignedUserId, address, ignoreDateRange, toNotify)"
        }
      ],
      "group": "Calendar",
      "description": "Book appointment in a calendar"
    },
    {
      "id": "calendar_get_free_slots",
      "label": "Get Free Slots Calendar",
      "method": "GET",
      "path": "/calendars/{calendarId}/free-slots",
      "fields": [
        {
          "id": "calendarId",
          "label": "Calendar ID",
          "type": "text",
          "required": true,
          "in": "path"
        },
        {
          "id": "startDate",
          "label": "Start Date",
          "type": "number",
          "required": true,
          "description": "The start date for fetching free calendar slots. Example: 1548898600000.",
          "in": "query"
        },
        {
          "id": "endDate",
          "label": "End Date",
          "type": "number",
          "required": true,
          "description": "The end date for fetching free calendar slots. Example: 1601490599999.",
          "in": "query"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: timezone, userId, userIds, enableLookBusy)"
