{
  "id": "n8n-aws-sqs",
  "name": "AWS SQS",
  "description": "Sends messages to AWS SQS",
  "category": "dev",
  "iconName": "LuPackage",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "draft",
  "auth": {
    "type": "none"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "default_send_message",
      "label": "Send Message",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "queue",
          "label": "Queue Name or ID",
          "type": "select",
          "in": "query",
          "required": true,
          "description": "Queue to send a message to. Choose from the list, or specify an ID using an <a href=\"https://docs.n8n.io/code/expressions/\">expression</a>.",
          "options": []
        },
        {
          "id": "queueType",
          "label": "Queue Type",
          "type": "select",
          "in": "query",
          "defaultValue": "standard",
          "options": [
            {
              "value": "fifo",
              "label": "FIFO"
            },
            {
              "value": "standard",
              "label": "Standard"
            }
          ]
        },
        {
          "id": "sendInputData",
          "label": "Send Input Data",
          "type": "toggle",
          "in": "query",
          "description": "Whether to send the data the node receives as JSON to SQS",
          "defaultValue": true
        },
        {
          "id": "message",
          "label": "Message",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "Message to send to the queue"
        },
        {
          "id": "messageGroupId",
          "label": "Message Group ID",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "Tag that specifies that a message belongs to a specific message group. Applies only to FIFO (first-in-first-out) queues."
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "in": "query",
          "placeholder": "Add option"
        }
      ]
    }
  ]
}
