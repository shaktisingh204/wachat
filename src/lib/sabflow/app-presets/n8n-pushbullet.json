{
  "id": "n8n-pushbullet",
  "name": "Pushbullet",
  "description": "Consume Pushbullet API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "credentialType": "oauth2"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "push_create",
      "label": "Create Push",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "type",
          "label": "Type",
          "type": "select",
          "in": "query",
          "required": true,
          "defaultValue": "note",
          "options": [
            {
              "value": "file",
              "label": "File"
            },
            {
              "value": "link",
              "label": "Link"
            },
            {
              "value": "note",
              "label": "Note"
            }
          ]
        },
        {
          "id": "title",
          "label": "Title",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "Title of the push"
        },
        {
          "id": "body",
          "label": "Body",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "Body of the push"
        },
        {
          "id": "url",
          "label": "URL",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "URL of the push"
        },
        {
          "id": "binaryPropertyName",
          "label": "Input Binary Field",
          "type": "text",
          "in": "query",
          "required": true,
          "defaultValue": "data"
        },
        {
          "id": "target",
          "label": "Target",
          "type": "select",
          "in": "query",
          "required": true,
          "description": "Define the medium that will be used to send the push",
          "defaultValue": "default",
          "options": [
            {
              "value": "channel_tag",
              "label": "Channel Tag"
            },
            {
              "value": "default",
              "label": "Default"
            },
            {
              "value": "device_iden",
              "label": "Device ID"
            },
            {
              "value": "email",
              "label": "Email"
            }
          ]
        },
        {
          "id": "value",
          "label": "Value",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "The value to be set depending on the target selected. For example, if the target selected is email then this field would take the email address of the person you are trying to send the push to."
        },
        {
          "id": "value",
          "label": "Value Name or ID",
          "type": "select",
          "in": "query",
          "required": true,
          "description": "Choose from the list, or specify an ID using an <a href=\"https://docs.n8n.io/code/expressions/\">expression</a>"
        }
      ]
    },
    {
      "id": "push_delete",
      "label": "Delete Push",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "pushId",
          "label": "Push ID",
          "type": "text",
          "in": "query",
          "required": true
        }
      ]
    },
    {
      "id": "push_get_all",
      "label": "Get Many Push",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "in": "query",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "in": "query",
          "description": "Max number of results to return",
          "defaultValue": 100
        },
        {
          "id": "filters",
          "label": "Filters",
          "type": "json",
          "in": "query",
          "placeholder": "Add Filter"
        }
      ]
    },
    {
      "id": "push_update",
      "label": "Update Push",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "pushId",
          "label": "Push ID",
          "type": "text",
          "in": "query",
          "required": true
        },
        {
          "id": "dismissed",
          "label": "Dismissed",
          "type": "toggle",
          "in": "query",
          "required": true,
          "description": "Whether to mark a push as having been dismissed by the user, will cause any notifications for the push to be hidden if possible",
          "defaultValue": false
        }
      ]
    }
  ]
}
