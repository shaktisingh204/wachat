{
  "id": "n8n-pushbullet",
  "name": "Pushbullet",
  "description": "Consume Pushbullet API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "credentialType": "oauth2"
  },
  "baseUrl": "https://api.pushbullet.com/v2",
  "endpoints": [
    {
      "id": "push_create",
      "label": "Create Push",
      "method": "POST",
      "path": "/upload-request",
      "fields": [
        {
          "id": "type",
          "label": "Type",
          "type": "select",
          "required": true,
          "defaultValue": "note",
          "options": [
            {
              "value": "file",
              "label": "File"
            },
            {
              "value": "link",
              "label": "Link"
            },
            {
              "value": "note",
              "label": "Note"
            }
          ]
        },
        {
          "id": "title",
          "label": "Title",
          "type": "text",
          "required": true,
          "description": "Title of the push"
        },
        {
          "id": "body",
          "label": "Body",
          "type": "text",
          "required": true,
          "description": "Body of the push"
        },
        {
          "id": "url",
          "label": "URL",
          "type": "text",
          "required": true,
          "description": "URL of the push"
        },
        {
          "id": "binaryPropertyName",
          "label": "Input Binary Field",
          "type": "text",
          "required": true,
          "defaultValue": "data"
        },
        {
          "id": "target",
          "label": "Target",
          "type": "select",
          "required": true,
          "description": "Define the medium that will be used to send the push",
          "defaultValue": "default",
          "options": [
            {
              "value": "channel_tag",
              "label": "Channel Tag"
            },
            {
              "value": "default",
              "label": "Default"
            },
            {
              "value": "device_iden",
              "label": "Device ID"
            },
            {
              "value": "email",
              "label": "Email"
            }
          ]
        },
        {
          "id": "value",
          "label": "Value",
          "type": "text",
          "required": true,
          "description": "The value to be set depending on the target selected. For example, if the target selected is email then this field would take the email address of the person you are trying to send the push to."
        }
      ],
      "group": "Push",
      "description": "Create a push"
    },
    {
      "id": "push_delete",
      "label": "Delete Push",
      "method": "DELETE",
      "path": "/pushes/{pushId}",
      "fields": [
        {
          "id": "pushId",
          "label": "Push ID",
          "type": "text",
          "required": true,
          "in": "path"
        }
      ],
      "group": "Push",
      "description": "Delete a push"
    },
    {
      "id": "push_get_all",
      "label": "Get Many Push",
      "method": "GET",
      "path": "/pushes",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 100
        },
        {
          "id": "filters",
          "label": "Filters",
          "type": "json",
          "placeholder": "Add Filter",
          "description": "(JSON object; supported keys: active, modified_after)"
        }
      ],
      "group": "Push",
      "description": "Get many pushes"
    },
    {
      "id": "push_update",
      "label": "Update Push",
      "method": "POST",
      "path": "/pushes/{pushId}",
      "fields": [
        {
          "id": "pushId",
          "label": "Push ID",
          "type": "text",
          "required": true,
          "in": "path"
        },
        {
          "id": "dismissed",
          "label": "Dismissed",
          "type": "toggle",
          "required": true,
          "description": "Whether to mark a push as having been dismissed by the user, will cause any notifications for the push to be hidden if possible",
          "defaultValue": false
        }
      ],
      "group": "Push",
      "description": "Update a push"
    }
  ]
}
