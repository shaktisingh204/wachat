{
  "id": "n8n-google-analytics",
  "name": "Google Analytics",
  "description": "Use the Google Analytics API",
  "category": "analytics",
  "iconName": "LuPackage",
  "version": 13,
  "lastVerified": "2026-06-12",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "provider": "google",
    "credentialType": "google_sheets",
    "fallback": {
      "type": "none"
    }
  },
  "baseUrl": "https://analyticsreporting.googleapis.com",
  "endpoints": [
    {
      "id": "user_activity_search",
      "label": "Search User Activity",
      "method": "POST",
      "path": "/v4/userActivity:search",
      "fields": [
        {
          "id": "viewId",
          "label": "View Name or ID",
          "type": "select",
          "required": true,
          "placeholder": "123456",
          "description": "The view from Google Analytics. Choose from the list, or specify an ID using an expression."
        },
        {
          "id": "userId",
          "label": "User ID",
          "type": "text",
          "required": true,
          "placeholder": "123456",
          "description": "ID of a user"
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 100
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: activityTypes)"
        }
      ],
      "group": "User Activity",
      "description": "Return user activity data"
    }
  ]
}
