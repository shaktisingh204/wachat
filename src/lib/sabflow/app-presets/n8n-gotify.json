{
  "id": "n8n-gotify",
  "name": "Gotify",
  "description": "Consume Gotify API",
  "category": "communication",
  "iconName": "LuPackage",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "message_create",
      "label": "Create Message",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "message",
          "label": "Message",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "The message to send, If using Markdown add the Content Type option"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "in": "query",
          "placeholder": "Add Field"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "in": "query",
          "placeholder": "Add option"
        }
      ]
    },
    {
      "id": "message_delete",
      "label": "Delete Message",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "messageId",
          "label": "Message ID",
          "type": "text",
          "in": "query",
          "required": true
        }
      ]
    },
    {
      "id": "message_get_all",
      "label": "Get Many Message",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "in": "query",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "in": "query",
          "description": "Max number of results to return",
          "defaultValue": 20
        }
      ]
    }
  ]
}
