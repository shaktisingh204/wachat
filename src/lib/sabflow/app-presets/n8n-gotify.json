{
  "id": "n8n-gotify",
  "name": "Gotify",
  "description": "Consume Gotify API",
  "category": "communication",
  "iconName": "LuPackage",
  "version": 4,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://{host}",
  "endpoints": [
    {
      "id": "message_create",
      "label": "Create Message",
      "method": "POST",
      "path": "/message",
      "fields": [
        {
          "id": "host",
          "label": "Host",
          "type": "text",
          "required": true,
          "in": "path",
          "description": "Host of your Gotify server, e.g. app.example.com (no https:// prefix)"
        },
        {
          "id": "message",
          "label": "Message",
          "type": "text",
          "required": true,
          "description": "The message to send, If using Markdown add the Content Type option"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: priority, title)"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: contentType)"
        }
      ],
      "group": "Message",
      "description": "Create a message"
    },
    {
      "id": "message_delete",
      "label": "Delete Message",
      "method": "DELETE",
      "path": "/message/{messageId}",
      "fields": [
        {
          "id": "host",
          "label": "Host",
          "type": "text",
          "required": true,
          "in": "path",
          "description": "Host of your Gotify server, e.g. app.example.com (no https:// prefix)"
        },
        {
          "id": "messageId",
          "label": "Message ID",
          "type": "text",
          "required": true,
          "in": "path"
        }
      ],
      "group": "Message",
      "description": "Delete a message"
    },
    {
      "id": "message_get_all",
      "label": "Get Many Message",
      "method": "GET",
      "path": "/message",
      "fields": [
        {
          "id": "host",
          "label": "Host",
          "type": "text",
          "required": true,
          "in": "path",
          "description": "Host of your Gotify server, e.g. app.example.com (no https:// prefix)"
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 20
        }
      ],
      "group": "Message",
      "description": "Get many messages"
    }
  ]
}
