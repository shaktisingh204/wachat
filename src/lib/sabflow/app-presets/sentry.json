{
  "id": "sentry",
  "name": "Sentry",
  "description": "Sentry error tracking and performance monitoring API.",
  "category": "Monitoring",
  "iconName": "LuActivity",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "bearer",
    "credentialType": "sentry"
  },
  "baseUrl": "https://sentry.io/api/0",
  "endpoints": [
    {
      "id": "list_organizations",
      "label": "List organizations",
      "method": "GET",
      "path": "/organizations/",
      "fields": [
        { "id": "cursor", "label": "Cursor", "type": "text", "in": "query" }
      ]
    },
    {
      "id": "list_projects",
      "label": "List organization projects",
      "method": "GET",
      "path": "/organizations/{organization_slug}/projects/",
      "fields": [
        { "id": "organization_slug", "label": "Organization slug", "type": "text", "required": true, "in": "path" },
        { "id": "cursor", "label": "Cursor", "type": "text", "in": "query" }
      ]
    },
    {
      "id": "get_project",
      "label": "Get project",
      "method": "GET",
      "path": "/projects/{organization_slug}/{project_slug}/",
      "fields": [
        { "id": "organization_slug", "label": "Organization slug", "type": "text", "required": true, "in": "path" },
        { "id": "project_slug", "label": "Project slug", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "list_issues",
      "label": "List issues",
      "method": "GET",
      "path": "/projects/{organization_slug}/{project_slug}/issues/",
      "fields": [
        { "id": "organization_slug", "label": "Organization slug", "type": "text", "required": true, "in": "path" },
        { "id": "project_slug", "label": "Project slug", "type": "text", "required": true, "in": "path" },
        { "id": "query", "label": "Search query", "type": "text", "in": "query" },
        { "id": "statsPeriod", "label": "Stats period", "type": "text", "in": "query" },
        { "id": "cursor", "label": "Cursor", "type": "text", "in": "query" }
      ]
    },
    {
      "id": "get_issue",
      "label": "Get issue",
      "method": "GET",
      "path": "/issues/{issue_id}/",
      "fields": [
        { "id": "issue_id", "label": "Issue ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "update_issue",
      "label": "Update issue",
      "method": "PUT",
      "path": "/issues/{issue_id}/",
      "fields": [
        { "id": "issue_id", "label": "Issue ID", "type": "text", "required": true, "in": "path" },
        { "id": "status", "label": "Status", "type": "select", "in": "body" },
        { "id": "assignedTo", "label": "Assigned to", "type": "text", "in": "body" },
        { "id": "isPublic", "label": "Is public", "type": "toggle", "in": "body" }
      ]
    },
    {
      "id": "list_events_for_issue",
      "label": "List events for issue",
      "method": "GET",
      "path": "/issues/{issue_id}/events/",
      "fields": [
        { "id": "issue_id", "label": "Issue ID", "type": "text", "required": true, "in": "path" },
        { "id": "cursor", "label": "Cursor", "type": "text", "in": "query" }
      ]
    },
    {
      "id": "list_releases",
      "label": "List releases",
      "method": "GET",
      "path": "/organizations/{organization_slug}/releases/",
      "fields": [
        { "id": "organization_slug", "label": "Organization slug", "type": "text", "required": true, "in": "path" },
        { "id": "query", "label": "Query", "type": "text", "in": "query" },
        { "id": "cursor", "label": "Cursor", "type": "text", "in": "query" }
      ]
    },
    {
      "id": "create_release",
      "label": "Create release",
      "method": "POST",
      "path": "/organizations/{organization_slug}/releases/",
      "fields": [
        { "id": "organization_slug", "label": "Organization slug", "type": "text", "required": true, "in": "path" },
        { "id": "version", "label": "Version", "type": "text", "required": true, "in": "body" },
        { "id": "projects", "label": "Projects (JSON array)", "type": "json", "required": true, "in": "body" },
        { "id": "ref", "label": "Ref", "type": "text", "in": "body" },
        { "id": "url", "label": "URL", "type": "text", "in": "body" },
        { "id": "commits", "label": "Commits (JSON)", "type": "json", "in": "body" }
      ]
    },
    {
      "id": "deploy_release",
      "label": "Deploy release",
      "method": "POST",
      "path": "/organizations/{organization_slug}/releases/{version}/deploys/",
      "fields": [
        { "id": "organization_slug", "label": "Organization slug", "type": "text", "required": true, "in": "path" },
        { "id": "version", "label": "Release version", "type": "text", "required": true, "in": "path" },
        { "id": "environment", "label": "Environment", "type": "text", "required": true, "in": "body" },
        { "id": "name", "label": "Name", "type": "text", "in": "body" },
        { "id": "url", "label": "URL", "type": "text", "in": "body" },
        { "id": "dateStarted", "label": "Date started", "type": "text", "in": "body" },
        { "id": "dateFinished", "label": "Date finished", "type": "text", "in": "body" }
      ]
    },
    {
      "id": "list_members",
      "label": "List members",
      "method": "GET",
      "path": "/organizations/{organization_slug}/members/",
      "fields": [
        { "id": "organization_slug", "label": "Organization slug", "type": "text", "required": true, "in": "path" },
        { "id": "cursor", "label": "Cursor", "type": "text", "in": "query" }
      ]
    },
    {
      "id": "list_teams",
      "label": "List teams",
      "method": "GET",
      "path": "/organizations/{organization_slug}/teams/",
      "fields": [
        { "id": "organization_slug", "label": "Organization slug", "type": "text", "required": true, "in": "path" },
        { "id": "cursor", "label": "Cursor", "type": "text", "in": "query" }
      ]
    }
  ]
}
