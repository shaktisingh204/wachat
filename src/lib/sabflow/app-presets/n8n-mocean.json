{
  "id": "n8n-mocean",
  "name": "Mocean",
  "description": "Send SMS and voice messages via Mocean",
  "category": "communication",
  "iconName": "LuPackage",
  "version": 12,
  "lastVerified": "2026-06-12",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://rest.moceanapi.com",
  "endpoints": [
    {
      "id": "sms_send",
      "label": "Send SMS",
      "method": "POST",
      "path": "/rest/2/sms",
      "fields": [
        {
          "id": "from",
          "label": "From",
          "type": "text",
          "required": true,
          "placeholder": "Sender Number",
          "description": "Number to which to send the message"
        },
        {
          "id": "to",
          "label": "To",
          "type": "text",
          "required": true,
          "placeholder": "Receipient number",
          "description": "Number from which to send the message"
        },
        {
          "id": "message",
          "label": "Message",
          "type": "text",
          "required": true,
          "description": "Message to send"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: dlrUrl)"
        }
      ],
      "group": "SMS",
      "description": "Send SMS/Voice message"
    },
    {
      "id": "voice_send",
      "label": "Send Voice",
      "method": "POST",
      "path": "/rest/2/voice/dial",
      "fields": [
        {
          "id": "from",
          "label": "From",
          "type": "text",
          "required": true,
          "placeholder": "Sender Number",
          "description": "Number to which to send the message"
        },
        {
          "id": "to",
          "label": "To",
          "type": "text",
          "required": true,
          "placeholder": "Receipient number",
          "description": "Number from which to send the message"
        },
        {
          "id": "language",
          "label": "Language",
          "type": "select",
          "defaultValue": "en-US",
          "options": [
            {
              "value": "cmn-CN",
              "label": "Chinese Mandarin (China)"
            },
            {
              "value": "en-GB",
              "label": "English (United Kingdom)"
            },
            {
              "value": "en-US",
              "label": "English (United States)"
            },
            {
              "value": "ja-JP",
              "label": "Japanese (Japan)"
            },
            {
              "value": "ko-KR",
              "label": "Korean (Korea)"
            }
          ]
        },
        {
          "id": "message",
          "label": "Message",
          "type": "text",
          "required": true,
          "description": "Message to send"
        }
      ],
      "group": "Voice",
      "description": "Send SMS/Voice message"
    }
  ]
}
