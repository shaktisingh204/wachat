{
  "id": "n8n-discourse",
  "name": "Discourse",
  "description": "Consume Discourse API",
  "category": "communication",
  "iconName": "LuPackage",
  "version": 4,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://{host}",
  "endpoints": [
    {
      "id": "category_create",
      "label": "Create Category",
      "method": "POST",
      "path": "/categories.json",
      "fields": [
        {
          "id": "host",
          "label": "Host",
          "type": "text",
          "required": true,
          "in": "path",
          "description": "Host of your Discourse server, e.g. app.example.com (no https:// prefix)"
        },
        {
          "id": "name",
          "label": "Name",
          "type": "text",
          "required": true,
          "description": "Name of the category"
        },
        {
          "id": "color",
          "label": "Color",
          "type": "text",
          "required": true,
          "description": "Color of the category",
          "defaultValue": "0000FF"
        },
        {
          "id": "textColor",
          "label": "Text Color",
          "type": "text",
          "required": true,
          "description": "Text color of the category",
          "defaultValue": "0000FF"
        }
      ],
      "group": "Category",
      "description": "Create a category"
    },
    {
      "id": "category_get_all",
      "label": "Get Many Category",
      "method": "GET",
      "path": "/categories.json",
      "fields": [
        {
          "id": "host",
          "label": "Host",
          "type": "text",
          "required": true,
          "in": "path",
          "description": "Host of your Discourse server, e.g. app.example.com (no https:// prefix)"
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50
        }
      ],
      "group": "Category",
      "description": "Get many categories"
    },
    {
      "id": "category_update",
      "label": "Update Category",
      "method": "PUT",
      "path": "/categories/{categoryId}.json",
      "fields": [
        {
          "id": "host",
          "label": "Host",
          "type": "text",
          "required": true,
          "in": "path",
          "description": "Host of your Discourse server, e.g. app.example.com (no https:// prefix)"
        },
        {
          "id": "categoryId",
          "label": "Category ID",
          "type": "text",
          "required": true,
          "description": "ID of the category",
          "in": "path"
