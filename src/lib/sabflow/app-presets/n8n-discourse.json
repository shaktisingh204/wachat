        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: color, textColor)"
        }
      ],
      "group": "Category",
      "description": "Update a category"
    },
