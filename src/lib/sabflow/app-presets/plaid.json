  "endpoints": [
    {
      "id": "link_token_create",
      "label": "Create link token",
      "method": "POST",
      "path": "/link/token/create",
      "fields": [
        { "id": "client_id", "label": "Client ID", "type": "text", "required": true, "in": "body" },
        { "id": "secret", "label": "Secret", "type": "password", "required": true, "in": "body" },
        { "id": "client_name", "label": "Client name", "type": "text", "required": true, "in": "body" },
        { "id": "user", "label": "User", "type": "json", "required": true, "in": "body" },
        { "id": "products", "label": "Products", "type": "json", "required": true, "in": "body" },
        { "id": "country_codes", "label": "Country codes", "type": "json", "required": true, "in": "body" },
        { "id": "language", "label": "Language", "type": "text", "defaultValue": "en", "in": "body" }
      ]
    },
    {
