{
  "id": "plaid",
  "name": "Plaid",
  "description": "Bank account linking & financial data.",
  "category": "Fintech",
  "iconName": "LuLandmark",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
