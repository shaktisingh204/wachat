{
  "id": "n8n-next-cloud",
  "name": "Nextcloud",
  "description": "Access data on Nextcloud",
  "category": "storage",
  "iconName": "LuPackage",
  "version": 3,
  "lastVerified": "2026-06-12",
  "status": "draft",
  "auth": {
    "type": "basic",
    "credentialType": "next_cloud",
    "baseUrlFromCredential": "baseUrl"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "file_delete",
      "label": "Delete File",
      "method": "DELETE",
      "path": "/{path}",
      "fields": [
        {
          "id": "path",
          "label": "Delete Path",
          "type": "text",
          "required": true,
          "placeholder": "/invoices/2019/invoice_1.pdf",
          "description": "The path to delete. Can be a single file or a whole folder. The path should start with \"/\".",
          "in": "path"
        }
      ],
      "group": "File",
      "description": "Delete a file"
    },
    {
      "id": "file_download",
      "label": "Download File",
      "method": "GET",
      "path": "/{path}",
      "fields": [
        {
          "id": "path",
          "label": "File Path",
          "type": "text",
          "required": true,
          "placeholder": "/invoices/2019/invoice_1.pdf",
          "description": "The file path of the file to download. Has to contain the full path. The path should start with \"/\".",
          "in": "path"
        },
        {
          "id": "binaryPropertyName",
          "label": "Put Output File in Field",
          "type": "text",
          "required": true,
          "defaultValue": "data"
        }
      ],
      "group": "File",
      "description": "Download a file"
    },
    {
      "id": "folder_delete",
      "label": "Delete Folder",
      "method": "DELETE",
      "path": "/{path}",
      "fields": [
        {
          "id": "path",
          "label": "Delete Path",
          "type": "text",
          "required": true,
          "placeholder": "/invoices/2019/invoice_1.pdf",
          "description": "The path to delete. Can be a single file or a whole folder. The path should start with \"/\".",
          "in": "path"
        }
      ],
      "group": "Folder",
      "description": "Delete a folder"
    },
    {
      "id": "folder_share",
      "label": "Share Folder",
      "method": "POST",
      "path": "/ocs/v2.php/apps/files_sharing/api/v1/shares",
      "fields": [
        {
          "id": "path",
          "label": "File Path",
          "type": "text",
          "required": true,
          "placeholder": "/invoices/2019/invoice_1.pdf",
          "description": "The file path of the file to share. Has to contain the full path. The path should start with \"/\"."
        },
        {
          "id": "shareType",
          "label": "Share Type",
          "type": "select",
          "description": "The share permissions to set",
          "defaultValue": 0,
          "options": [
            {
              "value": "7",
              "label": "Circle"
            },
            {
              "value": "4",
              "label": "Email"
            },
            {
              "value": "1",
              "label": "Group"
            },
            {
              "value": "3",
              "label": "Public Link"
            },
            {
              "value": "0",
              "label": "User"
            }
          ]
        },
        {
          "id": "circleId",
          "label": "Circle ID",
          "type": "text",
          "description": "The ID of the circle to share with"
        },
        {
          "id": "email",
          "label": "Email",
          "type": "text",
          "placeholder": "name@email.com",
          "description": "The Email address to share with"
        },
        {
          "id": "groupId",
          "label": "Group ID",
          "type": "text",
          "description": "The ID of the group to share with"
        },
        {
          "id": "user",
          "label": "User",
          "type": "text",
          "description": "The user to share with"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: password, permissions)"
        }
      ],
      "group": "Folder",
      "description": "Share a folder"
    },
    {
      "id": "user_create",
      "label": "Create User",
      "method": "POST",
      "path": "/ocs/v1.php/cloud/users",
      "fields": [
        {
          "id": "userId",
          "label": "Username",
          "type": "text",
          "required": true,
          "placeholder": "john",
          "description": "Username the user will have"
        },
        {
          "id": "email",
          "label": "Email",
          "type": "text",
          "required": true,
          "placeholder": "john@email.com",
          "description": "The email of the user to invite"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: displayName)"
        }
      ],
      "group": "User",
      "description": "Invite a user to a NextCloud organization"
    },
    {
      "id": "user_delete",
      "label": "Delete User",
      "method": "DELETE",
      "path": "/ocs/v1.php/cloud/users/{userid}",
      "fields": [
        {
          "id": "userId",
          "label": "Username",
          "type": "text",
          "required": true,
          "placeholder": "john",
          "description": "Username the user will have"
        }
      ],
      "group": "User",
      "description": "Delete a user"
    },
    {
      "id": "user_get",
      "label": "Get User",
      "method": "GET",
      "path": "/ocs/v1.php/cloud/users/{userid}",
      "fields": [
        {
          "id": "userId",
          "label": "Username",
          "type": "text",
          "required": true,
          "placeholder": "john",
          "description": "Username the user will have"
        }
      ],
      "group": "User",
      "description": "Retrieve information about a single user"
    },
    {
      "id": "user_get_all",
      "label": "Get Many User",
      "method": "GET",
      "path": "/ocs/v1.php/cloud/users",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: search, offset)"
        }
      ],
      "group": "User",
      "description": "Retrieve a list of users"
    },
    {
      "id": "user_update",
      "label": "Update User",
      "method": "PUT",
      "path": "/ocs/v1.php/cloud/users/{userid}",
      "fields": [
        {
          "id": "userId",
          "label": "Username",
          "type": "text",
          "required": true,
          "placeholder": "john",
          "description": "Username the user will have"
        },
        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: field, field.key, field.value)"
        }
      ],
      "group": "User",
      "description": "Edit attributes related to a user"
    }
  ]
}
