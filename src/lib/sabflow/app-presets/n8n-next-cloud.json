  "baseUrl": "",
  "endpoints": [
    {
      "id": "file_copy",
      "label": "Copy File",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "authentication",
          "label": "Authentication",
          "type": "select",
          "in": "query",
          "defaultValue": "accessToken",
          "options": [
            {
              "value": "accessToken",
              "label": "Access Token"
            },
            {
              "value": "oAuth2",
              "label": "OAuth2"
            }
          ]
        },
        {
          "id": "path",
          "label": "From Path",
          "type": "text",
          "in": "query",
          "required": true,
          "placeholder": "/invoices/original.txt",
          "description": "The path of file or folder to copy. The path should start with \"/\"."
        },
        {
          "id": "toPath",
          "label": "To Path",
          "type": "text",
          "in": "query",
          "required": true,
          "placeholder": "/invoices/copy.txt",
          "description": "The destination path of file or folder. The path should start with \"/\"."
        }
      ]
    },
    {
      "id": "file_delete",
