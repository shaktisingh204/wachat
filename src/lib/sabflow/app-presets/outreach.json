{
  "id": "outreach",
  "name": "Outreach",
  "description": "Sales engagement platform.",
  "category": "Sales",
  "iconName": "LuMail",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": { "type": "bearer", "credentialType": "outreach" },
  "baseUrl": "https://api.outreach.io/api/v2",
  "endpoints": [
    { "id": "list_prospects", "label": "List prospects", "method": "GET", "path": "/prospects", "fields": [{ "id": "page", "label": "Page", "type": "number", "in": "query" }, { "id": "per_page", "label": "Per page", "type": "number", "defaultValue": 25, "in": "query" }] },
    { "id": "get_prospect", "label": "Get prospect", "method": "GET", "path": "/prospects/{id}", "fields": [{ "id": "id", "label": "Prospect ID", "type": "text", "required": true, "in": "path" }] },
    { "id": "create_prospect", "label": "Create prospect", "method": "POST", "path": "/prospects", "fields": [{ "id": "data", "label": "Data envelope", "type": "json", "required": true, "in": "body", "defaultValue": { "type": "prospect", "attributes": { "firstName": "", "lastName": "", "emails": [] } } }] },
    { "id": "update_prospect", "label": "Update prospect", "method": "PATCH", "path": "/prospects/{id}", "fields": [{ "id": "id", "type": "text", "required": true, "in": "path" }, { "id": "data", "type": "json", "required": true, "in": "body" }] },
    { "id": "list_sequences", "label": "List sequences", "method": "GET", "path": "/sequences", "fields": [] },
    { "id": "add_prospect_to_sequence", "label": "Add prospect to sequence", "method": "POST", "path": "/sequenceStates", "fields": [{ "id": "data", "type": "json", "required": true, "in": "body", "defaultValue": { "type": "sequenceState", "attributes": { "sequenceId": 0, "prospectId": 0, "mailboxId": 0 } } }] },
    { "id": "list_accounts", "label": "List accounts", "method": "GET", "path": "/accounts", "fields": [] },
    { "id": "create_account", "label": "Create account", "method": "POST", "path": "/accounts", "fields": [{ "id": "data", "type": "json", "required": true, "in": "body", "defaultValue": { "type": "account", "attributes": { "name": "", "domain": "" } } }] },
    { "id": "list_users", "label": "List users", "method": "GET", "path": "/users", "fields": [] }
  ]
}
