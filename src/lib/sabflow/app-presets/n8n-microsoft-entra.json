          "id": "user",
          "label": "User to Delete",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        }
      ],
      "group": "User",
      "description": "[unverified path] Delete a user"
    },
    {
      "id": "user_get",
      "label": "Get User",
      "method": "GET",
      "path": "/users/{{ {user} }}",
      "fields": [
        {
          "id": "user",
          "label": "User to Get",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "output",
          "label": "Output",
          "type": "select",
          "defaultValue": "simple",
          "options": [
            {
              "value": "simple",
              "label": "Simplified"
            },
            {
              "value": "raw",
              "label": "Raw"
            },
            {
              "value": "fields",
              "label": "Selected Fields"
            }
          ]
        },
        {
          "id": "fields",
          "label": "Fields",
          "type": "select",
          "description": "The fields to add to the output (multiple values: comma-separated)",
          "in": "query"
        }
      ],
      "group": "User",
      "description": "[unverified path] Retrieve data for a specific user"
    },
    {
      "id": "user_get_all",
      "label": "Get Many User",
      "method": "GET",
      "path": "/users",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50,
          "in": "query"
        },
        {
          "id": "filter",
          "label": "Filter",
          "type": "text",
          "placeholder": "e.g. startswith(displayName, 'a')",
          "description": "Query parameter to filter results by",
          "in": "query"
        },
        {
          "id": "output",
          "label": "Output",
          "type": "select",
          "defaultValue": "simple",
          "options": [
            {
              "value": "simple",
              "label": "Simplified"
            },
            {
              "value": "raw",
              "label": "Raw"
            },
            {
              "value": "fields",
              "label": "Selected Fields"
            }
          ]
        },
        {
          "id": "fields",
          "label": "Fields",
          "type": "select",
          "description": "The fields to add to the output (multiple values: comma-separated)",
          "in": "query"
        }
      ],
      "group": "User",
      "description": "Retrieve a list of users"
    },
    {
      "id": "user_remove_group",
      "label": "Remove from Group User",
      "method": "DELETE",
      "path": "/groups/{{ {group} }}/members/{{ {user} }}/$ref",
      "fields": [
        {
          "id": "group",
          "label": "Group",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "user",
          "label": "User to Remove",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        }
      ],
      "group": "User",
      "description": "[unverified path] Remove user from group"
    },
    {
      "id": "user_update",
      "label": "Update User",
      "method": "PATCH",
      "path": "/users/{{ {user} }}",
      "fields": [
        {
          "id": "user",
          "label": "User to Update",
          "type": "text",
          "required": true,
          "description": "(provide the ID)",
          "in": "path"
        },
        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: aboutMe, accountEnabled, ageGroup, birthday, businessPhones, city, companyName, consentProvidedForMinor, country, department, displayName, employeeId, employeeType, givenName, employeeHireDate, employeeLeaveDateTime, employeeOrgData, forceChangePassword, interests, jobTitle, surname, mail, mailNickname, mobilePhone, mySite, officeLocation, onPremisesImmutableId, otherMails, password, passwordPolicies)"
        }
      ],
      "group": "User",
