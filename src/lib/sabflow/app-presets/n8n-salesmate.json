    {
      "id": "deal_create",
      "label": "Create Deal",
      "method": "POST",
      "path": "/v1/deals",
      "fields": [
        {
          "id": "title",
          "label": "Title",
          "type": "text",
          "required": true
        },
        {
          "id": "owner",
          "label": "Owner Name or ID",
          "type": "select",
          "required": true,
          "description": "Choose from the list, or specify an ID using an expression"
        },
        {
          "id": "primaryContact",
          "label": "Primary Contact Name or ID",
          "type": "select",
          "required": true,
          "description": "Primary contact for the deal. Choose from the list, or specify an ID using an expression."
        },
        {
          "id": "pipeline",
          "label": "Pipeline",
          "type": "select",
          "required": true,
          "options": [
            {
              "value": "Sales",
              "label": "Sales"
            }
          ]
        },
        {
          "id": "status",
          "label": "Status",
          "type": "select",
          "required": true,
          "defaultValue": "Open",
          "options": [
            {
              "value": "Open",
              "label": "Open"
            },
            {
              "value": "Close",
              "label": "Close"
            },
            {
              "value": "Lost",
              "label": "Lost"
            }
          ]
        },
        {
          "id": "stage",
          "label": "Stage",
          "type": "select",
          "required": true,
          "options": [
            {
              "value": "New (Untouched)",
              "label": "New (Untouched)"
            },
            {
              "value": "Contacted",
              "label": "Contacted"
            },
            {
              "value": "Qualified",
              "label": "Qualified"
            },
            {
              "value": "In Negotiation",
              "label": "In Negotiation"
            },
            {
              "value": "Proposal Presented",
              "label": "Proposal Presented"
            }
          ]
        },
        {
          "id": "currency",
          "label": "Currency",
          "type": "text",
          "required": true
        },
        {
          "id": "rawData",
          "label": "RAW Data",
          "type": "toggle",
          "description": "Whether the data should include the fields details",
          "defaultValue": false
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: description, tags, primaryCompany, source, estimatedCloseDate, dealValue, priority)"
        }
      ],
      "group": "Deal",
      "description": "Create a deal"
    },
