{
  "id": "n8n-salesmate",
  "name": "Salesmate",
  "description": "Consume Salesmate API",
  "category": "crm",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://apis.salesmate.io",
  "endpoints": [
    {
      "id": "company_create",
      "label": "Create Company",
      "method": "POST",
      "path": "/v1/companies",
      "fields": [
        {
          "id": "name",
          "label": "Name",
          "type": "text",
          "required": true
        },
        {
          "id": "owner",
          "label": "Owner Name or ID",
          "type": "select",
          "required": true,
          "description": "Choose from the list, or specify an ID using an expression"
        },
        {
          "id": "rawData",
          "label": "RAW Data",
          "type": "toggle",
          "description": "Whether the data should include the fields details",
          "defaultValue": false
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: website, phone, otherPhone, facebookHandle, googlePlusHandle, linkedInHandle, skypeId, twitterHandle, currency, billingAddressLine1, billingAddressLine2, billingCity, billingZipCode, billingState, description, tags)"
        }
      ],
      "group": "Company",
      "description": "Create a company"
    },
    {
      "id": "company_delete",
      "label": "Delete Company",
      "method": "DELETE",
      "path": "/v1/companies/{companyId}",
      "fields": [
        {
          "id": "id",
          "label": "Company ID",
          "type": "text",
          "required": true,
          "description": "If more than one company add them separated by ,"
        }
      ],
      "group": "Company",
      "description": "Delete a company"
    },
    {
      "id": "company_get",
      "label": "Get Company",
      "method": "GET",
      "path": "/v1/companies/{companyId}",
      "fields": [
        {
          "id": "id",
          "label": "Company ID",
          "type": "text",
          "required": true
        },
        {
          "id": "rawData",
          "label": "RAW Data",
          "type": "toggle",
          "description": "Whether the data should include the fields details",
          "defaultValue": false
        }
      ],
      "group": "Company",
      "description": "Get a company"
    },
    {
      "id": "company_get_all",
      "label": "Get Many Company",
      "method": "POST",
      "path": "/v2/companies/search",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 10
        },
        {
          "id": "jsonParameters",
          "label": "JSON Parameters",
          "type": "toggle",
          "defaultValue": false
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: fields, sortBy, sortOrder)"
        },
        {
          "id": "filtersJson",
          "label": "Filters",
          "type": "json"
        },
        {
          "id": "filters",
          "label": "Filters",
          "type": "json",
          "placeholder": "Add filter",
          "description": "(JSON object; supported keys: filtersUi, filtersUi.operator, filtersUi.conditions)"
        }
      ],
      "group": "Company",
      "description": "Get many companies"
    },
    {
      "id": "company_update",
      "label": "Update Company",
      "method": "PUT",
      "path": "/v1/companies/{companyId}",
      "fields": [
        {
          "id": "id",
          "label": "Company ID",
