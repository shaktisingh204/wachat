  },
  "baseUrl": "https://{host}",
  "endpoints": [
    {
      "id": "customer_create",
      "label": "Create Customer",
      "method": "POST",
      "path": "/rest/V1/customers",
      "fields": [
        {
          "id": "host",
          "label": "Host",
          "type": "text",
          "required": true,
          "in": "path",
          "description": "Host of your Magento 2 server, e.g. app.example.com (no https:// prefix)"
        },
        {
          "id": "email",
          "label": "Email",
          "type": "text",
          "required": true,
          "placeholder": "name@email.com",
          "description": "Email address of the user to create"
        },
        {
          "id": "firstname",
          "label": "First Name",
          "type": "text",
          "required": true,
          "description": "First name of the user to create"
        },
        {
          "id": "lastname",
          "label": "Last Name",
          "type": "text",
          "required": true,
          "description": "Last name of the user to create"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: addresses, amazon_id, confirmation, customAttributes, dob, default_billing, default_shipping, gender, group_id, is_subscribed, middlename, password, prefix, store_id, suffix, vertex_customer_code, vertex_customer_country, website_id)"
        }
      ],
      "group": "Customer",
      "description": "Create a new customer"
    },
    {
      "id": "customer_delete",
      "label": "Delete Customer",
