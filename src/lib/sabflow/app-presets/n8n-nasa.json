{
  "id": "n8n-nasa",
  "name": "NASA",
  "description": "Retrieve data from the NASA API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://api.nasa.gov",
  "endpoints": [
    {
      "id": "astronomy_picture_of_the_day_get",
      "label": "Get Astronomy Picture of the Day",
      "method": "GET",
      "path": "/planetary/apod",
      "fields": [
        {
          "id": "download",
          "label": "Download Image",
          "type": "toggle",
          "description": "By default just the URL of the image is returned. When set to true the image will be downloaded.",
          "defaultValue": true
        },
        {
          "id": "binaryPropertyName",
          "label": "Put Output File in Field",
          "type": "text",
          "required": true,
          "defaultValue": "data"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add field",
          "description": "(JSON object; supported keys: date)"
        }
      ],
      "group": "Astronomy Picture of the Day",
      "description": "Get the Astronomy Picture of the Day"
    },
    {
      "id": "asteroid_neo_feed_get",
      "label": "Get Asteroid Neo-Feed",
      "method": "GET",
      "path": "/neo/rest/v1/feed",
      "fields": [
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add field",
          "description": "(JSON object; supported keys: startDate, endDate)"
        }
      ],
      "group": "Asteroid Neo-Feed",
      "description": "Retrieve a list of asteroids based on their closest approach date to Earth"
    },
    {
      "id": "asteroid_neo_lookup_get",
      "label": "Get Asteroid Neo-Lookup",
      "method": "GET",
      "path": "/neo/rest/v1/neo/{asteroidId}",
      "fields": [
        {
          "id": "asteroidId",
          "label": "Asteroid ID",
          "type": "text",
          "required": true,
          "placeholder": "3542519",
          "description": "The ID of the asteroid to be returned",
          "in": "path"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: includeCloseApproachData)"
        }
      ],
      "group": "Asteroid Neo-Lookup",
      "description": "Look up an asteroid based on its NASA SPK-ID"
    },
    {
      "id": "asteroid_neo_browse_get_all",
      "label": "Get Many Asteroid Neo-Browse",
      "method": "GET",
      "path": "/neo/rest/v1/neo/browse",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 20
        }
      ],
      "group": "Asteroid Neo-Browse",
      "description": "Browse the overall asteroid dataset"
    },
    {
