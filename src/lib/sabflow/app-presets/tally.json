{
  "id": "tally",
  "name": "Tally",
  "description": "Tally Forms API for managing forms, submissions, and webhooks.",
  "category": "Forms",
  "iconName": "LuClipboardList",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "bearer",
    "credentialType": "tally"
  },
  "baseUrl": "https://api.tally.so",
  "endpoints": [
    {
      "id": "list_forms",
      "label": "List forms",
      "method": "GET",
      "path": "/forms",
      "fields": [
        { "id": "page", "label": "Page", "type": "number", "in": "query" },
        { "id": "limit", "label": "Limit", "type": "number", "defaultValue": 50, "in": "query" }
      ]
    },
    {
      "id": "get_form",
      "label": "Get form",
      "method": "GET",
      "path": "/forms/{formId}",
      "fields": [
        { "id": "formId", "label": "Form ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "list_submissions",
      "label": "List submissions",
      "method": "GET",
      "path": "/forms/{formId}/submissions",
      "fields": [
        { "id": "formId", "label": "Form ID", "type": "text", "required": true, "in": "path" },
        { "id": "page", "label": "Page", "type": "number", "in": "query" },
        { "id": "limit", "label": "Limit", "type": "number", "defaultValue": 50, "in": "query" }
      ]
    },
    {
      "id": "get_submission",
      "label": "Get submission",
      "method": "GET",
      "path": "/forms/{formId}/submissions/{submissionId}",
      "fields": [
        { "id": "formId", "label": "Form ID", "type": "text", "required": true, "in": "path" },
        { "id": "submissionId", "label": "Submission ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "list_workspaces",
      "label": "List workspaces",
      "method": "GET",
      "path": "/workspaces",
      "fields": [
        { "id": "page", "label": "Page", "type": "number", "in": "query" },
        { "id": "limit", "label": "Limit", "type": "number", "defaultValue": 50, "in": "query" }
      ]
    },
    {
      "id": "create_webhook",
      "label": "Create webhook",
      "method": "POST",
      "path": "/webhooks",
      "fields": [
        { "id": "formId", "label": "Form ID", "type": "text", "required": true, "in": "body" },
        { "id": "eventType", "label": "Event type", "type": "text", "required": true, "defaultValue": "FORM_RESPONSE", "in": "body" },
        { "id": "url", "label": "Webhook URL", "type": "text", "required": true, "in": "body" },
        { "id": "signingSecret", "label": "Signing secret", "type": "password", "in": "body" }
      ]
    },
    {
      "id": "delete_webhook",
      "label": "Delete webhook",
      "method": "DELETE",
      "path": "/webhooks/{id}",
      "fields": [
        { "id": "id", "label": "Webhook ID", "type": "text", "required": true, "in": "path" }
      ]
    }
  ]
}
