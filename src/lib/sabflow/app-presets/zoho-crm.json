{
  "id": "zoho-crm",
  "name": "Zoho CRM",
  "description": "Zoho CRM v6 API — records, search, lead conversion, module/field metadata, and attachments.",
  "category": "CRM",
  "iconName": "LuUsers",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "header",
    "header": "Authorization",
    "scheme": "Zoho-oauthtoken",
    "credentialType": "zoho_crm"
  },
  "baseUrl": "https://www.zohoapis.com/crm/v6",
  "endpoints": [
    {
      "id": "list_records",
      "label": "List records",
      "method": "GET",
      "path": "/{module}",
      "fields": [
        { "id": "module", "label": "Module", "type": "text", "required": true, "in": "path" },
        { "id": "fields", "label": "Fields (comma-sep)", "type": "text", "in": "query" },
        { "id": "page", "label": "Page", "type": "number", "defaultValue": 1, "in": "query" },
        { "id": "per_page", "label": "Per page", "type": "number", "defaultValue": 200, "in": "query" }
      ]
    },
    {
      "id": "get_record",
      "label": "Get record",
      "method": "GET",
      "path": "/{module}/{record_id}",
      "fields": [
        { "id": "module", "label": "Module", "type": "text", "required": true, "in": "path" },
        { "id": "record_id", "label": "Record ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "create_records",
      "label": "Create records",
      "method": "POST",
      "path": "/{module}",
      "fields": [
        { "id": "module", "label": "Module", "type": "text", "required": true, "in": "path" },
        { "id": "data", "label": "Data (JSON array)", "type": "json", "required": true, "in": "body" },
        { "id": "trigger", "label": "Trigger (JSON array)", "type": "json", "in": "body" }
      ]
    },
    {
      "id": "update_records",
      "label": "Update records",
      "method": "PUT",
      "path": "/{module}",
      "fields": [
        { "id": "module", "label": "Module", "type": "text", "required": true, "in": "path" },
        { "id": "data", "label": "Data (JSON array)", "type": "json", "required": true, "in": "body" },
        { "id": "trigger", "label": "Trigger (JSON array)", "type": "json", "in": "body" }
      ]
    },
    {
      "id": "delete_record",
      "label": "Delete record",
      "method": "DELETE",
      "path": "/{module}/{record_id}",
      "fields": [
        { "id": "module", "label": "Module", "type": "text", "required": true, "in": "path" },
        { "id": "record_id", "label": "Record ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "search_records",
      "label": "Search records",
      "method": "GET",
      "path": "/{module}/search",
      "fields": [
        { "id": "module", "label": "Module", "type": "text", "required": true, "in": "path" },
        { "id": "criteria", "label": "Criteria", "type": "text", "in": "query" },
        { "id": "email", "label": "Email", "type": "text", "in": "query" },
        { "id": "phone", "label": "Phone", "type": "text", "in": "query" },
        { "id": "word", "label": "Word", "type": "text", "in": "query" }
      ]
    },
    {
      "id": "convert_lead",
      "label": "Convert lead",
      "method": "POST",
      "path": "/Leads/{lead_id}/actions/convert",
      "fields": [
        { "id": "lead_id", "label": "Lead ID", "type": "text", "required": true, "in": "path" },
        { "id": "data", "label": "Data (JSON array)", "type": "json", "required": true, "in": "body" }
      ]
    },
    {
      "id": "list_modules",
      "label": "List modules",
      "method": "GET",
      "path": "/settings/modules",
      "fields": []
    },
    {
      "id": "list_fields",
      "label": "List fields",
      "method": "GET",
      "path": "/settings/fields",
      "fields": [
        { "id": "module", "label": "Module", "type": "text", "required": true, "in": "query" }
      ]
    },
    {
      "id": "upload_attachment",
      "label": "Upload attachment",
      "method": "POST",
      "path": "/{module}/{record_id}/Attachments",
      "fields": [
        { "id": "module", "label": "Module", "type": "text", "required": true, "in": "path" },
        { "id": "record_id", "label": "Record ID", "type": "text", "required": true, "in": "path" },
        { "id": "file_url", "label": "File URL", "type": "text", "required": true, "in": "body" }
      ]
    }
  ]
}
