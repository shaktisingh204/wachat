      "id": "activity_create",
      "label": "Create Activity",
      "method": "POST",
      "path": "/activities",
      "fields": [
        {
          "id": "activityTypeId",
          "label": "Activity Type Name or ID",
          "type": "select",
          "required": true,
          "description": "Choose from the list, or specify an ID using an expression"
        },
        {
          "id": "contacts",
          "label": "Contacts",
          "type": "text",
          "required": true,
          "description": "Comma-separated list of IDs of the contacts to associate the activity with"
        },
        {
          "id": "happenedAt",
          "label": "Happened At",
          "type": "text",
          "required": true,
          "placeholder": "2024-01-01T00:00:00Z",
          "description": "Date when the activity happened (ISO 8601 date-time)"
        },
        {
          "id": "summary",
          "label": "Summary",
          "type": "text",
          "required": true,
          "description": "Brief description of the activity - max 255 characters"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: description)"
        }
      ],
      "group": "Activity",
      "description": "Create an activity"
    },
    {
