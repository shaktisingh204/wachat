    },
    {
      "id": "customer_get",
      "label": "Get Customer",
      "method": "GET",
      "path": "/customers/{customerId}",
      "fields": [
        {
          "id": "customerId",
          "label": "Customer ID",
          "type": "text",
          "required": true,
          "description": "ID of the customer to retrieve",
          "in": "path"
        }
      ],
      "group": "Customer",
