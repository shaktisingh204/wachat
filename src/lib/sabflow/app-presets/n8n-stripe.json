{
  "id": "n8n-stripe",
  "name": "Stripe",
  "description": "Consume the Stripe API",
  "category": "finance",
  "iconName": "LuPackage",
  "version": 14,
  "lastVerified": "2026-06-12",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "provider": "stripe",
    "credentialType": "stripe",
    "fallback": {
      "type": "header",
      "credentialType": "http_header_auth"
    }
  },
  "baseUrl": "https://api.stripe.com/v1",
  "endpoints": [
    {
      "id": "balance_get",
      "label": "Get Balance",
      "method": "GET",
      "path": "/balance",
      "fields": [],
      "group": "Balance",
      "description": "Get a balance"
    },
    {
      "id": "customer_card_add",
      "label": "Add Customer Card",
      "method": "POST",
      "path": "/customers/{customerId}/sources",
      "fields": [
        {
          "id": "customerId",
          "label": "Customer ID",
          "type": "text",
          "required": true,
          "description": "ID of the customer to be associated with this card",
          "in": "path"
        },
        {
          "id": "token",
          "label": "Card Token",
          "type": "password",
          "required": true,
          "placeholder": "tok_1IMfKdJhRTnqS5TKQVG1LI9o",
          "description": "Token representing sensitive card information"
        }
      ],
      "group": "Customer Card",
      "description": "Add a customer card"
    },
    {
      "id": "customer_card_get",
      "label": "Get Customer Card",
      "method": "GET",
      "path": "/customers/{customerId}/sources/{sourceId}",
      "fields": [
        {
          "id": "customerId",
          "label": "Customer ID",
          "type": "text",
          "required": true,
          "description": "ID of the customer whose card to retrieve",
          "in": "path"
        },
        {
          "id": "sourceId",
          "label": "Source ID",
          "type": "text",
          "required": true,
          "description": "ID of the source to retrieve",
          "in": "path"
        }
      ],
      "group": "Customer Card",
      "description": "Get a customer card"
    },
    {
      "id": "customer_card_remove",
      "label": "Remove Customer Card",
      "method": "DELETE",
      "path": "/customers/{customerId}/sources/{cardId}",
      "fields": [
        {
          "id": "customerId",
          "label": "Customer ID",
          "type": "text",
          "required": true,
          "description": "ID of the customer whose card to remove",
          "in": "path"
        },
        {
          "id": "cardId",
          "label": "Card ID",
          "type": "text",
          "required": true,
          "description": "ID of the card to remove",
          "in": "path"
        }
      ],
      "group": "Customer Card",
      "description": "Remove a customer card"
    },
    {
      "id": "charge_create",
      "label": "Create Charge",
      "method": "POST",
      "path": "/charges",
      "fields": [
        {
          "id": "customerId",
          "label": "Customer ID",
          "type": "text",
          "required": true,
          "description": "ID of the customer to be associated with this charge"
        },
        {
          "id": "amount",
          "label": "Amount",
          "type": "number",
          "required": true,
          "description": "Amount in cents to be collected for this charge, e.g. enter 100 for $1.00",
          "defaultValue": 0
        },
        {
          "id": "currency",
          "label": "Currency Name or ID",
          "type": "select",
          "required": true,
          "description": "Three-letter ISO currency code, e.g. USD or EUR. It must be a Stripe-supported currency. Choose from the list, or specify an ID using an expression."
        },
        {
          "id": "source",
          "label": "Source ID",
          "type": "text",
          "required": true,
          "description": "ID of the customer's payment source to be charged"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: description, metadata, receipt_email, shipping)"
        }
      ],
      "group": "Charge",
      "description": "Create a charge"
    },
    {
      "id": "charge_get",
      "label": "Get Charge",
      "method": "GET",
      "path": "/charges/{chargeId}",
      "fields": [
        {
          "id": "chargeId",
          "label": "Charge ID",
          "type": "text",
          "required": true,
          "description": "ID of the charge to retrieve",
          "in": "path"
        }
      ],
      "group": "Charge",
      "description": "Get a charge"
    },
    {
      "id": "charge_get_all",
      "label": "Get Many Charge",
      "method": "GET",
      "path": "/charges",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50
        }
      ],
      "group": "Charge",
      "description": "Get many charges"
    },
    {
      "id": "charge_update",
      "label": "Update Charge",
      "method": "POST",
      "path": "/charges/{chargeId}",
      "fields": [
        {
          "id": "chargeId",
          "label": "Charge ID",
          "type": "text",
          "required": true,
          "description": "ID of the charge to update",
          "in": "path"
        },
        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: description, metadata, receipt_email, shipping)"
        }
      ],
      "group": "Charge",
      "description": "Update a charge"
    },
    {
      "id": "coupon_create",
      "label": "Create Coupon",
      "method": "POST",
      "path": "/coupons",
      "fields": [
        {
          "id": "duration",
          "label": "Apply",
          "type": "select",
          "required": true,
          "description": "How long the discount will be in effect",
          "defaultValue": "once",
          "options": [
            {
              "value": "forever",
              "label": "Forever"
            },
            {
              "value": "once",
              "label": "Once"
            }
          ]
        },
        {
          "id": "type",
          "label": "Discount Type",
          "type": "select",
          "required": true,
          "description": "Whether the coupon discount is a percentage or a fixed amount",
          "defaultValue": "percent",
          "options": [
            {
              "value": "fixedAmount",
              "label": "Fixed Amount (in Cents)"
            },
            {
              "value": "percent",
              "label": "Percent"
            }
          ]
        },
        {
          "id": "amountOff",
          "label": "Amount Off",
          "type": "number",
          "required": true,
          "description": "Amount in cents to subtract from an invoice total, e.g. enter 100 for $1.00",
          "defaultValue": 0
        },
        {
          "id": "currency",
          "label": "Currency Name or ID",
          "type": "select",
          "required": true,
          "description": "Three-letter ISO currency code, e.g. USD or EUR. It must be a Stripe-supported currency. Choose from the list, or specify an ID using an expression."
        },
        {
          "id": "percentOff",
          "label": "Percent Off",
          "type": "number",
          "required": true,
          "description": "Percentage to apply with the coupon",
          "defaultValue": 1
        }
      ],
      "group": "Coupon",
      "description": "Create a coupon"
    },
    {
      "id": "coupon_get_all",
      "label": "Get Many Coupon",
      "method": "GET",
      "path": "/coupons",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50
        }
      ],
      "group": "Coupon",
      "description": "Get many coupons"
    },
    {
