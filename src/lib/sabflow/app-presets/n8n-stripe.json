    {
      "id": "source_get",
      "label": "Get Source",
      "method": "GET",
      "path": "/sources/{sourceId}",
      "fields": [
        {
          "id": "sourceId",
          "label": "Source ID",
          "type": "text",
          "required": true,
          "description": "ID of the source to retrieve",
          "in": "path"
        }
      ],
      "group": "Source",
