    {
      "id": "token_create",
      "label": "Create Token",
      "method": "POST",
      "path": "/tokens",
      "fields": [
        {
          "id": "type",
          "label": "Type",
          "type": "select",
          "required": true,
          "description": "Type of token to create",
          "defaultValue": "cardToken",
          "options": [
            {
              "value": "cardToken",
              "label": "Card Token"
            }
          ]
        },
        {
          "id": "number",
          "label": "Card Number",
          "type": "text",
          "placeholder": "4242424242424242"
        },
        {
          "id": "cvc",
          "label": "CVC",
          "type": "text",
          "placeholder": "314",
          "description": "Security code printed on the back of the card"
        },
        {
          "id": "expirationMonth",
          "label": "Expiration Month",
          "type": "text",
          "placeholder": "10",
          "description": "Number of the month when the card will expire"
        },
        {
          "id": "expirationYear",
          "label": "Expiration Year",
          "type": "text",
          "placeholder": "2022",
          "description": "Year when the card will expire"
