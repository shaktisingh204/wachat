      "fields": [
        {
          "id": "name",
          "label": "Name",
          "type": "text",
          "required": true,
          "description": "Full name or business name of the customer to create"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: address, description, email, metadata, phone, shipping)"
        }
      ],
      "group": "Customer",
      "description": "Create a customer"
    },
    {
      "id": "customer_delete",
