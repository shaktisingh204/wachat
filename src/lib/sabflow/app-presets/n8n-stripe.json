    },
    {
      "id": "customer_get_all",
      "label": "Get Many Customer",
      "method": "GET",
      "path": "/customers",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50
        },
        {
          "id": "filters",
          "label": "Filters",
          "type": "json",
          "placeholder": "Add Filter",
          "description": "(JSON object; supported keys: email)"
        }
      ],
      "group": "Customer",
      "description": "Get many customers"
    },
    {
      "id": "customer_update",
      "label": "Update Customer",
      "method": "POST",
      "path": "/customers/{customerId}",
      "fields": [
        {
          "id": "customerId",
          "label": "Customer ID",
          "type": "text",
          "required": true,
          "description": "ID of the customer to update",
          "in": "path"
        },
        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: address, description, email, metadata, name, phone, shipping)"
        }
      ],
      "group": "Customer",
      "description": "Update a customer"
    },
    {
      "id": "meter_event_create",
      "label": "Create Meter Event",
      "method": "POST",
      "path": "/billing/meter_events",
      "fields": [
        {
          "id": "eventName",
          "label": "Event Name",
          "type": "text",
          "required": true,
          "description": "The name of the meter event. Corresponds with the event_name field on a meter."
        },
        {
          "id": "customerId",
          "label": "Customer ID",
          "type": "text",
          "required": true,
          "description": "The Stripe customer ID associated with this meter event"
        },
        {
          "id": "value",
          "label": "Value",
          "type": "number",
          "required": true,
          "description": "The value of the meter event. Must be an integer. Can be positive or negative.",
          "defaultValue": 1
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: identifier, timestamp, customPayload)"
        }
      ],
      "group": "Meter Event",
      "description": "Create a meter event"
    },
    {
      "id": "source_create",
      "label": "Create Source",
      "method": "POST",
      "path": "/sources",
      "fields": [
        {
          "id": "customerId",
          "label": "Customer ID",
          "type": "text",
          "required": true,
          "description": "ID of the customer to attach the source to"
        },
        {
          "id": "type",
          "label": "Type",
          "type": "select",
          "required": true,
          "description": "Type of source (payment instrument) to create",
          "defaultValue": "wechat",
          "options": [
            {
              "value": "wechat",
              "label": "WeChat"
            }
          ]
        },
        {
          "id": "amount",
          "label": "Amount",
          "type": "number",
          "description": "Amount in cents to be collected for this charge, e.g. enter 100 for $1.00",
          "defaultValue": 0
        },
        {
          "id": "currency",
          "label": "Currency Name or ID",
          "type": "select",
          "description": "Three-letter ISO currency code, e.g. USD or EUR. It must be a Stripe-supported currency. Choose from the list, or specify an ID using an expression."
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: metadata, statement_descriptor)"
        }
      ],
      "group": "Source",
      "description": "Create a source"
    },
    {
      "id": "source_delete",
      "label": "Delete Source",
      "method": "DELETE",
      "path": "/customers/{customerId}/sources/{sourceId}",
      "fields": [
        {
          "id": "customerId",
          "label": "Customer ID",
          "type": "text",
          "required": true,
          "description": "ID of the customer whose source to delete",
