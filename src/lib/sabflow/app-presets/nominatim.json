    { "id": "reverse", "label": "Reverse", "method": "GET", "path": "/reverse", "fields": [{ "id": "user_agent", "type": "text", "defaultValue": "SabFlow/1.0 (preset)", "required": true, "in": "header" }, { "id": "lat", "type": "number", "required": true, "in": "query" }, { "id": "lon", "type": "number", "required": true, "in": "query" }, { "id": "format", "type": "text", "defaultValue": "jsonv2", "required": true, "in": "query" }, { "id": "addressdetails", "type": "number", "in": "query" }, { "id": "zoom", "type": "number", "in": "query" }] },
    { "id": "lookup", "label": "Lookup OSM IDs", "method": "GET", "path": "/lookup", "fields": [{ "id": "user_agent", "type": "text", "defaultValue": "SabFlow/1.0 (preset)", "required": true, "in": "header" }, { "id": "osm_ids", "type": "text", "required": true, "in": "query" }, { "id": "format", "type": "text", "defaultValue": "jsonv2", "required": true, "in": "query" }] },
    { "id": "status", "label": "Status", "method": "GET", "path": "/status", "fields": [{ "id": "user_agent", "type": "text", "defaultValue": "SabFlow/1.0 (preset)", "required": true, "in": "header" }] }
