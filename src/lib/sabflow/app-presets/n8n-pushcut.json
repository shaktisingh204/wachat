{
  "id": "n8n-pushcut",
  "name": "Pushcut",
  "description": "Consume Pushcut API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://api.pushcut.io/v1",
  "endpoints": [
    {
      "id": "notification_send",
      "label": "Send Notification",
      "method": "POST",
      "path": "/notifications/${encodeURI(notificationName",
      "fields": [
        {
          "id": "notificationName",
          "label": "Notification Name or ID",
          "type": "select",
          "description": "Choose from the list, or specify an ID using an expression"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: devices, input, text, title)"
        }
      ],
      "group": "Notification",
      "description": "Send a notification"
    }
  ]
}
