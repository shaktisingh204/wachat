{
  "id": "n8n-uptime-robot",
  "name": "UptimeRobot",
  "description": "Consume UptimeRobot API",
  "category": "analytics",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://api.uptimerobot.com/v2",
  "endpoints": [
    {
      "id": "account_get",
      "label": "Get Account",
      "method": "POST",
      "path": "/getAccountDetails",
      "fields": [],
      "group": "Account",
      "description": "Get account details"
    },
    {
      "id": "monitor_create",
      "label": "Create Monitor",
      "method": "POST",
      "path": "/newMonitor",
      "fields": [
        {
          "id": "friendlyName",
          "label": "Friendly Name",
          "type": "text",
          "required": true,
          "description": "The friendly name of the monitor"
        },
        {
          "id": "type",
          "label": "Type",
          "type": "select",
          "required": true,
          "description": "The type of the monitor",
          "options": [
            {
              "value": "5",
              "label": "Heartbeat"
            },
            {
              "value": "1",
              "label": "HTTP(S)"
            },
            {
              "value": "2",
              "label": "Keyword"
            },
            {
              "value": "3",
              "label": "Ping"
            },
            {
              "value": "4",
              "label": "Port"
            }
          ]
        },
        {
          "id": "url",
          "label": "URL",
          "type": "text",
          "required": true,
          "description": "The URL/IP of the monitor"
        }
      ],
      "group": "Monitor",
      "description": "Create a monitor"
    },
    {
      "id": "monitor_delete",
      "label": "Delete Monitor",
      "method": "POST",
      "path": "/deleteMonitor",
      "fields": [
        {
          "id": "id",
          "label": "ID",
          "type": "text",
          "required": true,
          "description": "The ID of the monitor"
        }
      ],
      "group": "Monitor",
      "description": "Delete a monitor"
    },
    {
      "id": "monitor_get",
      "label": "Get Monitor",
      "method": "POST",
      "path": "/getMonitors",
      "fields": [
        {
          "id": "id",
          "label": "ID",
          "type": "text",
          "required": true,
          "description": "The ID of the monitor"
        }
      ],
      "group": "Monitor",
      "description": "Get a monitor"
    },
    {
      "id": "monitor_get_all",
      "label": "Get Many Monitor",
      "method": "POST",
      "path": "/getMonitors",
      "fields": [
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 50
        },
        {
          "id": "filters",
          "label": "Filters",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: alert_contacts, logs, mwindow, monitors, response_times, search, statuses, types)"
        }
      ],
      "group": "Monitor",
      "description": "Get many monitors"
    },
    {
      "id": "monitor_reset",
      "label": "Reset Monitor",
      "method": "POST",
      "path": "/resetMonitor",
      "fields": [
        {
          "id": "id",
          "label": "ID",
          "type": "text",
          "required": true,
          "description": "The ID of the monitor"
        }
      ],
      "group": "Monitor",
      "description": "Reset a monitor"
    },
    {
      "id": "monitor_update",
      "label": "Update Monitor",
      "method": "POST",
      "path": "/editMonitor",
      "fields": [
        {
          "id": "id",
          "label": "ID",
          "type": "text",
          "required": true,
          "description": "The ID of the monitor"
        },
        {
          "id": "updateFields",
          "label": "Update Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: friendly_name, http_auth_type, http_method, http_password, http_username, interval, port, status, sub_type, url)"
        }
      ],
      "group": "Monitor",
      "description": "Update a monitor"
    },
