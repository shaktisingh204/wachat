    {
      "id": "maintenance_window_create",
      "label": "Create Maintenance Window",
      "method": "POST",
      "path": "/newMWindow",
      "fields": [
        {
          "id": "duration",
          "label": "Duration (Minutes)",
          "type": "number",
          "required": true,
          "description": "The maintenance window activation period (minutes)",
          "defaultValue": 1
        },
        {
          "id": "friendlyName",
          "label": "Friendly Name",
          "type": "text",
          "required": true,
          "description": "The friendly name of the maintenance window"
        },
        {
          "id": "type",
          "label": "Type",
          "type": "select",
          "required": true,
          "description": "The type of the maintenance window",
          "options": [
            {
              "value": "1",
              "label": "Once"
            },
            {
              "value": "2",
              "label": "Daily"
            },
            {
              "value": "3",
              "label": "Weekly"
            },
            {
              "value": "4",
              "label": "Monthly"
            }
          ]
        },
        {
          "id": "weekDay",
          "label": "Week Day",
          "type": "select",
          "options": [
            {
              "value": "1",
              "label": "Monday"
            },
            {
              "value": "2",
              "label": "Tuesday"
            },
            {
              "value": "3",
              "label": "Wednesday"
            },
            {
              "value": "4",
              "label": "Thursday"
            },
            {
              "value": "5",
              "label": "Friday"
            },
            {
              "value": "6",
              "label": "Saturday"
            },
            {
              "value": "7",
              "label": "Sunday"
            }
          ]
        },
        {
          "id": "monthDay",
          "label": "Month Day",
          "type": "number",
          "defaultValue": 1
        },
        {
          "id": "start_time",
          "label": "Start Time",
          "type": "text",
          "required": true,
          "placeholder": "2024-01-01T00:00:00Z",
          "description": "The maintenance window start datetime (ISO 8601 date-time)"
        }
      ],
      "group": "Maintenance Window",
      "description": "Create a maintenance window"
