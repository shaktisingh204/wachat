{
  "id": "n8n-brandfetch",
  "name": "Brandfetch",
  "description": "Consume Brandfetch API",
  "category": "marketing",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://api.brandfetch.io/v2",
  "endpoints": [
    {
      "id": "color",
      "label": "Color",
      "method": "POST",
      "path": "/brands/{domain}",
      "fields": [
        {
          "id": "domain",
          "label": "Domain",
          "type": "text",
          "required": true,
          "description": "The domain name of the company",
          "in": "path"
        }
      ],
      "description": "Return a company's colors"
    },
    {
      "id": "company",
      "label": "Company",
      "method": "POST",
      "path": "/brands/{domain}",
      "fields": [
        {
          "id": "domain",
          "label": "Domain",
          "type": "text",
          "required": true,
          "description": "The domain name of the company",
          "in": "path"
        }
      ],
      "description": "Return a company's data"
    },
    {
      "id": "font",
      "label": "Font",
      "method": "POST",
      "path": "/brands/{domain}",
      "fields": [
        {
          "id": "domain",
          "label": "Domain",
          "type": "text",
          "required": true,
          "description": "The domain name of the company",
          "in": "path"
        }
      ],
      "description": "Return a company's fonts"
    },
    {
      "id": "industry",
      "label": "Industry",
      "method": "POST",
      "path": "/brands/{domain}",
      "fields": [
        {
          "id": "domain",
          "label": "Domain",
          "type": "text",
          "required": true,
          "description": "The domain name of the company",
          "in": "path"
        }
      ],
      "description": "Return a company's industry"
    },
    {
      "id": "logo",
      "label": "Logo",
      "method": "POST",
      "path": "/brands/{domain}",
      "fields": [
        {
          "id": "domain",
          "label": "Domain",
          "type": "text",
          "required": true,
          "description": "The domain name of the company",
          "in": "path"
        },
        {
          "id": "download",
          "label": "Download",
          "type": "toggle",
          "required": true,
          "description": "Name of the binary property to which to write the data of the read file",
          "defaultValue": false
        },
        {
          "id": "imageTypes",
          "label": "Image Type",
          "type": "select",
          "required": true,
          "description": "(multiple values: comma-separated)",
          "options": [
            {
              "value": "icon",
              "label": "Icon"
            },
            {
              "value": "logo",
              "label": "Logo"
            }
          ]
        },
        {
          "id": "imageFormats",
          "label": "Image Format",
          "type": "select",
          "required": true,
          "description": "The image format in which the logo should be returned as (multiple values: comma-separated)",
          "options": [
            {
              "value": "png",
              "label": "PNG"
            },
            {
              "value": "svg",
              "label": "SVG"
            }
          ]
        }
      ],
      "description": "Return a company's logo & icon"
    }
  ]
}
