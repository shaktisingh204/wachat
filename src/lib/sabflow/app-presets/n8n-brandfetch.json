{
  "id": "n8n-brandfetch",
  "name": "Brandfetch",
  "description": "Consume Brandfetch API",
  "category": "marketing",
  "iconName": "LuPackage",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "default_color",
      "label": "Color",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "domain",
          "label": "Domain",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "The domain name of the company"
        }
      ]
    },
    {
      "id": "default_company",
      "label": "Company",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "domain",
          "label": "Domain",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "The domain name of the company"
        }
      ]
    },
    {
      "id": "default_font",
      "label": "Font",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "domain",
          "label": "Domain",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "The domain name of the company"
        }
      ]
    },
    {
      "id": "default_industry",
      "label": "Industry",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "domain",
          "label": "Domain",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "The domain name of the company"
        }
      ]
    },
    {
      "id": "default_logo",
      "label": "Logo",
      "method": "GET",
      "path": "/",
      "fields": [
        {
          "id": "domain",
          "label": "Domain",
          "type": "text",
          "in": "query",
          "required": true,
          "description": "The domain name of the company"
        },
        {
          "id": "download",
          "label": "Download",
          "type": "toggle",
          "in": "query",
          "required": true,
          "description": "Name of the binary property to which to write the data of the read file",
          "defaultValue": false
        },
        {
          "id": "imageTypes",
          "label": "Image Type",
          "type": "select",
          "in": "query",
          "required": true,
          "options": [
            {
              "value": "icon",
              "label": "Icon"
            },
            {
              "value": "logo",
              "label": "Logo"
            }
          ]
        },
        {
          "id": "imageFormats",
          "label": "Image Format",
          "type": "select",
          "in": "query",
          "required": true,
          "description": "The image format in which the logo should be returned as",
          "options": [
            {
              "value": "png",
              "label": "PNG"
            },
            {
              "value": "svg",
              "label": "SVG"
            }
          ]
        }
      ]
    }
  ]
}
