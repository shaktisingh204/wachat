          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: days_to_resolve_issue, domain, grade_to_maintain, is_organization_point_of_contact, issue_desc, issue_title, issue_type, sendme_copy, target_url)"
