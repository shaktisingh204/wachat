{
  "id": "n8n-security-scorecard",
  "name": "SecurityScorecard",
  "description": "Consume SecurityScorecard API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 12,
  "lastVerified": "2026-06-12",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "http_header_auth"
  },
  "baseUrl": "https://api.securityscorecard.io",
  "endpoints": [
    {
      "id": "company_get_factor",
      "label": "Get Factor Scores Company",
      "method": "GET",
      "path": "/companies/{scorecardIdentifier}/factors",
      "fields": [
        {
          "id": "scorecardIdentifier",
          "label": "Scorecard Identifier",
          "type": "text",
          "required": true,
          "description": "Primary identifier of a company or scorecard, i.e. domain.",
          "in": "path"
        },
        {
          "id": "returnAll",
          "label": "Return All",
          "type": "toggle",
          "description": "Whether to return all results or only up to a given limit",
          "defaultValue": false
        },
        {
          "id": "limit",
          "label": "Limit",
          "type": "number",
          "description": "Max number of results to return",
          "defaultValue": 100
        },
        {
          "id": "filters",
          "label": "Filters",
          "type": "json",
          "placeholder": "Add Filter",
          "description": "(JSON object; supported keys: severity, severity_in)"
        }
      ],
      "group": "Company",
      "description": "Get company factor scores and issue counts"
    },
    {
      "id": "company_get_factor_historical",
