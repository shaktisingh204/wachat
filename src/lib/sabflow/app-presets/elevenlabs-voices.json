{
  "id": "elevenlabs-voices",
  "name": "ElevenLabs (Voices)",
  "description": "ElevenLabs voice management, voice design, models, and history endpoints.",
  "category": "AI",
  "iconName": "LuMic",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "header",
    "credentialType": "elevenlabs",
    "header": "xi-api-key"
  },
  "baseUrl": "https://api.elevenlabs.io/v1",
  "endpoints": [
    {
      "id": "list_voices",
      "label": "List voices",
      "method": "GET",
      "path": "/voices",
      "fields": []
    },
    {
      "id": "get_voice",
      "label": "Get voice",
      "method": "GET",
      "path": "/voices/{voice_id}",
      "fields": [
        { "id": "voice_id", "label": "Voice ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "delete_voice",
      "label": "Delete voice",
      "method": "DELETE",
      "path": "/voices/{voice_id}",
      "fields": [
        { "id": "voice_id", "label": "Voice ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "add_voice",
      "label": "Add voice",
      "method": "POST",
      "path": "/voices/add",
      "fields": [
        { "id": "name", "label": "Name", "type": "text", "required": true, "in": "body" },
        { "id": "files", "label": "Files JSON", "type": "json", "required": true, "in": "body" },
        { "id": "description", "label": "Description", "type": "textarea", "in": "body" },
        { "id": "labels", "label": "Labels JSON", "type": "json", "in": "body" }
      ]
    },
    {
      "id": "edit_voice",
      "label": "Edit voice",
      "method": "POST",
      "path": "/voices/{voice_id}/edit",
      "fields": [
        { "id": "voice_id", "label": "Voice ID", "type": "text", "required": true, "in": "path" },
        { "id": "name", "label": "Name", "type": "text", "in": "body" },
        { "id": "description", "label": "Description", "type": "textarea", "in": "body" },
        { "id": "labels", "label": "Labels JSON", "type": "json", "in": "body" }
      ]
    },
    {
      "id": "get_user_info",
      "label": "Get user info",
      "method": "GET",
      "path": "/user",
      "fields": []
    },
    {
      "id": "list_models",
      "label": "List models",
      "method": "GET",
      "path": "/models",
      "fields": []
    },
    {
      "id": "list_history",
      "label": "List history",
      "method": "GET",
      "path": "/history",
      "fields": []
    },
    {
      "id": "delete_history_item",
      "label": "Delete history item",
      "method": "DELETE",
      "path": "/history/{history_item_id}",
      "fields": [
        { "id": "history_item_id", "label": "History item ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "voice_design",
      "label": "Design voice",
      "method": "POST",
      "path": "/voice-generation/generate-voice",
      "fields": [
        { "id": "gender", "label": "Gender", "type": "text", "required": true, "in": "body" },
        { "id": "accent", "label": "Accent", "type": "text", "required": true, "in": "body" },
        { "id": "age", "label": "Age", "type": "text", "required": true, "in": "body" },
        { "id": "accent_strength", "label": "Accent strength", "type": "number", "required": true, "in": "body" },
        { "id": "text", "label": "Text", "type": "textarea", "required": true, "in": "body" }
      ]
    }
  ]
}
