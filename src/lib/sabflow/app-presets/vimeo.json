{
  "id": "vimeo",
  "name": "Vimeo",
  "description": "Video hosting platform.",
  "category": "Video",
  "iconName": "LuVideo",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "oauth2",
    "credentialType": "oauth2",
    "header": "Authorization",
    "scheme": "Bearer"
  },
  "baseUrl": "https://api.vimeo.com",
  "endpoints": [
    {
      "id": "get_video",
      "label": "Get video",
      "method": "GET",
      "path": "/videos/{video_id}",
      "fields": [
        { "id": "video_id", "label": "Video ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "list_my_videos",
      "label": "List my videos",
      "method": "GET",
      "path": "/me/videos",
      "fields": [
        { "id": "page", "label": "Page", "type": "number", "defaultValue": 1, "in": "query" },
        { "id": "per_page", "label": "Per page", "type": "number", "defaultValue": 25, "in": "query" }
      ]
    },
    {
      "id": "upload_video_resumable_start",
      "label": "Start resumable upload",
      "method": "POST",
      "path": "/me/videos",
      "fields": [
        { "id": "upload", "label": "Upload config", "type": "json", "required": true, "in": "body", "defaultValue": { "approach": "tus", "size": 0 } },
        { "id": "name", "label": "Name", "type": "text", "in": "body" },
        { "id": "description", "label": "Description", "type": "textarea", "in": "body" }
      ]
    },
    {
      "id": "list_albums",
      "label": "List albums",
      "method": "GET",
      "path": "/me/albums",
      "fields": [
        { "id": "page", "label": "Page", "type": "number", "defaultValue": 1, "in": "query" },
        { "id": "per_page", "label": "Per page", "type": "number", "defaultValue": 25, "in": "query" }
      ]
    },
    {
      "id": "create_album",
      "label": "Create album",
      "method": "POST",
      "path": "/me/albums",
      "fields": [
        { "id": "name", "label": "Name", "type": "text", "required": true, "in": "body" },
        { "id": "description", "label": "Description", "type": "textarea", "in": "body" }
      ]
    },
    {
      "id": "delete_video",
      "label": "Delete video",
      "method": "DELETE",
      "path": "/videos/{video_id}",
      "fields": [
        { "id": "video_id", "label": "Video ID", "type": "text", "required": true, "in": "path" }
      ]
    }
  ]
}
