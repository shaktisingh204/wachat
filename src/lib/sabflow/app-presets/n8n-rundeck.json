{
  "id": "n8n-rundeck",
  "name": "Rundeck",
  "description": "Manage Rundeck API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 3,
  "lastVerified": "2026-06-12",
  "status": "draft",
  "auth": {
    "type": "header",
    "credentialType": "rundeck",
    "header": "user-agent",
    "baseUrlFromCredential": "baseUrl"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "job_execute",
      "label": "Execute Job",
      "method": "POST",
      "path": "/api/14/job/{jobid}/run",
      "fields": [
        {
          "id": "jobid",
          "label": "Job ID",
          "type": "text",
          "required": true,
          "placeholder": "Rundeck Job ID",
          "description": "The job ID to execute",
          "in": "path"
        },
        {
          "id": "arguments",
          "label": "Arguments",
          "type": "json",
          "placeholder": "Add Argument",
          "description": "(JSON object; supported keys: arguments, arguments.name, arguments.value)"
        },
        {
          "id": "filter",
          "label": "Filter",
          "type": "text",
          "placeholder": "Add Filters",
          "description": "Filter Rundeck nodes by name"
        }
      ],
      "group": "Job",
      "description": "Execute a job"
    },
    {
      "id": "job_get_metadata",
      "label": "Get Metadata Job",
      "method": "GET",
      "path": "/api/18/job/{jobid}/info",
      "fields": [
        {
          "id": "jobid",
          "label": "Job ID",
          "type": "text",
          "required": true,
          "placeholder": "Rundeck Job ID",
          "description": "The job ID to get metadata off",
          "in": "path"
        }
      ],
      "group": "Job",
      "description": "Get metadata of a job"
    }
  ]
}
