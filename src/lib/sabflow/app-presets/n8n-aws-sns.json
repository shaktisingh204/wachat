{
  "id": "n8n-aws-sns",
  "name": "AWS SNS",
  "description": "Sends data to AWS SNS",
  "category": "dev",
  "iconName": "LuPackage",
  "version": 10,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "bearer",
    "credentialType": "aws_sns"
  },
  "baseUrl": "https://iam.amazonaws.com",
  "endpoints": [
    {
      "id": "create",
      "label": "Create",
      "method": "POST",
      "path": "/?Action=CreateTopic&params.join('&",
      "fields": [
        {
          "id": "name",
          "label": "Name",
          "type": "text",
          "required": true
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: displayName, fifoTopic)"
        }
      ],
      "description": "Create a topic"
    },
    {
      "id": "delete",
      "label": "Delete",
      "method": "DELETE",
      "path": "/?Action=DeleteTopic&params.join('&",
      "fields": [
        {
          "id": "topic",
          "label": "Topic",
          "type": "text",
          "required": true,
          "description": "(provide the ID)"
        }
      ],
      "description": "Delete a topic"
    },
    {
      "id": "publish",
      "label": "Publish",
      "method": "POST",
      "path": "/?Action=Publish&params.join('&",
      "fields": [
        {
          "id": "topic",
          "label": "Topic",
          "type": "text",
          "required": true,
          "description": "(provide the ID)"
        },
        {
          "id": "subject",
          "label": "Subject",
          "type": "text",
          "required": true,
          "description": "Subject when the message is delivered to email endpoints"
        },
        {
          "id": "message",
          "label": "Message",
          "type": "text",
          "required": true,
          "description": "The message you want to send"
        }
      ],
      "description": "Publish a message to a topic"
    }
  ]
}
