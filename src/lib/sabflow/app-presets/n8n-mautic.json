{
  "id": "n8n-mautic",
  "name": "Mautic",
  "description": "Consume Mautic API",
  "category": "marketing",
  "iconName": "LuPackage",
  "version": 2,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "basic",
    "credentialType": "mautic",
    "baseUrlFromCredential": "baseUrl"
  },
  "baseUrl": "",
  "endpoints": [
    {
      "id": "company_create",
      "label": "Create Company",
      "method": "POST",
      "path": "/companies/new",
      "fields": [
        {
          "id": "name",
          "label": "Company Name",
          "type": "text",
          "description": "The name of the company to create"
        },
        {
          "id": "simple",
          "label": "Simplify",
          "type": "toggle",
          "description": "Whether to return a simplified version of the response instead of the raw data",
          "defaultValue": true
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: addressUi, annualRevenue, companyEmail, customFieldsUi, description, fax, industry, isPublished, numberOfEmpoyees, overwriteWithBlank, phone, website)"
        }
      ],
      "group": "Company",
      "description": "Create a new company"
    },
    {
      "id": "company_delete",
      "label": "Delete Company",
      "method": "DELETE",
      "path": "/companies/{companyId}/delete",
      "fields": [
        {
          "id": "companyId",
          "label": "Company ID",
          "type": "text",
          "description": "The ID of the company to delete",
          "in": "path"
        },
        {
          "id": "simple",
          "label": "Simplify",
          "type": "toggle",
          "description": "Whether to return a simplified version of the response instead of the raw data",
          "defaultValue": true
        }
      ],
      "group": "Company",
      "description": "Delete a company"
    },
    {
      "id": "company_get",
      "label": "Get Company",
      "method": "GET",
      "path": "/companies/{companyId}",
      "fields": [
        {
          "id": "companyId",
          "label": "Company ID",
          "type": "text",
          "description": "The ID of the company to return",
          "in": "path"
        },
        {
          "id": "simple",
          "label": "Simplify",
          "type": "toggle",
          "description": "Whether to return a simplified version of the response instead of the raw data",
          "defaultValue": true
        }
      ],
      "group": "Company",
      "description": "Get data of a company"
    },
    {
      "id": "company_get_all",
