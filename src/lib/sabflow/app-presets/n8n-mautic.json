    {
      "id": "contact_create",
      "label": "Create Contact",
      "method": "POST",
      "path": "/contacts/new",
      "fields": [
        {
          "id": "jsonParameters",
          "label": "JSON Parameters",
          "type": "toggle",
          "defaultValue": false
        },
        {
          "id": "email",
          "label": "Email",
          "type": "text",
          "placeholder": "name@email.com",
          "description": "Email address of the contact"
        },
        {
          "id": "firstName",
          "label": "First Name",
          "type": "text"
        },
        {
          "id": "lastName",
          "label": "Last Name",
          "type": "text"
        },
        {
          "id": "company",
          "label": "Primary Company Name or ID",
          "type": "select",
          "description": "Choose from the list, or specify an ID using an expression"
        },
        {
          "id": "position",
          "label": "Position",
          "type": "text"
        },
        {
          "id": "title",
          "label": "Title",
          "type": "text"
        },
        {
          "id": "bodyJson",
          "label": "Body",
          "type": "json",
          "description": "Contact parameters"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: addressUi, b2bOrb2c, crmId, customFieldsUi, fax, hasPurchased, ipAddress, lastActive, mobile, ownerId, phone, prospectOrCustomer, sandbox, stage, tags, socialMediaUi, website)"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: search, orderBy, orderByDir, publishedOnly, minimal, rawData)"
        }
      ],
      "group": "Contact",
      "description": "Create a new contact"
    },
