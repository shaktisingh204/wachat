        {
          "id": "simple",
          "label": "Simplify",
          "type": "toggle",
          "description": "Whether to return a simplified version of the response instead of the raw data",
          "defaultValue": true
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: orderByDir, orderBy, search)"
        }
      ],
      "group": "Company",
      "description": "Get data of many companies"
    },
    {
      "id": "company_update",
