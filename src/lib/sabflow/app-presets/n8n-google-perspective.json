{
  "id": "n8n-google-perspective",
  "name": "Google Perspective",
  "description": "Consume Google Perspective API",
  "category": "misc",
  "iconName": "LuPackage",
  "version": 11,
  "lastVerified": "2026-06-11",
  "status": "draft",
  "auth": {
    "type": "oauth2",
    "provider": "google",
    "credentialType": "google_sheets",
    "fallback": {
      "type": "oauth2",
      "credentialType": "oauth2"
    }
  },
  "baseUrl": "https://commentanalyzer.googleapis.com",
  "endpoints": [
    {
      "id": "analyze_comment",
      "label": "Analyze Comment",
      "method": "POST",
      "path": "/v1alpha1/comments:analyze",
      "fields": [
        {
          "id": "text",
          "label": "Text",
          "type": "text",
          "required": true
        },
        {
          "id": "requestedAttributesUi",
          "label": "Attributes to Analyze",
          "type": "json",
          "required": true,
          "placeholder": "Add Atrribute",
          "description": "(JSON object; supported keys: requestedAttributesValues, requestedAttributesValues.attributeName, requestedAttributesValues.scoreThreshold)"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: languages)"
        }
      ]
    }
  ]
}
