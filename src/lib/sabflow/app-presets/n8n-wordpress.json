    {
      "id": "post_create",
      "label": "Create Post",
      "method": "POST",
      "path": "/posts",
      "fields": [
        {
          "id": "authType",
          "label": "Authentication",
          "type": "select",
          "description": "The authentication method to use",
          "defaultValue": "basicAuth",
          "options": [
            {
              "value": "basicAuth",
              "label": "Basic Auth"
            },
            {
              "value": "oAuth2",
              "label": "OAuth2 (WordPress.com)"
            }
          ]
        },
        {
          "id": "title",
          "label": "Title",
          "type": "text",
          "required": true,
          "description": "The title for the post"
        },
        {
          "id": "additionalFields",
          "label": "Additional Fields",
          "type": "json",
          "placeholder": "Add Field",
          "description": "(JSON object; supported keys: authorId, content, slug, password, status, date, commentStatus, pingStatus, format, sticky, categories, tags, postTemplate)"
        }
      ],
      "group": "Post",
      "description": "Create a post"
    },
    {
      "id": "post_get",
      "label": "Get Post",
      "method": "GET",
      "path": "/posts/{postId}",
      "fields": [
        {
          "id": "authType",
          "label": "Authentication",
          "type": "select",
          "description": "The authentication method to use",
          "defaultValue": "basicAuth",
          "options": [
            {
              "value": "basicAuth",
              "label": "Basic Auth"
            },
            {
              "value": "oAuth2",
              "label": "OAuth2 (WordPress.com)"
            }
          ]
        },
        {
          "id": "postId",
          "label": "Post ID",
          "type": "text",
          "required": true,
          "description": "Unique identifier for the object",
          "in": "path"
        },
        {
          "id": "options",
          "label": "Options",
          "type": "json",
          "placeholder": "Add option",
          "description": "(JSON object; supported keys: password, context)"
        }
      ],
      "group": "Post",
      "description": "Get a post"
    },
    {
