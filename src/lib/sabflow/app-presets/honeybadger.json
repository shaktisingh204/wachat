{
  "id": "honeybadger",
  "name": "Honeybadger",
  "description": "Honeybadger error tracking and uptime monitoring API.",
  "category": "Monitoring",
  "iconName": "LuBug",
  "version": 1,
  "lastVerified": "2026-05-17",
  "status": "verified",
  "auth": {
    "type": "basic",
    "credentialType": "honeybadger"
  },
  "baseUrl": "https://app.honeybadger.io/v2",
  "endpoints": [
    {
      "id": "list_projects",
      "label": "List projects",
      "method": "GET",
      "path": "/projects",
      "fields": [
        { "id": "page", "label": "Page", "type": "number", "in": "query" }
      ]
    },
    {
      "id": "get_project",
      "label": "Get project",
      "method": "GET",
      "path": "/projects/{project_id}",
      "fields": [
        { "id": "project_id", "label": "Project ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "list_faults",
      "label": "List faults",
      "method": "GET",
      "path": "/projects/{project_id}/faults",
      "fields": [
        { "id": "project_id", "label": "Project ID", "type": "text", "required": true, "in": "path" },
        { "id": "q", "label": "Search query", "type": "text", "in": "query" },
        { "id": "page", "label": "Page", "type": "number", "in": "query" }
      ]
    },
    {
      "id": "get_fault",
      "label": "Get fault",
      "method": "GET",
      "path": "/projects/{project_id}/faults/{fault_id}",
      "fields": [
        { "id": "project_id", "label": "Project ID", "type": "text", "required": true, "in": "path" },
        { "id": "fault_id", "label": "Fault ID", "type": "text", "required": true, "in": "path" }
      ]
    },
    {
      "id": "list_fault_notices",
      "label": "List fault notices",
      "method": "GET",
      "path": "/projects/{project_id}/faults/{fault_id}/notices",
      "fields": [
        { "id": "project_id", "label": "Project ID", "type": "text", "required": true, "in": "path" },
        { "id": "fault_id", "label": "Fault ID", "type": "text", "required": true, "in": "path" },
        { "id": "page", "label": "Page", "type": "number", "in": "query" }
      ]
    },
    {
      "id": "resolve_fault",
      "label": "Resolve fault",
      "method": "PUT",
      "path": "/projects/{project_id}/faults/{fault_id}",
      "fields": [
        { "id": "project_id", "label": "Project ID", "type": "text", "required": true, "in": "path" },
        { "id": "fault_id", "label": "Fault ID", "type": "text", "required": true, "in": "path" },
        { "id": "resolved", "label": "Resolved", "type": "toggle", "required": true, "defaultValue": true, "in": "body" }
      ]
    },
    {
      "id": "unresolve_fault",
      "label": "Unresolve fault",
      "method": "PUT",
      "path": "/projects/{project_id}/faults/{fault_id}",
      "fields": [
        { "id": "project_id", "label": "Project ID", "type": "text", "required": true, "in": "path" },
        { "id": "fault_id", "label": "Fault ID", "type": "text", "required": true, "in": "path" },
        { "id": "resolved", "label": "Resolved", "type": "toggle", "required": true, "defaultValue": false, "in": "body" }
      ]
    },
    {
      "id": "list_deploys",
      "label": "List deploys",
      "method": "GET",
      "path": "/projects/{project_id}/deploys",
      "fields": [
        { "id": "project_id", "label": "Project ID", "type": "text", "required": true, "in": "path" },
        { "id": "page", "label": "Page", "type": "number", "in": "query" }
      ]
    },
    {
      "id": "create_deploy",
      "label": "Create deploy",
      "method": "POST",
      "path": "/projects/{project_id}/deploys",
      "fields": [
        { "id": "project_id", "label": "Project ID", "type": "text", "required": true, "in": "path" },
        { "id": "environment", "label": "Environment", "type": "text", "required": true, "in": "body" },
        { "id": "revision", "label": "Revision", "type": "text", "in": "body" },
        { "id": "repository", "label": "Repository", "type": "text", "in": "body" },
        { "id": "local_username", "label": "Local username", "type": "text", "in": "body" }
      ]
    },
    {
      "id": "list_users",
      "label": "List users",
      "method": "GET",
      "path": "/users",
      "fields": [
        { "id": "page", "label": "Page", "type": "number", "in": "query" }
      ]
    }
  ]
}
