    "test": "node --test ./src/__tests__/cli.test.mjs"
  },
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
    "sabnode",
    "sabflow",
    "template",
    "scaffold",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  }
}
