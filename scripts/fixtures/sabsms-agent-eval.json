    { "id": "unclear-01", "category": "unclear", "inbound": "don't", "conversationCategory": "marketing", "responses": [{ "type": "reply", "body": "Just checking - would you like to stop receiving these messages? Reply STOP and we'll unsubscribe you." }], "expect": { "pipeline": "flagged_replied" } },
    { "id": "unclear-02", "category": "unclear", "inbound": "no", "conversationCategory": "marketing", "responses": [{ "type": "reply", "body": "No problem! If you'd rather not get these messages just reply STOP." }], "expect": { "pipeline": "flagged_replied" } },
