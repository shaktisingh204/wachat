    { "id": "unclear-04", "category": "unclear", "inbound": "hmm stop or maybe not lol", "conversationCategory": "marketing", "responses": [{ "type": "classifier", "intent": "unclear" }, { "type": "reply", "body": "Your call! Reply STOP anytime to unsubscribe, or let me know how I can help." }], "expect": { "pipeline": "flagged_replied" } },
    { "id": "unclear-05", "category": "unclear", "inbound": "I might block you", "conversationCategory": "marketing", "responses": [{ "type": "classifier", "intent": "unclear" }, { "type": "reply", "body": "Sorry to hear that! Reply STOP and we'll stop messaging you right away." }], "expect": { "pipeline": "flagged_replied" } }
  ],
