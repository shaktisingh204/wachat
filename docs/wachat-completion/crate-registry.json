    },
    "wachat-project-attributes": {
      "ident": "wachat_project_attributes",
      "state": "WachatProjectAttributesState",
      "mount": "/v1/wachat/project-attributes"
    },
    "wachat-link-generator": {
      "ident": "wachat_link_generator",
      "state": "WachatLinkGeneratorState",
      "mount": "/v1/wachat/link-generator"
    },
    "wachat-widget-tracking": {
      "ident": "wachat_widget_tracking",
      "state": "WachatWidgetTrackingState",
      "mount": "/v1/wachat/widget"
    },
    "wachat-integrations-hub": {
