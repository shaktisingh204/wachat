{
  "_comment": "Registry of WaChat-completion crates. register-crates.py uses ident/state/mount to apply the 3 api-side edits (Cargo dep, FromRef impl, router let+nest). name = crate dir under rust/crates/.",
  "crates": {
    "wachat-number-routing": {
      "ident": "wachat_number_routing",
      "state": "WachatNumberRoutingState",
      "mount": "/v1/wachat/number-routing",
      "wired": true
    },
    "wachat-canned-messages": {
      "ident": "wachat_canned_messages",
      "state": "WachatCannedMessagesState",
      "mount": "/v1/wachat/canned-messages"
    },
    "wachat-ai-training": {
      "ident": "wachat_ai_training",
      "state": "WachatAiTrainingState",
      "mount": "/v1/wachat/ai-training"
    },
    "wachat-interactive-builder": {
      "ident": "wachat_interactive_builder",
      "state": "WachatInteractiveBuilderState",
      "mount": "/v1/wachat/interactive-builder"
    },
    "wachat-setup-kb": {
      "ident": "wachat_setup_kb",
      "state": "WachatSetupKbState",
      "mount": "/v1/wachat/setup-kb"
    },
    "wachat-ads-roadmap": {
      "ident": "wachat_ads_roadmap",
      "state": "WachatAdsRoadmapState",
      "mount": "/v1/wachat/ads-roadmap"
