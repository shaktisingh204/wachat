    },
    "wachat-flow-events": {
      "ident": "wachat_flow_events",
      "state": "WachatFlowEventsState",
      "mount": "/v1/wachat/flow-events"
    },
    "wachat-opt-out-settings": {
      "ident": "wachat_opt_out_settings",
      "state": "WachatOptOutSettingsState",
      "mount": "/v1/wachat/opt-out-settings"
    },
    "wachat-ab-testing": {
      "ident": "wachat_ab_testing",
      "state": "WachatAbTestingState",
      "mount": "/v1/wachat/ab-tests"
    },
    "wachat-contact-merge": {
      "ident": "wachat_contact_merge",
      "state": "WachatContactMergeState",
      "mount": "/v1/wachat/contact-merge"
