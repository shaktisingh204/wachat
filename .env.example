# ════════════════════════════════════════════════════════════════════════════
# SabNode — full env reference
#
# Copy this file to `.env` and fill in the values you need.  Every variable
# is optional except where called out; SabFlow / CRM degrade
# gracefully when integrations aren't configured.
# ════════════════════════════════════════════════════════════════════════════

# ─── App ───────────────────────────────────────────────────────────────────
# Public origin used to build OAuth redirect URIs and embed-iframe URLs.
# Example: https://app.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== SabCRM (vendored Twenty engine — services/sabcrm) =====
# Server-side API base for the NestJS engine (also serves the SPA).
SABCRM_ENGINE_URL=http://127.0.0.1:4300
# Shared bearer token for privileged Next -> engine calls (SSO handoff, admin).
SABCRM_ENGINE_TOKEN=devtoken-change-me
# Browser-facing URL of the SabCRM SPA, embedded via iframe at /sabcrm.
NEXT_PUBLIC_SABCRM_URL=http://localhost:4300
AUTH_STATE_KEY=base64-encoded-32-byte-key

# ─── SabSMS — Rust engine for multi-provider SMS / MMS / RCS ──────────────
# The engine is `services/sabsms-engine/` (Rust + Axum + Tokio). The
# Next.js side talks to it via `src/lib/sabsms/engine-client.ts`. The
# engine calls back into Next for credit reservation / finalisation at
# `/api/sabsms/credits`. PM2 app name: `sabsms-engine`, default port 4002.
SABSMS_ENABLED=false
SABSMS_ENGINE_URL=http://localhost:4002
SABSMS_ENGINE_TOKEN=devtoken-change-me
# Base URL the Rust engine uses to call back into Next for credit
# reservation / finalisation. Defaults to NEXT_PUBLIC_APP_URL if unset.
SABSMS_APP_CALLBACK_URL=
# HMAC secret used to sign provider webhooks forwarded by Next to the engine.
SABSMS_WEBHOOK_SECRET=please-change-me-32-bytes-or-more
# AES-256-GCM key for provider credential ciphers — exactly 64 hex chars (32 bytes), shared with the engine.
SABSMS_CREDS_KEY=
# Allow the engine to fall back to env-provided provider creds (dev only).
SABSMS_ALLOW_ENV_CREDS=false
# Use the mock SMS provider instead of real provider APIs (dev/e2e only).
SABSMS_PROVIDER_MOCK=false
# OTP fraud guard mode (V2.7): enforce (default) | monitor (log + event,
# never block — the soak mode) | off. Read by the Rust engine.
SABSMS_FRAUD_MODE=enforce
# Base URL short links are minted under (e.g. https://sab.sm). Defaults to
# NEXT_PUBLIC_APP_URL + /s. Per-workspace branded domains (SabSMS settings)
# override this.
SABSMS_SHORT_LINK_BASE=
# Publicly reachable base URL of the Rust engine — used to build the
# provider webhook URLs (inbound + DLR callbacks) handed to Twilio/Telnyx/
# MSG91/Gupshup at provision time. Read by both the Next UI
# (`src/lib/sabsms/webhook-urls.ts`) and the engine worker. Falls back to
# SABSMS_ENGINE_URL when unset; set it to the externally-resolvable host in
# production (e.g. https://sms-engine.yourdomain.com).
SABSMS_ENGINE_PUBLIC_URL=
# India DLT enforcement (V2.8): strict (block all without a valid binding) |
# marketing_only (default — enforce on marketing, allow transactional) |
# off. Read by the Rust engine at send time.
SABSMS_DLT_ENFORCE=marketing_only
# Gupshup API base URL — used by both the send adapter and the
# test-connection probe. Defaults to Gupshup's public endpoint when unset.
SABSMS_GUPSHUP_BASE_URL=

# ─── SabFlow — outbound email (Step 13: failure alerts, Send Email block) ─
# When all four are present, SabFlow uses SMTP for failure alerts AND as a
# fallback for the Send Email block when no per-block credential is set.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── SabFlow — OAuth providers (Step 18 + Step 20) ────────────────────────
# All callbacks default to NEXT_PUBLIC_APP_URL + /api/sabflow/oauth/callback
# when *_OAUTH_REDIRECT_URI is unset.  Register that exact URL with each
# provider's app-management console.

# Google (Sheets, Drive, Analytics, Calendar, Gmail)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional override; defaults to ${NEXT_PUBLIC_APP_URL}/api/sabflow/oauth/callback
GOOGLE_OAUTH_REDIRECT_URI=

# Slack (channels, files, users, chat.postMessage)
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
SLACK_OAUTH_REDIRECT_URI=

