# ─── SabFlow — feature flags (Phase C.8) ─────────────────────────────────
# Enables the multiplayer presence layer (avatar stack, remote cursors,
# typing indicators) in the SabFlow editor. When unset/empty/'0'/'false'
# the editor renders normally and skips the 5-second presence beacon to
# `/api/sabflow/[flowId]/presence`. Set to `1` or `true` to opt in.
NEXT_PUBLIC_SABFLOW_COLLAB_ENABLED=

# Enables the execution step-replay / playback UI on the executions page.
# Off by default. Set to `true` or `1` to enable.
NEXT_PUBLIC_SABFLOW_PLAYBACK_ENABLED=

# Controls the block-marketplace tab in the editor sidebar.
# ON by default — set to `false` or `0` to hide it.
NEXT_PUBLIC_SABFLOW_MARKETPLACE_ENABLED=

# ─── SabFlow — execution / observability (informational) ──────────────────
# These don't require env vars; surfaced here as a reference of features:
#  - /dashboard/sabflow/executions       Execution list + replay
#  - /dashboard/sabflow/links            Multi-bot link dashboard
#  - /api/v1/flows/:id/run               REST API (key auth)
#  - /api/sabflow/api-keys               Mint/revoke v1 API keys
#  - /api/sabflow/env-vars               Workspace-scoped $env.* vars
#  - /api/sabflow/folders                Real folder records

# ─── SabFlow — execution retention cron (/api/cron/sabflow-executions-retention) ──
# Days to keep finished executions before they get pruned by the retention cron.
SABFLOW_EXECUTION_RETENTION_DAYS=90
# Per-flow execution-history cap.  Older rows beyond this count are pruned.
SABFLOW_MAX_EXECUTIONS_PER_FLOW=1000

# ─── Optional: n8n expression engine isolated-vm sandbox ──────────────────
# Set to 'vm' to enable the isolated-vm-backed expression evaluator (more
# secure but heavier).  Anything else uses the legacy evaluator.
N8N_EXPRESSION_ENGINE=

# Whether scripting blocks can read process.env at run-time.  Defaults to
# 'true' (blocked).  Set to 'false' to permit access — only do this in
# trusted single-tenant deployments.
N8N_BLOCK_ENV_ACCESS_IN_NODE=true

# ─── CRM contracts — e-signature flow (§6.2) ─────────────────────────────
# HMAC key used to mint/verify single-use signer tokens for the public
# `/sign/[contractId]/[signerToken]` route. Must be at least 32 random
# bytes; rotate to immediately invalidate every outstanding signing link.
# Generate with `openssl rand -hex 32`.
CONTRACT_SIGNER_SECRET=

# ─── CRM portal — magic-link sign-in (§6.6) ──────────────────────────────
# HMAC key used to mint/verify single-use magic-link tokens for the public
# `/portal/[tenantSlug]/auth/verify?token=...` route. Tokens are valid for
# 15 minutes and consumed once (bookkeeping in `crm_portal_magic_link_uses`).
# Rotate to invalidate every outstanding link. Generate with
# `openssl rand -hex 32`.
PORTAL_MAGIC_LINK_SECRET=

# HMAC key used to mint/verify the `portal_session` cookie that protects
# `/portal/[tenantSlug]/*`. Distinct from the main SabNode `session` cookie
# (different secret + different path scope). 7-day TTL. Generate with
# `openssl rand -hex 32`.
PORTAL_SESSION_SECRET=

# ─── Cron auth ────────────────────────────────────────────────────────────
# Shared secret required for /api/cron/* endpoints. The PM2 `sabnode-cron`
# worker (scripts/cron-worker.mjs) attaches this as `?token=$CRON_SECRET`
# on every scheduled invocation; the routes 401 without it. Generate with
# `openssl rand -hex 32`.
CRON_SECRET=

# Base URL the PM2 cron worker calls to invoke /api/cron/[job].
# Defaults to http://localhost:3000 if unset.
APP_BASE_URL=

# ─── India tax — e-invoice (IRN) + e-way bill (§6.10) ────────────────────
# AES-256-GCM key used to encrypt per-tenant IRP / EWB credentials at rest
# in `crm_india_tax_credentials`. Accepts either 64-char hex or 44-char
# base64 (both decode to 32 bytes). Generate with
# `openssl rand -hex 32`.
INDIA_TAX_ENCRYPTION_KEY=

# Provider creds — wire ONE of the channel partners when going live. The
# `internal` provider (deterministic mock, no network) is the default and
# requires no env vars.
#
# NIC IRP (official Invoice Reporting Portal) — sandbox host
# `einv-apisandbox.nic.in`, prod host `einvoice1.gst.gov.in`.
NIC_IRP_CLIENT_ID=
NIC_IRP_CLIENT_SECRET=
# NIC EWB portal — same auth model, separate creds.
NIC_EWB_CLIENT_ID=
NIC_EWB_CLIENT_SECRET=

# Cleartax channel partner — single bearer token gates both e-invoice + EWB.
CLEARTAX_API_TOKEN=

# Masters India channel partner — OAuth2 client-credentials.
MASTERS_INDIA_CLIENT_ID=
MASTERS_INDIA_CLIENT_SECRET=

# ─── GDPR erase execution gate ────────────────────────────────────────────
# When `true`, `executeEraseRequest` actually mutates rows (redact / hard
# delete). When unset, the action walks the same code path but records
# `executionMode: env_gated_logged_only` and skips mutations — letting ops
# dry-run in prod before flipping the switch.  See docs/ops/gdpr-erasure.md.
GDPR_EXECUTION_ENABLED=

# ============================================================================
# Twenty clone — Postgres dual-DB + staged auth migration (docs/twenty-clone/)
# All default to the SAFE current behaviour; nothing changes until set.
# ============================================================================

# --- SabNode-side Postgres (sabnode_identity schema: users/sessions/auth) ---
# Point at PgBouncer in production. Leave unset until Postgres is provisioned.
SABNODE_PG_URL=
# Per-process pool size (PM2 fork-mode fans out — keep small). Default 10.
SABNODE_PG_POOL_MAX=10

# --- Staged auth migration flags (PLAN.md §3) ---
# Write path:  off | dual | pg-only   (default off)
AUTH_PG_WRITE=off
# Read path:   mongo | pg-fallback | pg   (default mongo)
AUTH_PG_READ=mongo

# --- twenty-server (the cloned Twenty backend, its own Postgres core schema) ---
# Base URL of the running twenty-server (GraphQL at /graphql, metadata at /metadata).
TWENTY_SERVER_URL=http://127.0.0.1:3000

# --- CRM data-layer router (Seam B) ---
# Which backend serves SabCRM records:  rust | twenty   (default rust)
CRM_DATA_LAYER=rust


# ── SabPay (payment gateway) ────────────────────────────────────────────────
# Platform PayU Biz credentials. SabPay runs on SabNode's own PayU account;
# read by the Rust `sabpay` crate (and the legacy Next.js PayU billing flow).
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
# 'test' (test.payu.in) | 'production' (secure.payu.in). Default: test
PAYU_MODE=test
# Base URL of the Rust engine the Next.js app proxies SabPay calls to.
# Default: http://localhost:8080
RUST_API_URL=http://localhost:8080

# SabCRM Suite — new RecordSurface engine for /sabcrm/[objectSlug] (1|all|comma-list of slugs; unset = legacy Twenty page)

# ── SabSites (website builder — vendored Webstudio, mounted at /sites) ──────
# The builder runs inside the Next.js app (src/app/sites). Its data layer is
# Postgres 16 + PostgREST, deliberately separate from MongoDB. Auth is
# unified: the builder trusts the SabNode `session` JWT (JWT_SECRET above).
# Setup: docs/sabsites/README.md  •  Vendored patches: vendor/webstudio/SABNODE-PATCHES.md
# PostgREST endpoint the embedded builder queries (pm2: sabsites-postgrest)
POSTGREST_URL=http://127.0.0.1:4006
# JWT signed with SABSITES_POSTGREST_JWT_SECRET, role claim = sabsites
# (mint with scripts in docs/sabsites/README.md)
POSTGREST_API_KEY=
# Secret PostgREST validates POSTGREST_API_KEY against (>= 32 chars)
SABSITES_POSTGREST_JWT_SECRET=
# Postgres connection for PostgREST + migrations (db: sabsites)
SABSITES_DATABASE_URL=postgres://sabsites:sabsites@localhost:5432/sabsites
# Builder session-cookie secret (Webstudio's own AUTH_SECRET)
AUTH_SECRET=
# Webstudio feature flags / plan limits for all SabSites users
FEATURE_FLAGS=*
PLANS=[{"name":"Pro","features":{"canDownloadAssets":true,"canRestoreBackups":true,"allowAdditionalPermissions":true,"allowDynamicData":true,"allowAuth":true,"allowContentMode":true,"allowStagingPublish":true,"maxContactEmailsPerProject":5,"maxDomainsAllowedPerUser":200,"maxDailyPublishesPerUser":100,"maxProjectsAllowedPerUser":300,"maxAssetsPerProject":350}}]
# SabNode origin shown on the builder's fallback login screen
SABNODE_APP_URL=
# Canonical PUBLIC host the builder uses to build absolute URLs (OAuth
# redirects + p-<projectId> builder subdomains). MUST be set in production so
# the internal bind port (3002) never leaks into public URLs — without it the
# project-builder handshake redirects to sabnode.com:3002 and bounces back to
# the dashboard. Leave UNSET in local dev (keeps host:port from the request).
SABSITES_PUBLIC_HOST=sabnode.com
# Public protocol for those URLs (default https). Only override for plain-HTTP.
# SABSITES_PUBLIC_PROTO=https
# Project builders open on p-<projectId>.<domain> subdomains — production
# needs wildcard DNS + TLS for *.<domain> routed to this app, plus real
# OAuth client credentials for the internal builder handshake:
AUTH_WS_CLIENT_ID=
AUTH_WS_CLIENT_SECRET=
# Optional: S3/R2 asset storage for uploaded media (defaults to Postgres)
# S3_ENDPOINT= S3_REGION= S3_BUCKET= S3_ACCESS_KEY_ID= S3_SECRET_ACCESS_KEY=

# ───────────────────────────── SabMail ──────────────────────────────────
# ─── SabChat (live chat) ─────────────────────────────────────────────────
# Top-level /sabchat module. The realtime backbone + most engines need no env
# beyond the shared Rust API (RUST_API_URL) + CRON_SECRET. These gate the
# newer, optional pieces and ship them dark by default.
#
# Outbound journeys: when 'true' the /api/cron/sabchat-journeys sweep advances
# due runs + delivers the chat channel across every kind:'chat' project. Leave
# 'false' until journeys are in use (the route no-ops while disabled).
SABCHAT_JOURNEYS_ENABLED=false
# Voice / video calling + co-browse (sabchat-voice / sabchat-cobrowse) need a
# TURN/STUN relay to traverse NAT. Provision coturn — services/sabchat-turn/
# (docker compose, host install, or the PM2 `sabchat-turn` app gated on
# SABCHAT_TURN_ENABLED). Without a relay the call UI runs STUN-only.
# SABCHAT_TURN_URL=turn:turn.example.com:3478
# Preferred: a shared secret — the web app mints time-limited TURN creds
# (HMAC-SHA1) that coturn's use-auth-secret verifies. MUST match the relay.
# SABCHAT_TURN_SECRET=
# Set on the relay host (PM2/compose) to supervise coturn + advertise its IP:
# SABCHAT_TURN_ENABLED=false
# SABCHAT_TURN_EXTERNAL_IP=
# SABCHAT_TURN_BIN=turnserver
# Legacy static fallback (used only when SABCHAT_TURN_SECRET is unset):
# SABCHAT_TURN_USER=
# SABCHAT_TURN_CRED=
# SSO / SCIM (sabchat-sso): the org/project SSO settings UI writes SAML/OIDC
# metadata into the tenant config; an external IdP is configured there, not via
# env. SCIM provisioning tokens are minted in-app (no env needed).

# Top-level /sabmail email module (inbox client + sending + automations) and
# its Rust engine (services/sabmail-engine, PM2 app `sabmail-engine`).
#
# Feature flag — when 'true', send/journeys/inbound are owned by the Rust
# engine; when 'false' (default) everything degrades to the in-process path.
SABMAIL_ENABLED=false
# Rust engine HTTP endpoint + shared service token (>=16 chars). The Next
# layer (src/lib/sabmail/engine-client.ts) signs requests with this token.
SABMAIL_ENGINE_URL=http://localhost:4003
SABMAIL_ENGINE_TOKEN=
# Engine bind port (default 4003) + how often the journey ticker fires.
# SABMAIL_PORT=4003
# SABMAIL_JOURNEY_TICK_SECS=60
# 64 hex chars (32 bytes) — AES-256-GCM key for mailbox-credential encryption.
# Falls back to SABSMS_CREDS_KEY when unset. REQUIRED to connect mailboxes.
SABMAIL_CREDS_KEY=
# Public base URL the sync worker / sends use for List-Unsubscribe links + the
# internal bind route. Falls back to NEXT_PUBLIC_APP_URL. Without one, bulk
# mail ships with no one-click List-Unsubscribe (Gmail/Yahoo compliance gap).
SABMAIL_APP_URL=
# HMAC secret for stateless one-click unsubscribe tokens (falls back to
# CRON_SECRET, then SABMAIL_CREDS_KEY). Set a dedicated value in production.
SABMAIL_UNSUB_SECRET=
# ESP SPF include appended to the recommended SPF record (e.g. amazonses.com).
# Server reads SABMAIL_SPF_INCLUDE; the domains UI reads the NEXT_PUBLIC_ copy.
# SABMAIL_SPF_INCLUDE=
# NEXT_PUBLIC_SABMAIL_SPF_INCLUDE=
# Connect external mailboxes via OAuth (one-click "Connect Gmail/Outlook" on
# /sabmail/accounts). The connect flow (/api/sabmail/oauth/authorize+callback)
# stores ONLY an encrypted refresh token; the provider adapters mint access
# tokens on demand. Set the client id/secret and the consent screen + redirect
# URI (https://<host>/api/sabmail/oauth/callback) lights the buttons up.
# Gmail (Google Cloud OAuth client; enable the Gmail API):
# SABMAIL_GMAIL_CLIENT_ID=
# SABMAIL_GMAIL_CLIENT_SECRET=
# SABMAIL_GMAIL_REDIRECT_URI=   # default ${NEXT_PUBLIC_APP_URL}/api/sabmail/oauth/callback
# Gmail push (real-time): a Pub/Sub topic the app calls users.watch() against
# (topic must grant Publish to gmail-api-push@system.gserviceaccount.com).
# SABMAIL_GMAIL_PUBSUB_TOPIC=   # e.g. projects/<proj>/topics/sabmail-gmail
# Outlook/Microsoft (Entra app registration; Graph Mail.ReadWrite/Mail.Send):
# SABMAIL_MS_CLIENT_ID=
# SABMAIL_MS_CLIENT_SECRET=
# SABMAIL_MS_REDIRECT_URI=      # default ${NEXT_PUBLIC_APP_URL}/api/sabmail/oauth/callback
# SABMAIL_MS_AUTHORITY=https://login.microsoftonline.com/common
# NOTE: Graph push subscriptions require a PUBLICLY reachable NEXT_PUBLIC_APP_URL
# (Graph POSTs a validation handshake to /api/push/outlook at subscribe time);
# the /api/cron/sabmail-watch-renewal cron re-arms Gmail watch + Graph subs.
#
# ── Collaborative drafting (optional, degrade-safe) ──────────────────────────
# Collision detection + presence in the composer is ALWAYS on (Mongo-only, no
# config). Real-time CRDT co-editing is an OPTIONAL upgrade that rides the Yjs
# sync gateway (services/sabflow-ws). When the flag is off or JWT_SECRET is
# unset, /api/sabmail/ws-token returns 503 and the composer stays presence-only.
# SABMAIL_COLLAB_ENABLED=false
# NEXT_PUBLIC_SABMAIL_COLLAB_ENABLED=false
# Override the browser's gateway URL (defaults to wss://<host>/sabflow/ws).
# NEXT_PUBLIC_SABMAIL_WS_URL=

# ─────────────────────── SabMail hosted MTA (Stalwart) ──────────────────────
# Self-hosted Stalwart Mail Server box (see deploy/stalwart/) that acts as
# SabMail's outbound submission relay AND inbound MX. This is a standalone OS
# service managed by systemd on its own host (e.g. mail.example.com) — NOT a
# PM2 app and NOT built by deploy.sh. The values below are how the Next.js app
# reaches it.
#
# Mail-host FQDN (== Stalwart [server] hostname, the cert CN, the A/PTR record).
SABMAIL_MAIL_HOST=
# Primary mail domain Stalwart is authoritative for (== its directory domain).
STALWART_DEFAULT_DOMAIN=
# Stalwart management API — bound to 127.0.0.1:8085 on the box; reach it over an
# SSH tunnel for programmatic account/DKIM provisioning. Never expose publicly.
STALWART_ADMIN_URL=http://127.0.0.1:8085
# Admin secret == the Stalwart [authentication.fallback-admin] secret.
# Generate with: openssl rand -base64 24
STALWART_ADMIN_TOKEN=
# Bearer the inbound Sieve/webhook posts to /api/webhooks/sabmail-inbound. The
# route authorizes against this value directly (also accepts CRON_SECRET). Use a
# DEDICATED random secret here (openssl rand -hex 32) — do NOT reuse CRON_SECRET;
# put the same string in deploy/stalwart/inbound-sieve.sieve.
SABMAIL_INBOUND_WEBHOOK_SECRET=
#
# Outbound send now points at the Stalwart SUBMISSION listener (:587 STARTTLS,
# auth required). These are the existing SabMail SMTP-relay vars (sending.ts):
#   SABMAIL_SMTP_HOST=mail.example.com        # == SABMAIL_MAIL_HOST
#   SABMAIL_SMTP_PORT=587                      # 587 STARTTLS (or 465 implicit TLS)
#   SABMAIL_SMTP_USER=sabmail@example.com      # submission account on Stalwart
#   SABMAIL_SMTP_PASS=                         # its password
# Full bring-up runbook: deploy/stalwart/README.md
#
# Optional Meilisearch — when set, SabMail inbox search (src/lib/sabmail/search.ts)
# queries a Meilisearch index first and falls back to live IMAP SEARCH otherwise.
# The `meilisearch` npm package is an optional dep (degrade-safe); install it +
# set these to enable. Unset → SabMail always uses IMAP search (the default).
# MEILISEARCH_URL=http://127.0.0.1:7700
# MEILISEARCH_API_KEY=
