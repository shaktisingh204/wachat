# ─── SabFlow — feature flags (Phase C.8) ─────────────────────────────────
# Enables the multiplayer presence layer (avatar stack, remote cursors,
# typing indicators) in the SabFlow editor. When unset/empty/'0'/'false'
# the editor renders normally and skips the 5-second presence beacon to
# `/api/sabflow/[flowId]/presence`. Set to `1` or `true` to opt in.
NEXT_PUBLIC_SABFLOW_COLLAB_ENABLED=

# Enables the execution step-replay / playback UI on the executions page.
# Off by default. Set to `true` or `1` to enable.
NEXT_PUBLIC_SABFLOW_PLAYBACK_ENABLED=

# Controls the block-marketplace tab in the editor sidebar.
# ON by default — set to `false` or `0` to hide it.
NEXT_PUBLIC_SABFLOW_MARKETPLACE_ENABLED=

# ─── SabFlow — execution / observability (informational) ──────────────────
# These don't require env vars; surfaced here as a reference of features:
#  - /dashboard/sabflow/executions       Execution list + replay
#  - /dashboard/sabflow/links            Multi-bot link dashboard
#  - /api/v1/flows/:id/run               REST API (key auth)
#  - /api/sabflow/api-keys               Mint/revoke v1 API keys
#  - /api/sabflow/env-vars               Workspace-scoped $env.* vars
#  - /api/sabflow/folders                Real folder records

# ─── SabFlow — execution retention cron (/api/cron/sabflow-executions-retention) ──
# Days to keep finished executions before they get pruned by the retention cron.
SABFLOW_EXECUTION_RETENTION_DAYS=90
# Per-flow execution-history cap.  Older rows beyond this count are pruned.
SABFLOW_MAX_EXECUTIONS_PER_FLOW=1000

# ─── Optional: n8n expression engine isolated-vm sandbox ──────────────────
# Set to 'vm' to enable the isolated-vm-backed expression evaluator (more
# secure but heavier).  Anything else uses the legacy evaluator.
N8N_EXPRESSION_ENGINE=

# Whether scripting blocks can read process.env at run-time.  Defaults to
# 'true' (blocked).  Set to 'false' to permit access — only do this in
# trusted single-tenant deployments.
N8N_BLOCK_ENV_ACCESS_IN_NODE=true

# ─── CRM contracts — e-signature flow (§6.2) ─────────────────────────────
# HMAC key used to mint/verify single-use signer tokens for the public
# `/sign/[contractId]/[signerToken]` route. Must be at least 32 random
# bytes; rotate to immediately invalidate every outstanding signing link.
# Generate with `openssl rand -hex 32`.
CONTRACT_SIGNER_SECRET=

# ─── CRM portal — magic-link sign-in (§6.6) ──────────────────────────────
# HMAC key used to mint/verify single-use magic-link tokens for the public
# `/portal/[tenantSlug]/auth/verify?token=...` route. Tokens are valid for
# 15 minutes and consumed once (bookkeeping in `crm_portal_magic_link_uses`).
# Rotate to invalidate every outstanding link. Generate with
# `openssl rand -hex 32`.
PORTAL_MAGIC_LINK_SECRET=

# HMAC key used to mint/verify the `portal_session` cookie that protects
# `/portal/[tenantSlug]/*`. Distinct from the main SabNode `session` cookie
# (different secret + different path scope). 7-day TTL. Generate with
# `openssl rand -hex 32`.
PORTAL_SESSION_SECRET=

# ─── Cron auth ────────────────────────────────────────────────────────────
# Shared secret required for /api/cron/* endpoints. The PM2 `sabnode-cron`
# worker (scripts/cron-worker.mjs) attaches this as `?token=$CRON_SECRET`
# on every scheduled invocation; the routes 401 without it. Generate with
# `openssl rand -hex 32`.
CRON_SECRET=

# Base URL the PM2 cron worker calls to invoke /api/cron/[job].
# Defaults to http://localhost:3000 if unset.
APP_BASE_URL=

# ─── India tax — e-invoice (IRN) + e-way bill (§6.10) ────────────────────
# AES-256-GCM key used to encrypt per-tenant IRP / EWB credentials at rest
# in `crm_india_tax_credentials`. Accepts either 64-char hex or 44-char
# base64 (both decode to 32 bytes). Generate with
# `openssl rand -hex 32`.
INDIA_TAX_ENCRYPTION_KEY=

# Provider creds — wire ONE of the channel partners when going live. The
# `internal` provider (deterministic mock, no network) is the default and
# requires no env vars.
#
# NIC IRP (official Invoice Reporting Portal) — sandbox host
# `einv-apisandbox.nic.in`, prod host `einvoice1.gst.gov.in`.
NIC_IRP_CLIENT_ID=
NIC_IRP_CLIENT_SECRET=
# NIC EWB portal — same auth model, separate creds.
NIC_EWB_CLIENT_ID=
NIC_EWB_CLIENT_SECRET=

# Cleartax channel partner — single bearer token gates both e-invoice + EWB.
CLEARTAX_API_TOKEN=

# Masters India channel partner — OAuth2 client-credentials.
MASTERS_INDIA_CLIENT_ID=
MASTERS_INDIA_CLIENT_SECRET=

# ─── GDPR erase execution gate ────────────────────────────────────────────
# When `true`, `executeEraseRequest` actually mutates rows (redact / hard
# delete). When unset, the action walks the same code path but records
# `executionMode: env_gated_logged_only` and skips mutations — letting ops
# dry-run in prod before flipping the switch.  See docs/ops/gdpr-erasure.md.
GDPR_EXECUTION_ENABLED=

# ============================================================================
# Twenty clone — Postgres dual-DB + staged auth migration (docs/twenty-clone/)
# All default to the SAFE current behaviour; nothing changes until set.
# ============================================================================

# --- SabNode-side Postgres (sabnode_identity schema: users/sessions/auth) ---
# Point at PgBouncer in production. Leave unset until Postgres is provisioned.
SABNODE_PG_URL=
# Per-process pool size (PM2 fork-mode fans out — keep small). Default 10.
SABNODE_PG_POOL_MAX=10

# --- Staged auth migration flags (PLAN.md §3) ---
# Write path:  off | dual | pg-only   (default off)
AUTH_PG_WRITE=off
# Read path:   mongo | pg-fallback | pg   (default mongo)
AUTH_PG_READ=mongo

# --- twenty-server (the cloned Twenty backend, its own Postgres core schema) ---
# Base URL of the running twenty-server (GraphQL at /graphql, metadata at /metadata).
TWENTY_SERVER_URL=http://127.0.0.1:3000

# --- CRM data-layer router (Seam B) ---
# Which backend serves SabCRM records:  rust | twenty   (default rust)
CRM_DATA_LAYER=rust


# ── SabPay (payment gateway) ────────────────────────────────────────────────
# Platform PayU Biz credentials. SabPay runs on SabNode's own PayU account;
# read by the Rust `sabpay` crate (and the legacy Next.js PayU billing flow).
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
# 'test' (test.payu.in) | 'production' (secure.payu.in). Default: test
PAYU_MODE=test
# Base URL of the Rust engine the Next.js app proxies SabPay calls to.
# Default: http://localhost:8080
RUST_API_URL=http://localhost:8080
