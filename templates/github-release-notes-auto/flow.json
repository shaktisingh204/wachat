{
  "schemaVersion": 1,
  "trigger": {
    "id": "t_gh_release",
    "type": "webhook",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "github.release.published",
    "options": {
      "path": "/webhooks/github-release-notes-auto",
      "method": "POST",
      "authentication": "header",
      "authHeaderName": "X-Hub-Signature-256",
      "responseMode": "immediately",
      "enabled": true
    }
  },
  "nodes": [
    {
      "id": "n_trigger",
      "name": "Release Published",
      "type": "n8n-nodes-base.githubTrigger",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": { "events": ["release"], "owner": "={{ $vars.GH_OWNER }}", "repository": "={{ $vars.GH_REPO }}" },
      "credentials": { "githubApi": { "id": "github-cred", "name": "GitHub" } }
    },
    {
      "id": "n_compare",
      "name": "Compare PRs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [240, 0],
      "parameters": {
        "method": "GET",
        "url": "=https://api.github.com/repos/{{ $vars.GH_OWNER }}/{{ $vars.GH_REPO }}/compare/{{ $json.previous_tag }}...{{ $json.release.tag_name }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "githubApi"
      },
      "credentials": { "githubApi": { "id": "github-cred", "name": "GitHub" } }
    },
    {
      "id": "n_summarize",
      "name": "GPT-4o Summarize",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [480, 0],
      "parameters": {
        "resource": "chat",
        "operation": "complete",
        "model": "gpt-4o",
        "messages": {
          "values": [
            { "role": "system", "content": "Write polished release notes from these PR titles. Group by Feature/Fix/Chore." },
            { "role": "user", "content": "={{ JSON.stringify($json.commits) }}" }
          ]
        }
      },
      "credentials": { "openAiApi": { "id": "openai-cred", "name": "OpenAI API" } }
    },
    {
      "id": "n_update_release",
      "name": "Update Release Body",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [720, 0],
      "parameters": {
        "resource": "release",
        "operation": "update",
        "owner": "={{ $vars.GH_OWNER }}",
        "repository": "={{ $vars.GH_REPO }}",
        "releaseId": "={{ $node['Release Published'].json.release.id }}",
        "additionalFields": { "body": "={{ $json.message.content }}" }
      },
      "credentials": { "githubApi": { "id": "github-cred", "name": "GitHub" } }
    },
    {
      "id": "n_slack",
      "name": "Slack #releases",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [960, -120],
      "parameters": {
        "resource": "message",
        "operation": "post",
        "channel": "#releases",
        "text": "=Release shipped: {{ $node['Release Published'].json.release.tag_name }}"
      },
      "credentials": { "slackApi": { "id": "slack-cred", "name": "Slack" } }
    },
    {
      "id": "n_linkedin",
      "name": "LinkedIn Post",
      "type": "n8n-nodes-base.linkedIn",
      "typeVersion": 1,
      "position": [960, 120],
      "parameters": {
        "resource": "post",
        "operation": "create",
        "text": "=New release: {{ $node['Release Published'].json.release.tag_name }} — read the notes."
      },
      "credentials": { "linkedInOAuth2Api": { "id": "linkedin-cred", "name": "LinkedIn" } }
    }
  ],
  "connections": {
    "n_trigger": { "main": [[{ "node": "n_compare", "type": "main", "index": 0 }]] },
    "n_compare": { "main": [[{ "node": "n_summarize", "type": "main", "index": 0 }]] },
    "n_summarize": { "main": [[{ "node": "n_update_release", "type": "main", "index": 0 }]] },
    "n_update_release": {
      "main": [[
        { "node": "n_slack", "type": "main", "index": 0 },
        { "node": "n_linkedin", "type": "main", "index": 0 }
      ]]
    }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Main",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_trigger", "n_compare", "n_summarize", "n_update_release", "n_slack", "n_linkedin"]
    }
  ],
  "variables": [
    { "id": "v_owner", "name": "GH_OWNER", "defaultValue": "your-org" },
    { "id": "v_repo", "name": "GH_REPO", "defaultValue": "your-repo" }
  ],
  "events": [],
  "settings": { "executionOrder": "v1" }
}
