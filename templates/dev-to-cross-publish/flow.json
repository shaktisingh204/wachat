{
  "schemaVersion": 1,
  "trigger": {
    "id": "t_ghost_pub",
    "type": "webhook",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "ghost.post.published",
    "options": {
      "path": "/webhooks/ghost-published-dev",
      "method": "POST",
      "authentication": "header",
      "authHeaderName": "X-Ghost-Token",
      "responseMode": "immediately",
      "enabled": true
    }
  },
  "nodes": [
    {
      "id": "n_webhook",
      "name": "Ghost Published",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": {
        "httpMethod": "POST",
        "path": "ghost-published-dev",
        "responseMode": "onReceived",
        "options": {}
      },
      "webhookId": "ghost-published-dev-webhook"
    },
    {
      "id": "n_extract",
      "name": "Extract Post",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [240, 0],
      "parameters": {
        "values": {
          "string": [
            { "name": "title", "value": "={{ $json.post.current.title }}" },
            { "name": "markdown", "value": "={{ $json.post.current.markdown }}" },
            { "name": "canonical", "value": "={{ $json.post.current.url }}" }
          ]
        }
      }
    },
    {
      "id": "n_create",
      "name": "DEV.to Article Create",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [480, 0],
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.DEVTO_URL }}/api/articles",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "article[title]", "value": "={{ $json.title }}" },
            { "name": "article[body_markdown]", "value": "={{ $json.markdown }}" },
            { "name": "article[canonical_url]", "value": "={{ $json.canonical }}" },
            { "name": "article[published]", "value": "false" }
          ]
        }
      },
      "credentials": { "httpHeaderAuth": { "id": "devto-cred", "name": "DEV.to Header Auth" } }
    },
    {
      "id": "n_capture",
      "name": "Capture Article URL",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [720, 0],
      "parameters": {
        "values": {
          "string": [
            { "name": "articleUrl", "value": "={{ $json.url }}" }
          ]
        }
      }
    },
    {
      "id": "n_slack",
      "name": "Slack #engineering",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [960, 0],
      "parameters": {
        "authentication": "oAuth2",
        "resource": "message",
        "operation": "post",
        "channel": "={{ $vars.SLACK_CHANNEL }}",
        "text": ":memo: Draft on DEV.to: <{{ $json.articleUrl }}|{{ $node['Extract Post'].json.title }}>"
      },
      "credentials": { "slackOAuth2Api": { "id": "slack-cred", "name": "Slack OAuth2" } }
    }
  ],
  "connections": {
    "n_webhook": { "main": [[{ "node": "n_extract", "type": "main", "index": 0 }]] },
    "n_extract": { "main": [[{ "node": "n_create", "type": "main", "index": 0 }]] },
    "n_create": { "main": [[{ "node": "n_capture", "type": "main", "index": 0 }]] },
    "n_capture": { "main": [[{ "node": "n_slack", "type": "main", "index": 0 }]] }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Main",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_webhook", "n_extract", "n_create", "n_capture", "n_slack"]
    }
  ],
  "variables": [
    { "id": "v_url", "name": "DEVTO_URL", "defaultValue": "https://dev.to" },
    { "id": "v_slack", "name": "SLACK_CHANNEL", "defaultValue": "#engineering" }
  ],
  "events": [],
  "settings": { "executionOrder": "v1" }
}
