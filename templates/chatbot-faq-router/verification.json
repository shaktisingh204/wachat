          "status": 200,
          "body": { "choices": [{ "message": { "content": "general" } }] }
        }
      },
      "expect": {
        "finalStatus": "success",
        "executedBlocks": ["n_chat_webhook", "n_ai_classify", "n_switch_intent", "n_faq_general", "n_respond"],
