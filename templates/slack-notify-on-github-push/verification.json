{
  "schemaVersion": 1,
  "templateId": "slack-notify-on-github-push",
  "cases": [
    {
      "id": "happy-path",
      "description": "GitHub push payload — should extract fields and post Slack message.",
      "triggerPayload": {
        "ref": "refs/heads/main",
        "repository": { "full_name": "acme/my-app" },
        "pusher": { "name": "alice" },
        "head_commit": {
          "message": "fix: resolve null pointer on login",
          "url": "https://github.com/acme/my-app/commit/abc123"
        }
      },
      "fixtures": {
        "slack.postMessage": { "status": 200, "body": { "ok": true, "ts": "1716100000.000001" } }
      },
      "expect": {
        "finalStatus": "success",
        "executedBlocks": ["n_github_webhook", "n_set_vars", "n_slack_message"],
        "variables": {
          "repoName": "acme/my-app",
          "pusherName": "alice",
          "branch": "main"
        }
      }
    }
  ]
}
