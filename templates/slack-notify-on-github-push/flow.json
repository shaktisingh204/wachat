{
  "schemaVersion": 1,
  "trigger": {
    "id": "t_github_push_start",
    "type": "webhook",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "github.push",
    "options": {
      "path": "/webhooks/github-push",
      "method": "POST",
      "authentication": "header",
      "authHeaderName": "X-Hub-Signature-256",
      "responseMode": "immediately",
      "enabled": true
    }
  },
  "nodes": [
    {
      "id": "n_github_webhook",
      "name": "GitHub Push Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": {
        "httpMethod": "POST",
        "path": "github-push",
        "responseMode": "onReceived",
        "responseData": "firstEntryJson",
        "options": {}
      },
      "webhookId": "github-push-webhook"
    },
    {
      "id": "n_set_vars",
      "name": "Extract Push Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [240, 0],
      "parameters": {
        "values": {
          "string": [
            { "name": "repoName", "value": "={{ $json.repository.full_name }}" },
            { "name": "pusherName", "value": "={{ $json.pusher.name }}" },
            { "name": "branch", "value": "={{ $json.ref.replace('refs/heads/', '') }}" },
            { "name": "commitMessage", "value": "={{ $json.head_commit.message }}" },
            { "name": "commitUrl", "value": "={{ $json.head_commit.url }}" }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "n_slack_message",
      "name": "Post to Slack",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [480, 0],
      "parameters": {
        "authentication": "oAuth2",
        "resource": "message",
        "operation": "post",
        "channel": "={{ $vars.SLACK_CHANNEL }}",
        "text": ":rocket: *New push to `{{ $json.branch }}`* on <{{ $json.commitUrl }}|{{ $json.repoName }}>\nBy *{{ $json.pusherName }}*: {{ $json.commitMessage }}",
        "otherOptions": {
          "unfurl_links": false,
          "unfurl_media": false
        }
      },
      "credentials": {
        "slackOAuth2Api": { "id": "slack-cred", "name": "Slack OAuth2" }
      }
    }
  ],
  "connections": {
    "n_github_webhook": {
      "main": [[{ "node": "n_set_vars", "type": "main", "index": 0 }]]
    },
    "n_set_vars": {
      "main": [[{ "node": "n_slack_message", "type": "main", "index": 0 }]]
    }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Main",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_github_webhook", "n_set_vars", "n_slack_message"]
    }
  ],
  "variables": [
    { "id": "v_slack_channel", "name": "SLACK_CHANNEL", "defaultValue": "#deployments" }
  ],
  "events": [],
  "settings": {
    "executionOrder": "v1"
  }
}
