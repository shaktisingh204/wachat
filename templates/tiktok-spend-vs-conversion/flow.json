{
  "schemaVersion": 1,
  "trigger": {
    "id": "t_daily",
    "type": "cron",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "cron.tick",
    "options": { "schedule": "0 9 * * *", "enabled": true }
  },
  "nodes": [
    {
      "id": "n_cron",
      "name": "Daily 09:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": { "rule": { "interval": [{ "field": "cronExpression", "expression": "0 9 * * *" }] } }
    },
    {
      "id": "n_tiktok",
      "name": "TikTok Spend",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [240, -120],
      "parameters": {
        "method": "GET",
        "url": "https://business-api.tiktok.com/open_api/v1.3/report/integrated/get/",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "tikTokAdsApi"
      },
      "credentials": { "tikTokAdsApi": { "id": "tt-cred", "name": "TikTok Ads" } }
    },
    {
      "id": "n_shopify",
      "name": "Shopify Orders by UTM",
      "type": "n8n-nodes-base.shopify",
      "typeVersion": 1,
      "position": [240, 120],
      "parameters": { "resource": "order", "operation": "getAll" },
      "credentials": { "shopifyApi": { "id": "shopify-cred", "name": "Shopify" } }
    },
    {
      "id": "n_merge",
      "name": "Merge",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2,
      "position": [480, 0],
      "parameters": { "mode": "combine", "combinationMode": "multiplex" }
    },
    {
      "id": "n_roas",
      "name": "Compute ROAS",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 0],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const spend = $input.first().json.spend ?? 0; const revenue = $input.first().json.revenue ?? 0; const roas = revenue / Math.max(spend, 1); return [{ json: { spend, revenue, roas } }];"
      }
    },
    {
      "id": "n_if",
      "name": "ROAS < 1?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [960, 0],
      "parameters": {
        "conditions": { "number": [{ "value1": "={{ $json.roas }}", "operation": "smaller", "value2": 1 }] }
      }
    },
    {
      "id": "n_slack",
      "name": "Slack #growth",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [1200, -120],
      "parameters": {
        "resource": "message",
        "operation": "post",
        "channel": "#growth",
        "text": "ROAS below 1."
      },
      "credentials": { "slackApi": { "id": "slack-cred", "name": "Slack" } }
    },
    {
      "id": "n_linear",
      "name": "Linear Investigate Ticket",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1200, 0],
      "parameters": {
        "method": "POST",
        "url": "https://api.linear.app/graphql",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "linearApi"
      },
      "credentials": { "linearApi": { "id": "linear-cred", "name": "Linear" } }
    },
    {
      "id": "n_airtable",
      "name": "Airtable Healthy Log",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2,
      "position": [1200, 200],
      "parameters": { "operation": "create", "application": "={{ $vars.AIRTABLE_BASE }}", "table": "tiktok_roas_daily" },
      "credentials": { "airtableTokenApi": { "id": "airtable-cred", "name": "Airtable" } }
    }
  ],
  "connections": {
    "n_cron": {
      "main": [[
        { "node": "n_tiktok", "type": "main", "index": 0 },
        { "node": "n_shopify", "type": "main", "index": 0 }
      ]]
    },
    "n_tiktok": { "main": [[{ "node": "n_merge", "type": "main", "index": 0 }]] },
    "n_shopify": { "main": [[{ "node": "n_merge", "type": "main", "index": 1 }]] },
    "n_merge": { "main": [[{ "node": "n_roas", "type": "main", "index": 0 }]] },
    "n_roas": { "main": [[{ "node": "n_if", "type": "main", "index": 0 }]] },
    "n_if": {
      "true": [[
        { "node": "n_slack", "type": "main", "index": 0 },
        { "node": "n_linear", "type": "main", "index": 0 }
      ]],
      "false": [[{ "node": "n_airtable", "type": "main", "index": 0 }]]
    }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Main",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_cron", "n_tiktok", "n_shopify", "n_merge", "n_roas", "n_if", "n_slack", "n_linear", "n_airtable"]
    }
  ],
  "variables": [
    { "id": "v_b", "name": "AIRTABLE_BASE", "defaultValue": "appXXXXX" }
  ],
  "events": [],
  "settings": { "executionOrder": "v1" }
}
