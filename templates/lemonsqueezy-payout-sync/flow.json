{
  "schemaVersion": 1,
  "trigger": {
    "id": "t_ls_payout",
    "type": "webhook",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "lemonsqueezy.payout",
    "options": {
      "path": "/webhooks/ls-payout",
      "method": "POST",
      "authentication": "header",
      "authHeaderName": "X-LS-Token",
      "responseMode": "immediately",
      "enabled": true
    }
  },
  "nodes": [
    {
      "id": "n_webhook",
      "name": "LS Payout",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": {
        "httpMethod": "POST",
        "path": "ls-payout",
        "responseMode": "onReceived",
        "options": {}
      },
      "webhookId": "ls-payout-webhook"
    },
    {
      "id": "n_extract",
      "name": "Extract Payout",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [240, 0],
      "parameters": {
        "values": {
          "string": [
            { "name": "payoutId", "value": "={{ $json.payout.id }}" },
            { "name": "amount", "value": "={{ $json.payout.amount_cents }}" },
            { "name": "currency", "value": "={{ $json.payout.currency }}" }
          ]
        }
      }
    },
    {
      "id": "n_qb_journal",
      "name": "QuickBooks Journal",
      "type": "n8n-nodes-base.quickBooks",
      "typeVersion": 1,
      "position": [480, -100],
      "parameters": {
        "resource": "journalEntry",
        "operation": "create",
        "lineItems": "={{ [{\"amount\": $json.amount / 100, \"description\": 'LS payout ' + $json.payoutId}] }}"
      },
      "credentials": { "quickBooksOAuth2Api": { "id": "quickbooks-cred", "name": "QuickBooks OAuth2" } }
    },
    {
      "id": "n_slack",
      "name": "Slack #finance",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [480, 100],
      "parameters": {
        "authentication": "oAuth2",
        "resource": "message",
        "operation": "post",
        "channel": "={{ $vars.SLACK_CHANNEL }}",
        "text": ":moneybag: LemonSqueezy payout {{ $json.payoutId }} — {{ $json.amount }} {{ $json.currency }}"
      },
      "credentials": { "slackOAuth2Api": { "id": "slack-cred", "name": "Slack OAuth2" } }
    },
    {
      "id": "n_merge",
      "name": "Merge",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2,
      "position": [720, 0],
      "parameters": { "mode": "combine", "combinationMode": "mergeByPosition" }
    },
    {
      "id": "n_done",
      "name": "Done",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [960, 0],
      "parameters": {}
    }
  ],
  "connections": {
    "n_webhook": { "main": [[{ "node": "n_extract", "type": "main", "index": 0 }]] },
    "n_extract": {
      "main": [
        [
          { "node": "n_qb_journal", "type": "main", "index": 0 },
          { "node": "n_slack", "type": "main", "index": 0 }
        ]
      ]
    },
    "n_qb_journal": { "main": [[{ "node": "n_merge", "type": "main", "index": 0 }]] },
    "n_slack": { "main": [[{ "node": "n_merge", "type": "main", "index": 1 }]] },
    "n_merge": { "main": [[{ "node": "n_done", "type": "main", "index": 0 }]] }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Main",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_webhook", "n_extract", "n_qb_journal", "n_slack", "n_merge", "n_done"]
    }
  ],
  "variables": [
    { "id": "v_slack", "name": "SLACK_CHANNEL", "defaultValue": "#finance" }
  ],
  "events": [],
  "settings": { "executionOrder": "v1" }
}
