{
  "schemaVersion": 1,
  "trigger": {
    "id": "n_trello_trigger",
    "type": "webhook",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "trello.card.create",
    "options": {
      "path": "/webhooks/trello-to-asana-mirror",
      "method": "POST",
      "authentication": "header",
      "authHeaderName": "X-Trello-Webhook",
      "responseMode": "immediately",
      "enabled": true
    }
  },
  "nodes": [
    {
      "id": "n_trello_trigger",
      "name": "Trello Card Created",
      "type": "n8n-nodes-base.trelloTrigger",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": {
        "events": ["createCard"],
        "boardId": "={{ $vars.TRELLO_BOARD_ID }}"
      },
      "credentials": {
        "trelloApi": { "id": "trello-cred", "name": "Trello API" }
      }
    },
    {
      "id": "n_extract_card",
      "name": "Extract Card Fields",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [240, 0],
      "parameters": {
        "values": {
          "string": [
            { "name": "cardId", "value": "={{ $json.action.data.card.id }}" },
            { "name": "cardName", "value": "={{ $json.action.data.card.name }}" },
            { "name": "cardDesc", "value": "={{ $json.action.data.card.desc }}" },
            { "name": "listName", "value": "={{ $json.action.data.list.name }}" }
          ]
        }
      }
    },
    {
      "id": "n_asana_create",
      "name": "Create Asana Task",
      "type": "n8n-nodes-base.asana",
      "typeVersion": 1,
      "position": [480, 0],
      "parameters": {
        "resource": "task",
        "operation": "create",
        "workspace": "={{ $vars.ASANA_WORKSPACE_ID }}",
        "name": "={{ $node['Extract Card Fields'].json.cardName }}",
        "additionalFields": {
          "projects": "={{ $vars.ASANA_PROJECT_ID }}",
          "notes": "Mirrored from Trello list \"{{ $node['Extract Card Fields'].json.listName }}\". Source card: {{ $node['Extract Card Fields'].json.cardId }}.\n\n{{ $node['Extract Card Fields'].json.cardDesc }}"
        }
      },
      "credentials": {
        "asanaApi": { "id": "asana-cred", "name": "Asana API" }
      }
    },
    {
      "id": "n_slack_notify",
      "name": "Slack Mirror Confirm",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [720, 0],
      "parameters": {
        "authentication": "oAuth2",
        "resource": "message",
        "operation": "post",
        "channel": "={{ $vars.SLACK_PM_CHANNEL }}",
        "text": ":arrows_counterclockwise: Mirrored Trello card *{{ $node['Extract Card Fields'].json.cardName }}* into Asana (task {{ $json.gid }})."
      },
      "credentials": {
        "slackOAuth2Api": { "id": "slack-cred", "name": "Slack OAuth2" }
      }
    }
  ],
  "connections": {
    "n_trello_trigger": {
      "main": [[{ "node": "n_extract_card", "type": "main", "index": 0 }]]
    },
    "n_extract_card": {
      "main": [[{ "node": "n_asana_create", "type": "main", "index": 0 }]]
    },
    "n_asana_create": {
      "main": [[{ "node": "n_slack_notify", "type": "main", "index": 0 }]]
    }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Main",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_trello_trigger", "n_extract_card", "n_asana_create", "n_slack_notify"]
    }
  ],
  "variables": [
    { "id": "v_trello_board", "name": "TRELLO_BOARD_ID", "defaultValue": "" },
    { "id": "v_asana_workspace", "name": "ASANA_WORKSPACE_ID", "defaultValue": "" },
    { "id": "v_asana_project", "name": "ASANA_PROJECT_ID", "defaultValue": "" },
    { "id": "v_slack_channel", "name": "SLACK_PM_CHANNEL", "defaultValue": "#pm-ops" }
  ],
  "events": [],
  "settings": {
    "executionOrder": "v1"
  }
}
