{
  "schemaVersion": 1,
  "templateId": "daily-report-email",
  "cases": [
    {
      "id": "happy-path",
      "description": "Cron fires → MongoDB returns aggregated data → email sent successfully.",
      "triggerPayload": {},
      "fixtures": {
        "mongoDb.aggregate": {
          "status": 200,
          "body": [{ "totalCount": 42, "totalRevenue": 8400.5, "avgAmount": 200.01 }]
        },
        "smtp.sendMail": { "status": 200, "body": { "accepted": ["team@example.com"] } }
      },
      "expect": {
        "finalStatus": "success",
        "executedBlocks": ["n_cron_trigger", "n_mongo_query", "n_build_report", "n_send_email"],
        "variables": {}
      }
    },
    {
      "id": "empty-data",
      "description": "No data in MongoDB — report should still send with zero values.",
      "triggerPayload": {},
      "fixtures": {
        "mongoDb.aggregate": { "status": 200, "body": [{}] },
        "smtp.sendMail": { "status": 200, "body": { "accepted": ["team@example.com"] } }
      },
      "expect": {
        "finalStatus": "success",
        "executedBlocks": ["n_cron_trigger", "n_mongo_query", "n_build_report", "n_send_email"],
        "variables": {}
      }
    }
  ]
}
