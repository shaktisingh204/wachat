{
  "schemaVersion": 1,
  "trigger": {
    "id": "t_daily",
    "type": "cron",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "cron.tick",
    "options": { "schedule": "0 7 * * *", "enabled": true }
  },
  "nodes": [
    {
      "id": "n_cron",
      "name": "Daily 07:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": { "rule": { "interval": [{ "field": "cronExpression", "expression": "0 7 * * *" }] } }
    },
    {
      "id": "n_pull",
      "name": "Mailerlite Groups",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [240, 0],
      "parameters": {
        "method": "GET",
        "url": "={{ $vars.MAILERLITE_URL }}/api/v2/groups"
      },
      "credentials": { "httpHeaderAuth": { "id": "mailerlite-cred", "name": "Mailerlite Header Auth" } }
    },
    {
      "id": "n_split",
      "name": "Per Group",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 2,
      "position": [480, 0],
      "parameters": { "batchSize": 1 }
    },
    {
      "id": "n_extract",
      "name": "Extract Group",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [720, 0],
      "parameters": {
        "values": {
          "string": [
            { "name": "groupName", "value": "={{ $json.name }}" },
            { "name": "total", "value": "={{ $json.total }}" },
            { "name": "active", "value": "={{ $json.active }}" }
          ]
        }
      }
    },
    {
      "id": "n_airtable",
      "name": "Airtable Segment Row",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2,
      "position": [960, 0],
      "parameters": {
        "operation": "append",
        "application": "={{ $vars.AIRTABLE_BASE }}",
        "table": "Segments",
        "fields": {
          "Group": "={{ $json.groupName }}",
          "Total": "={{ $json.total }}",
          "Active": "={{ $json.active }}"
        }
      },
      "credentials": { "airtableApi": { "id": "airtable-cred", "name": "Airtable API" } }
    },
    {
      "id": "n_slack",
      "name": "Slack Growth Channel",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [1200, 0],
      "parameters": {
        "authentication": "oAuth2",
        "resource": "message",
        "operation": "post",
        "channel": "={{ $vars.SLACK_CHANNEL }}",
        "text": ":chart_with_upwards_trend: {{ $json.groupName }}: {{ $json.active }}/{{ $json.total }} active"
      },
      "credentials": { "slackOAuth2Api": { "id": "slack-cred", "name": "Slack OAuth2" } }
    }
  ],
  "connections": {
    "n_cron": { "main": [[{ "node": "n_pull", "type": "main", "index": 0 }]] },
    "n_pull": { "main": [[{ "node": "n_split", "type": "main", "index": 0 }]] },
    "n_split": { "main": [[{ "node": "n_extract", "type": "main", "index": 0 }]] },
    "n_extract": { "main": [[{ "node": "n_airtable", "type": "main", "index": 0 }]] },
    "n_airtable": { "main": [[{ "node": "n_slack", "type": "main", "index": 0 }]] }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Main",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_cron", "n_pull", "n_split", "n_extract", "n_airtable", "n_slack"]
    }
  ],
  "variables": [
    { "id": "v_ml", "name": "MAILERLITE_URL", "defaultValue": "https://api.mailerlite.com" },
    { "id": "v_at", "name": "AIRTABLE_BASE", "defaultValue": "" },
    { "id": "v_slack", "name": "SLACK_CHANNEL", "defaultValue": "#growth" }
  ],
  "events": [],
  "settings": { "executionOrder": "v1" }
}
