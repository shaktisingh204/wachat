{
  "schemaVersion": 1,
  "trigger": {
    "id": "n_cron_daily",
    "type": "cron",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "cron.tick",
    "options": { "schedule": "0 8 * * *", "enabled": true }
  },
  "nodes": [
    {
      "id": "n_cron_daily",
      "name": "Daily 8am",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": { "rule": { "interval": [{ "field": "hours", "hoursInterval": 24 }] } }
    },
    {
      "id": "n_mongo_due",
      "name": "Find Recall-Due Patients",
      "type": "n8n-nodes-base.mongoDb",
      "typeVersion": 1,
      "position": [240, 0],
      "parameters": {
        "operation": "find",
        "collection": "patients",
        "query": "{ \"recall_due_days\": { \"$lte\": 7 } }"
      },
      "credentials": { "mongoDb": { "id": "mongo-cred", "name": "Mongo Dental" } }
    },
    {
      "id": "n_split_patients",
      "name": "One Per Patient",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 2,
      "position": [480, 0],
      "parameters": { "batchSize": 1 }
    },
    {
      "id": "n_sms_recall",
      "name": "SMS Recall Reminder",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [720, -80],
      "parameters": {
        "resource": "sms",
        "operation": "send",
        "from": "={{ $vars.TWILIO_FROM_NUMBER }}",
        "to": "={{ $json.phone }}",
        "message": "Hi {{ $json.firstName }}, your six-month dental recall is due. Reply YES to book."
      },
      "credentials": { "twilioApi": { "id": "twilio-cred", "name": "Twilio API" } }
    },
    {
      "id": "n_email_recall",
      "name": "Email Recall Reminder",
      "type": "n8n-nodes-base.sendGrid",
      "typeVersion": 1,
      "position": [720, 80],
      "parameters": {
        "resource": "mail",
        "operation": "send",
        "fromEmail": "={{ $vars.FROM_EMAIL }}",
        "toEmail": "={{ $json.email }}",
        "subject": "Your dental recall is due",
        "contentType": "text/html",
        "content": "<p>Hi {{ $json.firstName }}, please book your six-month visit.</p>"
      },
      "credentials": { "sendGridApi": { "id": "sendgrid-cred", "name": "SendGrid API" } }
    }
  ],
  "connections": {
    "n_cron_daily": { "main": [[{ "node": "n_mongo_due", "type": "main", "index": 0 }]] },
    "n_mongo_due": { "main": [[{ "node": "n_split_patients", "type": "main", "index": 0 }]] },
    "n_split_patients": {
      "main": [
        [
          { "node": "n_sms_recall", "type": "main", "index": 0 },
          { "node": "n_email_recall", "type": "main", "index": 0 }
        ]
      ]
    }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Recall",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": [
        "n_cron_daily",
        "n_mongo_due",
        "n_split_patients",
        "n_sms_recall",
        "n_email_recall"
      ]
    }
  ],
  "variables": [
    { "id": "v_twilio_from", "name": "TWILIO_FROM_NUMBER", "defaultValue": "" },
    { "id": "v_from_email", "name": "FROM_EMAIL", "defaultValue": "front-desk@dental.example.com" }
  ],
  "events": [],
  "settings": { "executionOrder": "v1" }
}
