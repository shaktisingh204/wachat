{
  "schemaVersion": 1,
  "trigger": {
    "id": "t_gumroad_sale",
    "type": "webhook",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "gumroad.sale",
    "options": {
      "path": "/webhooks/gumroad-sale",
      "method": "POST",
      "authentication": "header",
      "authHeaderName": "X-Gumroad-Token",
      "responseMode": "immediately",
      "enabled": true
    }
  },
  "nodes": [
    {
      "id": "n_webhook",
      "name": "Gumroad Sale",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": {
        "httpMethod": "POST",
        "path": "gumroad-sale",
        "responseMode": "onReceived",
        "options": {}
      },
      "webhookId": "gumroad-sale-webhook"
    },
    {
      "id": "n_extract",
      "name": "Extract Order",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [240, 0],
      "parameters": {
        "values": {
          "string": [
            { "name": "buyerEmail", "value": "={{ $json.email }}" },
            { "name": "product", "value": "={{ $json.product_name }}" },
            { "name": "price", "value": "={{ $json.price }}" }
          ]
        }
      }
    },
    {
      "id": "n_sendgrid",
      "name": "SendGrid Thank-You",
      "type": "n8n-nodes-base.sendGrid",
      "typeVersion": 1,
      "position": [480, 0],
      "parameters": {
        "resource": "mail",
        "operation": "send",
        "fromEmail": "={{ $vars.FROM_EMAIL }}",
        "toEmail": "={{ $json.buyerEmail }}",
        "subject": "Thanks for your purchase of {{ $json.product }}",
        "contentType": "text/html",
        "content": "<p>Thanks! Your copy of <strong>{{ $json.product }}</strong> is ready.</p>"
      },
      "credentials": { "sendGridApi": { "id": "sendgrid-cred", "name": "SendGrid API" } }
    },
    {
      "id": "n_slack",
      "name": "Slack #sales",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [720, 0],
      "parameters": {
        "authentication": "oAuth2",
        "resource": "message",
        "operation": "post",
        "channel": "={{ $vars.SLACK_CHANNEL }}",
        "text": ":moneybag: New sale: *{{ $node['Extract Order'].json.product }}* — {{ $node['Extract Order'].json.price }}"
      },
      "credentials": { "slackOAuth2Api": { "id": "slack-cred", "name": "Slack OAuth2" } }
    },
    {
      "id": "n_log",
      "name": "Airtable Receipts",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2,
      "position": [960, 0],
      "parameters": {
        "operation": "append",
        "application": "={{ $vars.AIRTABLE_BASE }}",
        "table": "GumroadSales",
        "fields": { "Email": "={{ $node['Extract Order'].json.buyerEmail }}" }
      },
      "credentials": { "airtableApi": { "id": "airtable-cred", "name": "Airtable API" } }
    }
  ],
  "connections": {
    "n_webhook": { "main": [[{ "node": "n_extract", "type": "main", "index": 0 }]] },
    "n_extract": { "main": [[{ "node": "n_sendgrid", "type": "main", "index": 0 }]] },
    "n_sendgrid": { "main": [[{ "node": "n_slack", "type": "main", "index": 0 }]] },
    "n_slack": { "main": [[{ "node": "n_log", "type": "main", "index": 0 }]] }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Main",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_webhook", "n_extract", "n_sendgrid", "n_slack", "n_log"]
    }
  ],
  "variables": [
    { "id": "v_from", "name": "FROM_EMAIL", "defaultValue": "hello@example.com" },
    { "id": "v_slack", "name": "SLACK_CHANNEL", "defaultValue": "#sales" },
    { "id": "v_at", "name": "AIRTABLE_BASE", "defaultValue": "" }
  ],
  "events": [],
  "settings": { "executionOrder": "v1" }
}
