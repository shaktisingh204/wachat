{
  "schemaVersion": 1,
  "trigger": {
    "id": "n_ft_trigger",
    "type": "webhook",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "fivetran.connector_error",
    "options": {
      "path": "/webhooks/fivetran-error",
      "method": "POST",
      "authentication": "header",
      "authHeaderName": "X-Fivetran-Signature",
      "responseMode": "immediately",
      "enabled": true
    }
  },
  "nodes": [
    {
      "id": "n_ft_trigger",
      "name": "Fivetran Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": {
        "httpMethod": "POST",
        "path": "fivetran-error",
        "responseMode": "onReceived",
        "options": {}
      },
      "webhookId": "fivetran-error-webhook"
    },
    {
      "id": "n_extract_conn",
      "name": "Extract Connector",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [240, 0],
      "parameters": {
        "values": {
          "string": [
            { "name": "connectorId", "value": "={{ $json.data.connector_id }}" },
            { "name": "connectorName", "value": "={{ $json.data.connector_name }}" },
            { "name": "errorReason", "value": "={{ $json.data.reason }}" }
          ]
        }
      }
    },
    {
      "id": "n_fetch_details",
      "name": "Fetch Connector Details",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [480, 0],
      "parameters": {
        "method": "GET",
        "url": "={{ $vars.FIVETRAN_API }}/v1/connectors/{{ $json.connectorId }}"
      },
      "credentials": { "httpBasicAuth": { "id": "ft-cred", "name": "Fivetran" } }
    },
    {
      "id": "n_dedupe",
      "name": "Dedupe 1h Window",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [600, 0],
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.DEDUPE_URL }}",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "key", "value": "fivetran-{{ $json.connectorId }}" },
            { "name": "ttlSeconds", "value": "3600" }
          ]
        }
      }
    },
    {
      "id": "n_slack_data",
      "name": "Slack #data",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [720, -80],
      "parameters": {
        "authentication": "oAuth2",
        "resource": "message",
        "operation": "post",
        "channel": "={{ $vars.SLACK_DATA_CHANNEL }}",
        "text": ":exclamation: Fivetran {{ $json.connectorName }} failed: {{ $json.errorReason }}.",
        "otherOptions": {}
      },
      "credentials": { "slackOAuth2Api": { "id": "slack-cred", "name": "Slack OAuth2" } }
    },
    {
      "id": "n_linear_bug",
      "name": "Linear Bug",
      "type": "n8n-nodes-base.linear",
      "typeVersion": 1,
      "position": [720, 80],
      "parameters": {
        "resource": "issue",
        "operation": "create",
        "teamId": "={{ $vars.LINEAR_API_TEAM }}",
        "title": "Fivetran failure: {{ $json.connectorName }}",
        "description": "Reason: {{ $json.errorReason }}"
      },
      "credentials": { "linearApi": { "id": "linear-cred", "name": "Linear API" } }
    }
  ],
  "connections": {
    "n_ft_trigger": { "main": [[{ "node": "n_extract_conn", "type": "main", "index": 0 }]] },
    "n_extract_conn": { "main": [[{ "node": "n_fetch_details", "type": "main", "index": 0 }]] },
    "n_fetch_details": { "main": [[{ "node": "n_dedupe", "type": "main", "index": 0 }]] },
    "n_dedupe": {
      "main": [
        [
          { "node": "n_slack_data", "type": "main", "index": 0 },
          { "node": "n_linear_bug", "type": "main", "index": 0 }
        ]
      ]
    }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Fivetran",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_ft_trigger", "n_extract_conn", "n_fetch_details", "n_dedupe", "n_slack_data", "n_linear_bug"]
    }
  ],
  "variables": [
    { "id": "v_ft", "name": "FIVETRAN_API", "defaultValue": "https://api.fivetran.com" },
    { "id": "v_dedupe", "name": "DEDUPE_URL", "defaultValue": "https://dedupe.example.com/check" },
    { "id": "v_slack", "name": "SLACK_DATA_CHANNEL", "defaultValue": "#data" },
    { "id": "v_team", "name": "LINEAR_API_TEAM", "defaultValue": "" }
  ],
  "events": [],
  "settings": { "executionOrder": "v1" }
}
