{
  "schemaVersion": 1,
  "trigger": {
    "id": "t_github_issue",
    "type": "webhook",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "github.issues.opened",
    "options": {
      "path": "/webhooks/github-issue-to-linear",
      "method": "POST",
      "authentication": "header",
      "authHeaderName": "X-Hub-Signature-256",
      "responseMode": "immediately",
      "enabled": true
    }
  },
  "nodes": [
    {
      "id": "n_github_issue_trigger",
      "name": "GitHub Issue Opened",
      "type": "n8n-nodes-base.githubTrigger",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": {
        "owner": "={{ $vars.GITHUB_OWNER }}",
        "repository": "={{ $vars.GITHUB_REPO }}",
        "events": ["issues"]
      },
      "credentials": {
        "githubApi": { "id": "github-cred", "name": "GitHub API" }
      }
    },
    {
      "id": "n_filter_opened",
      "name": "Filter: Opened Only",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [240, 0],
      "parameters": {
        "conditions": {
          "string": [{ "value1": "={{ $json.action }}", "operation": "equal", "value2": "opened" }]
        }
      }
    },
    {
      "id": "n_map_issue",
      "name": "Map Issue Fields",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [480, 0],
      "parameters": {
        "values": {
          "string": [
            { "name": "title", "value": "=[GH #{{ $json.issue.number }}] {{ $json.issue.title }}" },
            { "name": "description", "value": "={{ $json.issue.body }}\n\n---\n_Mirrored from GitHub: {{ $json.issue.html_url }}_" },
            { "name": "githubUrl", "value": "={{ $json.issue.html_url }}" },
            { "name": "githubNumber", "value": "={{ $json.issue.number }}" },
            { "name": "reporter", "value": "={{ $json.issue.user.login }}" }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "n_create_linear_issue",
      "name": "Create Linear Issue",
      "type": "n8n-nodes-base.linear",
      "typeVersion": 1,
      "position": [720, 0],
      "parameters": {
        "authentication": "apiKey",
        "resource": "issue",
        "operation": "create",
        "teamId": "={{ $vars.LINEAR_TEAM_ID }}",
        "title": "={{ $json.title }}",
        "additionalFields": {
          "description": "={{ $json.description }}",
          "labelIds": ["={{ $vars.LINEAR_GITHUB_LABEL_ID }}"]
        }
      },
      "credentials": {
        "linearApi": { "id": "linear-cred", "name": "Linear API" }
      }
    },
    {
      "id": "n_comment_on_github",
      "name": "Comment on GitHub Issue",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [960, 0],
      "parameters": {
        "authentication": "oAuth2",
        "resource": "issue",
        "operation": "createComment",
        "owner": "={{ $vars.GITHUB_OWNER }}",
        "repository": "={{ $vars.GITHUB_REPO }}",
        "issueNumber": "={{ $node['Map Issue Fields'].json.githubNumber }}",
        "body": "=:link: This issue has been tracked in Linear: {{ $json.url }}"
      },
      "credentials": {
        "githubOAuth2Api": { "id": "github-oauth-cred", "name": "GitHub OAuth2" }
      }
    }
  ],
  "connections": {
    "n_github_issue_trigger": {
      "main": [[{ "node": "n_filter_opened", "type": "main", "index": 0 }]]
    },
    "n_filter_opened": {
      "main": [
        [{ "node": "n_map_issue", "type": "main", "index": 0 }],
        []
      ]
    },
    "n_map_issue": {
      "main": [[{ "node": "n_create_linear_issue", "type": "main", "index": 0 }]]
    },
    "n_create_linear_issue": {
      "main": [[{ "node": "n_comment_on_github", "type": "main", "index": 0 }]]
    }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Main",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_github_issue_trigger", "n_filter_opened", "n_map_issue", "n_create_linear_issue", "n_comment_on_github"]
    }
  ],
  "variables": [
    { "id": "v_gh_owner", "name": "GITHUB_OWNER", "defaultValue": "" },
    { "id": "v_gh_repo", "name": "GITHUB_REPO", "defaultValue": "" },
    { "id": "v_linear_team", "name": "LINEAR_TEAM_ID", "defaultValue": "" },
    { "id": "v_linear_label", "name": "LINEAR_GITHUB_LABEL_ID", "defaultValue": "" }
  ],
  "events": [],
  "settings": {
    "executionOrder": "v1"
  }
}
