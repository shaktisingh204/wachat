{
  "schemaVersion": 1,
  "trigger": {
    "id": "t_email_remind",
    "type": "webhook",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "superhuman.reminder",
    "options": {
      "path": "/webhooks/superhuman-reminder",
      "method": "POST",
      "authentication": "header",
      "authHeaderName": "X-SH-Token",
      "responseMode": "immediately",
      "enabled": true
    }
  },
  "nodes": [
    {
      "id": "n_webhook",
      "name": "Email Reminder",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": {
        "httpMethod": "POST",
        "path": "superhuman-reminder",
        "responseMode": "onReceived",
        "options": {}
      },
      "webhookId": "superhuman-reminder-webhook"
    },
    {
      "id": "n_extract",
      "name": "Extract Email",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [240, 0],
      "parameters": {
        "values": {
          "string": [
            { "name": "subject", "value": "={{ $json.email.subject }}" },
            { "name": "fromAddr", "value": "={{ $json.email.from }}" },
            { "name": "threadUrl", "value": "={{ $json.email.url }}" }
          ]
        }
      }
    },
    {
      "id": "n_check",
      "name": "Format Nudge",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [480, 0],
      "parameters": {
        "values": {
          "string": [
            { "name": "nudge", "value": ":bell: Follow up: <{{ $json.threadUrl }}|{{ $json.subject }}> — from {{ $json.fromAddr }}" }
          ]
        }
      }
    },
    {
      "id": "n_slack",
      "name": "Slack #sales-followup",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [720, 0],
      "parameters": {
        "authentication": "oAuth2",
        "resource": "message",
        "operation": "post",
        "channel": "={{ $vars.SLACK_CHANNEL }}",
        "text": "={{ $json.nudge }}"
      },
      "credentials": { "slackOAuth2Api": { "id": "slack-cred", "name": "Slack OAuth2" } }
    },
    {
      "id": "n_log",
      "name": "Airtable Log",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2,
      "position": [960, 0],
      "parameters": {
        "operation": "append",
        "application": "={{ $vars.AIRTABLE_BASE }}",
        "table": "Followups",
        "fields": { "Subject": "={{ $node['Extract Email'].json.subject }}" }
      },
      "credentials": { "airtableApi": { "id": "airtable-cred", "name": "Airtable API" } }
    }
  ],
  "connections": {
    "n_webhook": { "main": [[{ "node": "n_extract", "type": "main", "index": 0 }]] },
    "n_extract": { "main": [[{ "node": "n_check", "type": "main", "index": 0 }]] },
    "n_check": { "main": [[{ "node": "n_slack", "type": "main", "index": 0 }]] },
    "n_slack": { "main": [[{ "node": "n_log", "type": "main", "index": 0 }]] }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Main",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_webhook", "n_extract", "n_check", "n_slack", "n_log"]
    }
  ],
  "variables": [
    { "id": "v_slack", "name": "SLACK_CHANNEL", "defaultValue": "#sales-followup" },
    { "id": "v_at", "name": "AIRTABLE_BASE", "defaultValue": "" }
  ],
  "events": [],
  "settings": { "executionOrder": "v1" }
}
