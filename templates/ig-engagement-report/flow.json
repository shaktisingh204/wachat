{
  "schemaVersion": 1,
  "trigger": {
    "id": "t_weekly",
    "type": "cron",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "cron.tick",
    "options": { "schedule": "0 8 * * 1", "enabled": true }
  },
  "nodes": [
    {
      "id": "n_cron",
      "name": "Monday 08:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": { "rule": { "interval": [{ "field": "cronExpression", "expression": "0 8 * * 1" }] } }
    },
    {
      "id": "n_ig",
      "name": "Instagram Graph Metrics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [240, 0],
      "parameters": {
        "method": "GET",
        "url": "=https://graph.facebook.com/v19.0/{{ $vars.IG_USER_ID }}/insights",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "facebookGraphApi"
      },
      "credentials": { "facebookGraphApi": { "id": "fb-cred", "name": "Meta Graph API" } }
    },
    {
      "id": "n_rollup",
      "name": "Rollup Metrics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 0],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const rows = $input.first().json.data || []; return [{ json: { reach: rows[0]?.values?.[0]?.value ?? 0, engagement: rows[1]?.values?.[0]?.value ?? 0, saves: rows[2]?.values?.[0]?.value ?? 0 } }];"
      }
    },
    {
      "id": "n_pdf",
      "name": "Render PDF",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [720, 0],
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.PDF_RENDER_URL }}",
        "sendBody": true
      }
    },
    {
      "id": "n_slack",
      "name": "Slack #social",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [960, -120],
      "parameters": {
        "resource": "message",
        "operation": "post",
        "channel": "#social",
        "text": "Weekly IG report ready."
      },
      "credentials": { "slackApi": { "id": "slack-cred", "name": "Slack" } }
    },
    {
      "id": "n_email",
      "name": "Email CMO",
      "type": "n8n-nodes-base.sendGrid",
      "typeVersion": 1,
      "position": [960, 120],
      "parameters": {
        "resource": "mail",
        "operation": "send",
        "fromEmail": "social@example.com",
        "toEmail": "cmo@example.com",
        "subject": "Weekly Instagram engagement",
        "content": "Attached: PDF."
      },
      "credentials": { "sendGridApi": { "id": "sendgrid-cred", "name": "SendGrid" } }
    }
  ],
  "connections": {
    "n_cron": { "main": [[{ "node": "n_ig", "type": "main", "index": 0 }]] },
    "n_ig": { "main": [[{ "node": "n_rollup", "type": "main", "index": 0 }]] },
    "n_rollup": { "main": [[{ "node": "n_pdf", "type": "main", "index": 0 }]] },
    "n_pdf": {
      "main": [[
        { "node": "n_slack", "type": "main", "index": 0 },
        { "node": "n_email", "type": "main", "index": 0 }
      ]]
    }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Main",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_cron", "n_ig", "n_rollup", "n_pdf", "n_slack", "n_email"]
    }
  ],
  "variables": [
    { "id": "v_u", "name": "IG_USER_ID", "defaultValue": "" },
    { "id": "v_pdf", "name": "PDF_RENDER_URL", "defaultValue": "https://pdf.example.com/render" }
  ],
  "events": [],
  "settings": { "executionOrder": "v1" }
}
