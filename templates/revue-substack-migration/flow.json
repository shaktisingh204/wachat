{
  "schemaVersion": 1,
  "trigger": {
    "id": "t_revue_export",
    "type": "webhook",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "revue.export.ready",
    "options": {
      "path": "/webhooks/revue-export",
      "method": "POST",
      "authentication": "header",
      "authHeaderName": "X-Revue-Token",
      "responseMode": "immediately",
      "enabled": true
    }
  },
  "nodes": [
    {
      "id": "n_webhook",
      "name": "Revue Export Ready",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": {
        "httpMethod": "POST",
        "path": "revue-export",
        "responseMode": "onReceived",
        "options": {}
      },
      "webhookId": "revue-export-webhook"
    },
    {
      "id": "n_extract",
      "name": "Extract Export URL",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [240, 0],
      "parameters": {
        "values": {
          "string": [
            { "name": "exportUrl", "value": "={{ $json.export.url }}" }
          ]
        }
      }
    },
    {
      "id": "n_fetch",
      "name": "Fetch CSV",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [480, 0],
      "parameters": { "method": "GET", "url": "={{ $json.exportUrl }}" }
    },
    {
      "id": "n_split",
      "name": "Split Rows",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 2,
      "position": [720, 0],
      "parameters": { "batchSize": 1 }
    },
    {
      "id": "n_substack",
      "name": "Substack Add Subscriber",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [960, 0],
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.SUBSTACK_URL }}/api/v1/publication/subscribers",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "email", "value": "={{ $json.email }}" },
            { "name": "firstName", "value": "={{ $json.first_name }}" }
          ]
        }
      },
      "credentials": { "httpHeaderAuth": { "id": "substack-cred", "name": "Substack Header Auth" } }
    },
    {
      "id": "n_log",
      "name": "Airtable Migration Log",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2,
      "position": [1200, 0],
      "parameters": {
        "operation": "append",
        "application": "={{ $vars.AIRTABLE_BASE }}",
        "table": "Migration",
        "fields": { "Email": "={{ $json.email }}" }
      },
      "credentials": { "airtableApi": { "id": "airtable-cred", "name": "Airtable API" } }
    }
  ],
  "connections": {
    "n_webhook": { "main": [[{ "node": "n_extract", "type": "main", "index": 0 }]] },
    "n_extract": { "main": [[{ "node": "n_fetch", "type": "main", "index": 0 }]] },
    "n_fetch": { "main": [[{ "node": "n_split", "type": "main", "index": 0 }]] },
    "n_split": { "main": [[{ "node": "n_substack", "type": "main", "index": 0 }]] },
    "n_substack": { "main": [[{ "node": "n_log", "type": "main", "index": 0 }]] }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Main",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_webhook", "n_extract", "n_fetch", "n_split", "n_substack", "n_log"]
    }
  ],
  "variables": [
    { "id": "v_ss", "name": "SUBSTACK_URL", "defaultValue": "https://substack.com" },
    { "id": "v_at", "name": "AIRTABLE_BASE", "defaultValue": "" }
  ],
  "events": [],
  "settings": { "executionOrder": "v1" }
}
