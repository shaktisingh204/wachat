{
  "schemaVersion": 1,
  "trigger": {
    "id": "t_drift",
    "type": "webhook",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "drift.conversation.routed",
    "options": {
      "path": "/webhooks/drift-routed",
      "method": "POST",
      "enabled": true
    }
  },
  "nodes": [
    {
      "id": "n_webhook",
      "name": "Drift Routed",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": {
        "httpMethod": "POST",
        "path": "drift-routed",
        "responseMode": "onReceived"
      },
      "webhookId": "drift-routed-webhook"
    },
    {
      "id": "n_extract",
      "name": "Extract Context",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [240, 0],
      "parameters": {
        "values": {
          "string": [
            { "name": "conversationId", "value": "={{ $json.data.conversationId }}" },
            { "name": "visitorEmail", "value": "={{ $json.data.contact.email }}" },
            { "name": "transcript", "value": "={{ $json.data.transcript }}" }
          ]
        }
      }
    },
    {
      "id": "n_slack",
      "name": "Post to #live-support",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [480, -150],
      "parameters": {
        "authentication": "oAuth2",
        "resource": "message",
        "operation": "post",
        "channel": "={{ $vars.LIVE_SUPPORT_CHANNEL }}",
        "text": ":bell: Drift handoff {{ $json.conversationId }}\n{{ $json.transcript }}"
      },
      "credentials": {
        "slackOAuth2Api": { "id": "slack-cred", "name": "Slack OAuth2" }
      }
    },
    {
      "id": "n_hubspot",
      "name": "Tag HubSpot Contact",
      "type": "n8n-nodes-base.hubspot",
      "typeVersion": 2,
      "position": [480, 0],
      "parameters": {
        "resource": "contact",
        "operation": "update",
        "email": "={{ $json.visitorEmail }}",
        "additionalFields": {
          "lifecycleStage": "salesQualifiedLead"
        }
      },
      "credentials": {
        "hubspotApi": { "id": "hubspot-cred", "name": "HubSpot API" }
      }
    },
    {
      "id": "n_sendgrid",
      "name": "ETA Email",
      "type": "n8n-nodes-base.sendGrid",
      "typeVersion": 1,
      "position": [480, 150],
      "parameters": {
        "resource": "mail",
        "operation": "send",
        "fromEmail": "={{ $vars.FROM_EMAIL }}",
        "toEmail": "={{ $json.visitorEmail }}",
        "subject": "An agent is on the way",
        "contentType": "text/plain",
        "content": "A live agent will reply within 5 minutes."
      },
      "credentials": {
        "sendGridApi": { "id": "sendgrid-cred", "name": "SendGrid" }
      }
    },
    {
      "id": "n_mongo",
      "name": "Mongo Handoff Log",
      "type": "n8n-nodes-base.mongoDb",
      "typeVersion": 1,
      "position": [720, 0],
      "parameters": {
        "operation": "insert",
        "collection": "drift_handoffs",
        "fields": "conversationId,visitorEmail,handoffAt"
      },
      "credentials": {
        "mongoDb": { "id": "mongo-cred", "name": "MongoDB" }
      }
    }
  ],
  "connections": {
    "n_webhook": { "main": [[{ "node": "n_extract", "type": "main", "index": 0 }]] },
    "n_extract": {
      "main": [
        [
          { "node": "n_slack", "type": "main", "index": 0 },
          { "node": "n_hubspot", "type": "main", "index": 0 },
          { "node": "n_sendgrid", "type": "main", "index": 0 }
        ]
      ]
    },
    "n_slack": { "main": [[{ "node": "n_mongo", "type": "main", "index": 0 }]] },
    "n_hubspot": { "main": [[{ "node": "n_mongo", "type": "main", "index": 0 }]] },
    "n_sendgrid": { "main": [[{ "node": "n_mongo", "type": "main", "index": 0 }]] }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Main",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_webhook", "n_extract", "n_slack", "n_hubspot", "n_sendgrid", "n_mongo"]
    }
  ],
  "variables": [
    { "id": "v_chan", "name": "LIVE_SUPPORT_CHANNEL", "defaultValue": "#live-support" },
    { "id": "v_from", "name": "FROM_EMAIL", "defaultValue": "support@example.com" }
  ],
  "events": [],
  "settings": { "executionOrder": "v1" }
}
