{
  "schemaVersion": 1,
  "trigger": {
    "id": "t_gh_offer",
    "type": "webhook",
    "graphCoordinates": { "x": 0, "y": 0 },
    "appEvent": "greenhouse.offer.extended",
    "options": {
      "path": "/webhooks/greenhouse-offer",
      "method": "POST",
      "enabled": true
    }
  },
  "nodes": [
    {
      "id": "n_webhook",
      "name": "Greenhouse Offer Extended",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": {
        "httpMethod": "POST",
        "path": "greenhouse-offer",
        "responseMode": "onReceived"
      },
      "webhookId": "gh-offer-webhook"
    },
    {
      "id": "n_extract",
      "name": "Extract Offer",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [240, 0],
      "parameters": {
        "values": {
          "string": [
            { "name": "candidateName", "value": "={{ $json.candidate.name }}" },
            { "name": "candidateEmail", "value": "={{ $json.candidate.email }}" },
            { "name": "role", "value": "={{ $json.job.title }}" },
            { "name": "salary", "value": "={{ $json.offer.salary }}" },
            { "name": "startDate", "value": "={{ $json.offer.startDate }}" }
          ]
        }
      }
    },
    {
      "id": "n_openai",
      "name": "GPT-4o Draft Letter",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [480, 0],
      "parameters": {
        "resource": "chat",
        "operation": "complete",
        "model": "gpt-4o",
        "messages": {
          "values": [
            { "role": "system", "content": "Write a warm, professional offer letter (no markdown)." },
            { "role": "user", "content": "Name: {{ $json.candidateName }}\nRole: {{ $json.role }}\nSalary: {{ $json.salary }}\nStart: {{ $json.startDate }}" }
          ]
        },
        "options": { "temperature": 0.3 }
      },
      "credentials": {
        "openAiApi": { "id": "openai-cred", "name": "OpenAI API" }
      }
    },
    {
      "id": "n_docusign",
      "name": "Create DocuSign Envelope",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [720, 0],
      "parameters": {
        "method": "POST",
        "url": "=https://{{ $vars.DOCUSIGN_HOST }}/restapi/v2.1/accounts/{{ $vars.DOCUSIGN_ACCOUNT }}/envelopes",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "emailSubject", "value": "Your offer letter" },
            { "name": "status", "value": "sent" },
            { "name": "documents[0].name", "value": "Offer.txt" },
            { "name": "documents[0].documentBase64", "value": "={{ Buffer.from($json.message.content).toString('base64') }}" }
          ]
        }
      },
      "credentials": {
        "httpHeaderAuth": { "id": "docusign-cred", "name": "DocuSign JWT" }
      }
    },
    {
      "id": "n_sendgrid",
      "name": "Email Candidate",
      "type": "n8n-nodes-base.sendGrid",
      "typeVersion": 1,
      "position": [960, 0],
      "parameters": {
        "resource": "mail",
        "operation": "send",
        "fromEmail": "={{ $vars.FROM_EMAIL }}",
        "toEmail": "={{ $node['Extract Offer'].json.candidateEmail }}",
        "subject": "Your offer letter is ready",
        "contentType": "text/html",
        "content": "<p>Hi {{ $node['Extract Offer'].json.candidateName }}, please review and sign the envelope sent via DocuSign.</p>"
      },
      "credentials": {
        "sendGridApi": { "id": "sendgrid-cred", "name": "SendGrid" }
      }
    },
    {
      "id": "n_mongo_archive",
      "name": "Archive Letter to Mongo",
      "type": "n8n-nodes-base.mongoDb",
      "typeVersion": 1,
      "position": [1200, 120],
      "parameters": {
        "operation": "insert",
        "collection": "offer_letters",
        "fields": "candidateEmail,role,letterBody"
      },
      "credentials": {
        "mongoDb": { "id": "mongo-cred", "name": "MongoDB" }
      }
    },
    {
      "id": "n_slack",
      "name": "Slack #recruiting",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [1200, 0],
      "parameters": {
        "authentication": "oAuth2",
        "resource": "message",
        "operation": "post",
        "channel": "={{ $vars.RECRUITING_CHANNEL }}",
        "text": ":scroll: Offer letter sent to {{ $node['Extract Offer'].json.candidateName }} ({{ $node['Extract Offer'].json.role }})"
      },
      "credentials": {
        "slackOAuth2Api": { "id": "slack-cred", "name": "Slack OAuth2" }
      }
    }
  ],
  "connections": {
    "n_webhook": { "main": [[{ "node": "n_extract", "type": "main", "index": 0 }]] },
    "n_extract": { "main": [[{ "node": "n_openai", "type": "main", "index": 0 }]] },
    "n_openai": { "main": [[{ "node": "n_docusign", "type": "main", "index": 0 }]] },
    "n_docusign": { "main": [[{ "node": "n_sendgrid", "type": "main", "index": 0 }]] },
    "n_sendgrid": {
      "main": [
        [
          { "node": "n_mongo_archive", "type": "main", "index": 0 },
          { "node": "n_slack", "type": "main", "index": 0 }
        ]
      ]
    }
  },
  "groups": [
    {
      "id": "g_main",
      "title": "Main",
      "graphCoordinates": { "x": 0, "y": 0 },
      "blockIds": ["n_webhook", "n_extract", "n_openai", "n_docusign", "n_sendgrid", "n_mongo_archive", "n_slack"]
    }
  ],
  "variables": [
    { "id": "v_ds_host", "name": "DOCUSIGN_HOST", "defaultValue": "demo.docusign.net" },
    { "id": "v_ds_acct", "name": "DOCUSIGN_ACCOUNT", "defaultValue": "" },
    { "id": "v_from", "name": "FROM_EMAIL", "defaultValue": "recruiting@example.com" },
    { "id": "v_recruit", "name": "RECRUITING_CHANNEL", "defaultValue": "#recruiting" }
  ],
  "events": [],
  "settings": { "executionOrder": "v1" }
}
