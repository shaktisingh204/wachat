# =============================================================================
# SabNode Rust API — example environment file
#
# Copy to `.env` (the binary loads it via `dotenvy` in dev) or supply each
# variable through your orchestrator (systemd `EnvironmentFile=`, Fly.io
# `flyctl secrets set`, Kubernetes Secrets, etc.) in production.
# =============================================================================

# ---- HTTP server -------------------------------------------------------------

# TCP port the Axum server binds to. Match the EXPOSE in rust/Dockerfile.
SABNODE_PORT=8080

# Deployment environment. Accepted: dev | staging | production.
# Selects the JSON formatter (prod) vs the pretty formatter (dev) in
# `sabnode-observability::init_telemetry`.
SABNODE_ENV=dev

# Application-level log level used by internal helpers that don't read RUST_LOG
# directly (e.g. health probes, structured audit logs).
SABNODE_LOG_LEVEL=info

# `tracing-subscriber` env-filter directive. Overrides SABNODE_LOG_LEVEL for the
# global subscriber. See https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html
RUST_LOG=info,sabnode=debug

# ---- Data stores -------------------------------------------------------------

# MongoDB connection URI. Same env name as the Node side
# (`src/lib/mongodb.ts` reads `process.env.MONGODB_URI`).
MONGODB_URI=mongodb://localhost:27017

# MongoDB database name. Same env name as the Node side
# (`src/lib/mongodb.ts` reads `process.env.MONGODB_DB`).
MONGODB_DB=app1

# Redis connection URL. Same env name as the Node side
# (`src/lib/redis.ts` reads `process.env.REDIS_URL`).
REDIS_URL=redis://localhost:6379

# ---- Auth --------------------------------------------------------------------

# HMAC secret used to sign / verify the Rust service's JWTs. MUST be at least
# 32 bytes. Rotate via your secret manager — never commit a real value.
RUST_JWT_SECRET=changeme-32-bytes-min

# ---- Observability (OpenTelemetry) ------------------------------------------

# OTLP/HTTP collector endpoint. Must point at the SAME collector that the
# Node.js app exports to via `@opentelemetry/exporter-trace-otlp-http`.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# `service.name` resource attribute attached to every exported span.
OTEL_SERVICE_NAME=sabnode-api
