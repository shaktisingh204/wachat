{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@n8n/errors": [
        "./src/lib/sabflow/n8n/internal/errors"
      ],
      "@n8n/errors/*": [
        "./src/lib/sabflow/n8n/internal/errors/*"
      ],
      "@n8n/di": [
        "./src/lib/sabflow/n8n/internal/di/di"
      ],
      "@n8n/constants": [
        "./src/lib/sabflow/n8n/internal/constants"
      ],
      "@n8n/constants/*": [
        "./src/lib/sabflow/n8n/internal/constants/*"
      ],
      "n8n-workflow": [
        "./src/lib/sabflow/n8n"
      ],
      "n8n-workflow/*": [
        "./src/lib/sabflow/n8n/*"
      ],
      "@n8n/expression-runtime": [
        "./src/lib/sabflow/n8n/internal/expression-runtime"
      ],
      "@n8n/expression-runtime/*": [
        "./src/lib/sabflow/n8n/internal/expression-runtime/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "src/types/**/*.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}