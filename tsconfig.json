{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@n8n/errors": [
        "./src/lib/sabflow/n8n/internal/errors"
      ],
      "@n8n/errors/*": [
        "./src/lib/sabflow/n8n/internal/errors/*"
      ],
      "@n8n/di": [
        "./src/lib/sabflow/n8n/internal/di/di"
      ],
      "@n8n/constants": [
        "./src/lib/sabflow/n8n/internal/constants"
      ],
      "@n8n/constants/*": [
        "./src/lib/sabflow/n8n/internal/constants/*"
      ],
      "n8n-workflow": [
        "./src/lib/sabflow/n8n"
      ],
      "n8n-workflow/*": [
        "./src/lib/sabflow/n8n/*"
      ],
      "@n8n-core/*": [
        "./src/lib/sabflow/n8n/core/*"
      ],
      "@n8n/backend-common": [
        "./src/lib/sabflow/n8n/internal/backend-common"
      ],
      "@n8n/decorators": [
        "./src/lib/sabflow/n8n/internal/decorators"
      ],
      "@n8n/config": [
        "./src/lib/sabflow/n8n/internal/config"
      ],
      "@n8n/config/*": [
        "./src/lib/sabflow/n8n/internal/config/*"
      ],
      "@n8n/client-oauth2": [
        "./src/lib/sabflow/n8n/internal/client-oauth2"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "src/types/**/*.d.ts",
    "src/lib/sabflow/n8n/**/*.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "n8n-master",
    "typebot.io-main",
    ".claude/worktrees"
  ]
}