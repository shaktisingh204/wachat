# Port the WS gateway binds to. The Next.js client + browsers connect here.
SABFLOW_WS_PORT=4002

# Shared secret used to verify SabFlow WS JWTs. Must match the value used by
# the Next.js app when minting tokens. >= 32 bytes recommended in production.
SABFLOW_WS_JWT_SECRET=changeme

# Redis used for pub/sub fan-out and future cross-instance state.
# The bundled docker-compose.yml exposes Redis on 127.0.0.1:6380 (not 6379)
# to avoid colliding with a host-native Redis.
REDIS_URL=redis://127.0.0.1:6380

# Optional OTLP exporter endpoint (HTTP, e.g. http://localhost:4318/v1/traces).
# Leave blank to disable OpenTelemetry export entirely.
OTLP_ENDPOINT=
