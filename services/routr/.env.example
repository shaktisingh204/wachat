# SabCall engine env — copy to the HOST environment that runs `sabcall-engine`.
#
# This is NOT read by the Docker stack (Routr + Asterisk). It is the env the
# host-run Rust engine (services/sabcall-engine) uses to talk to the Asterisk
# media tier over ARI and to expose its HTTP control surface to the Next.js app.
#
#   cd services/sabcall-engine
#   set -a && . ../routr/.env.example && set +a   # (after copying + editing)
#   cargo run
#
# Defaults below match the Asterisk config in services/routr/asterisk/.

# Master gate. The engine boots HTTP either way, but only connects to Asterisk
# and runs the Stasis loop when this is true.
SABCALL_ENABLED=true

# ── Asterisk ARI (the media tier published by the Docker stack on :8088) ──────
ASTERISK_ARI_URL=http://localhost:8088
ASTERISK_ARI_WS_URL=ws://localhost:8088
# Must match the [sabcall] user in services/routr/asterisk/ari.conf.
ASTERISK_ARI_USER=sabcall
ASTERISK_ARI_PASS=sabcall
# Must match Stasis(sabcall) in services/routr/asterisk/extensions.conf.
ASTERISK_ARI_APP=sabcall

# ── Engine HTTP control surface (consumed by the Next.js app) ────────────────
# Port the engine listens on (originate, hangup, pjsip.conf, routr.json, …).
PORT=4005
# Bearer token the Next.js side must present on control endpoints. CHANGE THIS.
SABCALL_ENGINE_TOKEN=change-me

# ── Mongo (CDRs, tenant SIP resource model) ──────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=test

# Where the engine writes synthesized TTS clips. MUST be readable by Asterisk —
# i.e. inside the path Asterisk serves sounds from. For the Dockerized Asterisk,
# mount a host dir to /var/lib/asterisk/sounds/sabcall and point both sides here.
ASTERISK_SOUNDS_DIR=/var/lib/asterisk/sounds/sabcall

# ── Optional integrations (leave unset to disable) ───────────────────────────
# HTTP TTS endpoint — POST {text, format} → audio bytes (cached in ASTERISK_SOUNDS_DIR).
# SABCALL_TTS_URL=http://localhost:5005/tts
# HTTP STT endpoint — POST {audioUrl} → {text}.
# SABCALL_STT_URL=http://localhost:5005/stt
# HTTP LLM endpoint — POST {system, prompt} → {text}; powers the autopilot voice agent.
# SABCALL_LLM_URL=http://localhost:5005/llm
# Next.js callback URL for call events (recording done, call ended, transcript ready).
# SABCALL_EVENTS_URL=http://localhost:3000/api/v1/sabcall/events
# WebSocket sink an `autopilot` call forks its audio to (real-time STT↔LLM↔TTS).
# SABCALL_AUTOPILOT_STREAM_URL=ws://localhost:5005/stream
