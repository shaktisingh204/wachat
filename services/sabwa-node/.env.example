# Port the Express server binds to. The Next.js engine-client defaults to :4001.
PORT=4001

# URL the Next.js web app uses to reach this service. Mirrors PORT above.
SABWA_ENGINE_URL=http://localhost:4001

# MongoDB connection URI. The engine reads/writes collections prefixed with `sabwa_`.
MONGO_URL=mongodb://localhost:27017/sabnode

# Redis used for pub/sub fan-out + queues.
REDIS_URL=redis://localhost:6379

# Shared service-to-service token. Must match SABWA_ENGINE_TOKEN in the Next.js .env.
# Sent by callers as the `X-Sabwa-Service-Token` header.
SABWA_ENGINE_TOKEN=devtoken-change-me

# Secret used to sign/verify SabWa JWTs (>= 32 bytes recommended).
SABWA_JWT_SECRET=please-change-me-32-bytes-or-more

# 32 raw bytes of key material, base64-encoded — used to encrypt the per-session
# Baileys auth state blob at rest in `sabwa_sessions.authState`.
AUTH_STATE_KEY=base64-encoded-32-byte-key

# Optional: log level (trace|debug|info|warn|error). Defaults to info.
LOG_LEVEL=info

# Tip: run `node scripts/gen-keys.js >> .env` to mint fresh AUTH_STATE_KEY,
# SABWA_JWT_SECRET, and SABWA_ENGINE_TOKEN values.
