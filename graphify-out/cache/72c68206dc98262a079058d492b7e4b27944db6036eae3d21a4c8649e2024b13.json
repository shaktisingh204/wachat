allee": "(\n    <div className=\"flex w-full flex-col gap-6\">\n      <CrmPageHeader\n        title=\"Time Report\"\n        subtitle=\"Group logged time by employee, project, or date. Export as CSV.\"\n        icon={BarChart3}\n        actions={\n          <ZoruButton\n            onClick={() =>\n              downloadCsv(\n                `time-report-${group}-${new Date().toISOString().slice(0, 10)}.csv`,\n                toCsv(rows, groupLabel),\n              )\n            }\n            disabled={rows.length === 0}\n          >\n            <Download className=\"h-4 w-4\" strokeWidth={1.75} />\n            Export CSV\n          </ZoruButton>\n        }\n      />\n\n      <ZoruCard className=\"p-6\">\n        <div className=\"flex flex-wrap items-end gap-3\">\n          <div className=\"min-w-[180px] flex-1\">\n            <ZoruLabel className=\"text-[11px] uppercase tracking-[0.18em] text-zoru-ink-muted\">\n              Group by\n            </ZoruLabel>\n            <ZoruSelect value={group} onValueChange={(v) => setGroup(v as Group)}>\n              <ZoruSelectTrigger className=\"mt-1 h-9 rounded-lg border-zoru-line bg-zoru-bg text-[13px]\">\n                <ZoruSelectValue />\n              </ZoruSelectTrigger>\n              <ZoruSelectContent>\n                <ZoruSelectItem value=\"employee\">Employee</ZoruSelectItem>\n                <ZoruSelectItem value=\"project\">Project</ZoruSelectItem>\n                <ZoruSelectItem value=\"date\">Date</ZoruSelectItem>\n              </ZoruSelectContent>\n            </ZoruSelect>\n          </div>\n          <div className=\"min-w-[140px] flex-1\">\n            <ZoruLabel className=\"text-[11px] uppercase tracking-[0.18em] text-zoru-ink-muted\">\n              From\n            </ZoruLabel>\n            <ZoruInput\n              type=\"date\"\n              value={from}\n              onChange={(e) => setFrom(e.target.value)}\n              className=\"mt-1 h-9 rounded-lg border-zoru-line bg-zoru-bg text-[13px]\"\n            />\n          </div>\n          <div className=\"min-w-[140px] flex-1\">\n            <ZoruLabel className=\"text-[11px] uppercase tracking-[0.18em] text-zoru-ink-muted\">\n              To\n            </ZoruLabel>\n            <ZoruInput\n              type=\"date\"\n              value={to}\n              onChange={(e) => setTo(e.target.value)}\n              className=\"mt-1 h-9 rounded-lg border-zoru-line bg-zoru-bg text-[13px]\"\n            />\n          </div>\n          <ZoruButton variant=\"outline\" onClick={refresh}>\n            <Filter className=\"h-4 w-4\" strokeWidth={1.75} />\n            Apply\n          </ZoruButton>\n          <ZoruButton\n            variant=\"ghost\"\n            onClick={()", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/crm/time-tracking/reports/page.tsx", "source_location": "L80"}, {"caller_nid": "page_timetrackingreportspage", "callee": "slice", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/crm/time-tracking/reports/page.tsx", "source_location": "L90"}, {"caller_nid": "page_timetrackingreportspage", "callee": "toISOString", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/crm/time-tracking/reports/page.tsx", "source_location": "L90"}, {"caller_nid": "page_timetrackingreportspage", "callee": "setFrom", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/crm/time-tracking/reports/page.tsx", "source_location": "L149"}, {"caller_nid": "page_timetrackingreportspage", "callee": "setTo", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/crm/time-tracking/reports/page.tsx", "source_location": "L150"}]}