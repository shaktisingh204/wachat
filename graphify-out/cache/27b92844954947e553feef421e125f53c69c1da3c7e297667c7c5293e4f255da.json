Kind=bill&fromId=${billId}`}\n        >\n          <FileMinus className=\"h-3.5 w-3.5\" /> Convert to debit note\n        </Link>\n      </ZoruButton>\n\n      <ZoruButton size=\"sm\" variant=\"outline\" onClick={() => setEmailOpen(true)}>\n        <Mail className=\"h-3.5 w-3.5\" /> Email\n      </ZoruButton>\n\n      <ZoruButton size=\"sm\" variant=\"outline\" asChild>\n        <a\n          href={`/dashboard/crm/purchases/expenses/${billId}?print=1`}\n          target=\"_blank\"\n          rel=\"noopener noreferrer\"\n        >\n          <Printer className=\"h-3.5 w-3.5\" /> Print\n        </a>\n      </ZoruButton>\n\n      <ZoruButton size=\"sm\" variant=\"outline\" asChild>\n        <Link\n          href={`/dashboard/crm/purchases/expenses/new?fromKind=bill&fromId=${billId}`}\n        >\n          <Copy className=\"h-3.5 w-3.5\" /> Duplicate\n        </Link>\n      </ZoruButton>\n\n      <ZoruButton size=\"sm\" variant=\"outline\" onClick={()", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/crm/purchases/expenses/_components/bill-detail-actions.tsx", "source_location": "L105"}, {"caller_nid": "bill_detail_actions_billdetailactions", "callee": "replace", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/crm/purchases/expenses/_components/bill-detail-actions.tsx", "source_location": "L115"}, {"caller_nid": "bill_detail_actions_billdetailactions", "callee": "map", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/crm/purchases/expenses/_components/bill-detail-actions.tsx", "source_location": "L121"}, {"caller_nid": "bill_detail_actions_billdetailactions", "callee": "setEmailOpen", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/crm/purchases/expenses/_components/bill-detail-actions.tsx", "source_location": "L158"}, {"caller_nid": "bill_detail_actions_async", "callee": "updateBillStatus", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard