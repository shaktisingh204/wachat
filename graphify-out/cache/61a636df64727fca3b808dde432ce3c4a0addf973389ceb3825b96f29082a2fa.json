3.exec(state.db, schema);\n\t\t}\n\t\tconsole.log('[DataWorker] Tables ensured successfully');\n\n\t\tstate.initialized = true;\n\t\tstate.version = version;\n\t})", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/n8n-master/packages/frontend/editor-ui/src/app/workers/data/worker.ts", "source_location": "L104"}, {"caller_nid": "worker_initialize", "callee": "error", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/n8n-master/packages/frontend/editor-ui/src/app/workers/data/worker.ts", "source_location": "L156"}, {"caller_nid": "worker_exec", "callee": "execOp", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/n8n-master/packages/frontend/editor-ui/src/app/workers/data/worker.ts", "source_location": "L167"}, {"caller_nid": "worker_query", "callee": "queryOp", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/n8n-master/packages/frontend/editor-ui/src/app/workers/data/worker.ts", "source_location": "L174"}, {"caller_nid": "worker_querywithparams", "callee": "queryWithParamsOp", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/n8n-master/packages/frontend/editor-ui/src/app/workers/data/worker.ts", "source_location": "L181"}, {"caller_nid": "worker_close", "callee": "closeOp", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/n8n-master/packages/frontend/editor-ui/src/app/workers/data/worker.ts", "source_location": "L188"}, {"caller_nid": "worker_loadnodetypes", "callee": "loadNodeTypesOp", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/n8n-master/packages/frontend/editor-ui/src/app/workers/data/worker.ts", "source_location": "L203"}, {"caller_nid": "worker_storeversion", "callee": "storeVersionOp", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/n8n-master/packages/frontend/editor-ui/src/app/workers/data/worker.ts", "source_location": "L210"}, {"caller_nid": "worker_getstoredversion", "callee": "getStoredVersionOp", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/n8n-master/packages/frontend/edi