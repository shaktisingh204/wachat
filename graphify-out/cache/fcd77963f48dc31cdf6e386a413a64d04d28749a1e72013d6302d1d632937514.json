elwal/Downloads/sabnode/src/app/dashboard/facebook/custom-ecommerce/manage/[shopId]/flow-builder/page.tsx", "source_location": "L587", "weight": 1.0}], "raw_calls": [{"caller_nid": "page_nodepreview", "callee": "(() => {\n    switch (node.type) {\n      case \"text\":\n      case \"input\":\n      case \"orderConfirmation\":\n        return (\n          <p className=\"whitespace-pre-wrap\">\n            {renderTextWithVariables(node.data.text)}\n          </p>\n        );\n      case \"image\":\n        return (\n          <div className=\"space-y-1\">\n            <div className=\"flex aspect-video w-full items-center justify-center rounded-[var(--zoru-radius)] bg-zoru-bg/50\">\n              <ImageIcon className=\"h-8 w-8 text-zoru-ink-subtle\" />\n            </div>\n            {node.data.caption ? (\n              <p className=\"whitespace-pre-wrap text-xs\">\n                {renderTextWithVariables(node.data.caption)}\n              </p>\n            ) : null}\n          </div>\n        );\n      case \"buttons\":\n        return (\n          <div className=\"space-y-2\">\n            <p className=\"whitespace-pre-wrap\">\n              {renderTextWithVariables(node.data.text)}\n            </p>\n            <div className=\"mt-2 space-y-1 border-t border-zoru-line pt-2\">\n              {(node.data.buttons || []).map(\n                (btn: ButtonConfig, index: number) => (\n                  <div\n                    key={btn.id || index}\n                    className=\"rounded-[var(--zoru-radius-sm)] bg-zoru-bg/50 py-1.5 text-center text-xs text-zoru-ink\"\n                  >\n                    {btn.text || `Button ${index + 1}`}\n                  </div>\n                ),\n              )}\n            </div>\n          </div>\n        );\n      case \"carousel\": {\n        const elementCount = node.data.elements?.length || 0;\n        return (\n          <p className=\"text-xs italic text-zoru-ink-muted\">\n            Sends a carousel with {elementCount} card(s).\n          </p>\n        );\n      }\n      case \"addToCart\":\n        return (\n          <p className=\"text-xs italic text-zoru-ink-muted\">\n            Adds &ldquo;{node.data.productName || \"product\"}&rdquo; to cart.\n          </p>\n        );\n      default:\n        return null;\n    }\n  })", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/facebook/custom-ecommerce/manage/[shopId]/flow-builder/page.tsx", "source_location": "L178"}, {"caller_nid": "page_handledatachange", "callee": "updateNodeData", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/facebook/custom-ecommerce/manage/[shopId]/flow-builder/page.tsx", "source_location": "L419"}, {"caller_nid": "page_addflowbutton", "callee": "toast", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/facebook/custom-ecommerce/manage/[shopId]/flow-builder/page.tsx", "source_location": "L435"}, {"caller_nid": "page_addflowbutton", "callee": "now", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/facebook/custom-ecommerce/manage/[shopId]/flow-builder/page.tsx", "source_location": "L444"}, {"caller_nid": "page_removeflowbutton", "callee": "filter", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/facebook/custom-ecommerce/manage/[shopId]/flow-builder/page.tsx", "source_location": "L450"}, {"caller_nid": "page_handleelementchange", "callee": "map", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/facebook/custom-ecommerce/manage/[shopId]/flow-builder/page.tsx", "source_location": "L461"}, {"caller_nid": "page_handleelementbuttonchange", "callee": "map", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/facebook/custom-ecommerce/manage/[shopId]/flow-builder/page.tsx", "source_location": "L474"}, {"caller_nid": "page_addelement", "callee": "toast", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/