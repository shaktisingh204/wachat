.5\" /> Merge\n            </ZoruButton>\n\n            {!resolvedish ? (\n                <ZoruButton\n                    size=\"sm\"\n                    onClick={() => runStatusChange('resolved', 'Resolved')}\n                    disabled={pending}\n                >\n                    <CheckCircle2 className=\"h-3.5 w-3.5\" /> Resolve\n                </ZoruButton>\n            ) : null}\n            {status !== 'closed' ? (\n                <ZoruButton\n                    variant=\"outline\"\n                    size=\"sm\"\n                    onClick={() => runStatusChange('closed', 'Closed')}\n                    disabled={pending}\n                >\n                    <Lock className=\"h-3.5 w-3.5\" /> Close\n                </ZoruButton>\n            ) : null}\n            {resolvedish ? (\n                <ZoruButton\n                    variant=\"outline\"\n                    size=\"sm\"\n                    onClick={() => runStatusChange('reopened', 'Re-opened')}\n                    disabled={pending}\n                >\n                    <RotateCcw className=\"h-3.5 w-3.5\" /> Re-open\n                </ZoruButton>\n            ) : null}\n\n            <ZoruButton\n                variant=\"outline\"\n                size=\"sm\"\n                onClick={()", "source_file": "/Users/harshkhandelwal/Downloads/sabnode/src/app/dashboard/crm/tickets/_components/ticket-detail-actions.tsx", "source_location": "L92"}]}