{
  "manifest_version": 3,
  "name": "SabNode Companion",
  "version": "1.0.0",
  "description": "Quick access to your SabNode workspace, broadcasts, and CRM from any tab.",
  "permissions": ["storage", "tabs", "notifications", "scripting"],
  "host_permissions": [
    "https://app.sabnode.com/*",
    "https://*.sabnode.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "SabNode"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.sabnode.com/*",
        "https://*.sabnode.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
